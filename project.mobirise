        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = \"color\")": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = \"image\")": {
              "background-image": "url(@bg-value)",
              "& when (@overlay)": {
                ".mbr-overlay": {
                  "background": "@overlayColor",
                  "opacity": "@overlayOpacity"
                }
              }
            },
            "img, .item-img": {
              "width": "100%",
              "& when (@autoSize)": {
                "height": "100%",
                "object-fit": "cover",
                "& when (@showCardTitle)": {
                  "height": "(@imageHeight * 100px)",
                  "object-fit": "cover"
                },
                "& when (@showText)": {
                  "height": "(@imageHeight * 100px)",
                  "object-fit": "cover"
                },
                "& when (@showButtons)": {
                  "height": "(@imageHeight * 100px)",
                  "object-fit": "cover"
                }
              }
            },
            ".item:focus, span:focus": {
              "outline": "none"
            },
            ".item": {
              "margin-bottom": "2rem"
            },
            "@media (max-width: 767px)": {
              ".item": {
                "margin-bottom": "1rem"
              }
            },
            "& when not (@spacing)": {
              ".row": {
                "margin-left": "0",
                "margin-right": "0"
              },
              ".item": {
                "padding": "0",
                "margin": "0"
              }
            },
            ".item-content": {
              "margin-top": "2rem",
              "padding": "0 2.25rem 2.25rem",
              "@media (min-width: 992px) and (max-width: 1200px)": {
                "padding": "0 1.5rem 1.5rem",
                "padding-top": "1rem",
                "margin-top": "1rem"
              },
              "@media (max-width: 767px)": {
                "padding": "2rem 1.5rem",
                "padding-top": "1rem",
                "margin-top": "1rem"
              },
              "display": "flex",
              "flex-direction": "column",
              "height": "100%"
            },
            ".item-wrapper": {
              "position": "relative",
              "background": "@cardsBg",
              "height": "100%",
              "display": "flex",
              "flex-flow": "column nowrap",
              ".item-footer": {
                "margin-top": "auto"
              }
            },
            ".mbr-section-title": {
              "color": "#373365",
              "text-align": "center"
            },
            ".item-title": {
              "text-align": "left"
            },
            ".item-subtitle": {
              "text-align": "left"
            },
            ".mbr-text, .item .mbr-section-btn": {
              "text-align": "justify",
              "color": "#373365"
            },
            ".content-head": {
              "max-width": "800px"
            }
          },
          "_name": "features04",
          "_sourceTheme": "startm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"features4 start cid-vcT2lcPehi\" group=\"Features\" id=\"features04-4v\" mbr-class=\"{'mbr-fullscreen': fullScreen, 'mbr-parallax-background': bg.parallax}\">\n\t<mbr-parameters>\n\t\t<header>Size</header>\n\t\t<input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n\t\t<input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"8\">\n\t\t<input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"3\">\n\t\t<select title=\"Columns\" name=\"cardsWidth\">\n\t\t\t<option value=\"12\">1</option>\n\t\t\t<option value=\"6\">2</option>\n\t\t\t<option value=\"4\" selected>3</option>\n\t\t\t<option value=\"3\">4</option>\n\t\t</select>\n\t\t<header>Show/Hide</header>\n\t\t<input type=\"checkbox\" name=\"showTitle\" title=\"Title\" checked>\n\t\t<input type=\"checkbox\" name=\"showSubtitle\" title=\"Subtitle\">\n\t\t<input type=\"checkbox\" name=\"showmainButtons\" title=\"Buttons\">\n\t\t<header>Cards</header>\n\t\t<input type=\"checkbox\" name=\"autoSize\" title=\"Auto Size\" checked>\n\t\t<input type=\"range\" name=\"imageHeight\" title=\"Height\" min=\"1\" max=\"8\" step=\"1\" value=\"3\" condition=\"autoSize && !(showButtons==false && showCardTitle==false && showText==false)\">\n\t\t<input type=\"checkbox\" title=\"Spacing\" name=\"spacing\" checked>\n\t\t<input type=\"checkbox\" name=\"showCardTitle\" title=\"Title\" checked>\n\t\t<input type=\"checkbox\" name=\"showText\" title=\"Text\" checked>\n\t\t<input type=\"checkbox\" name=\"showButtons\" title=\"Buttons\" checked>\n\t\t<input type=\"color\" name=\"cardsBg\" title=\"BG\" value=\"#ffffff\">\n\t\t<header>Background</header>\n\t\t<fieldset type=\"background\" parallax name=\"bg\" required>\n\t\t\t<input type=\"image\" title=\"Image\" value=\"https://images.unsplash.com/photo-1481627834876-b7833e8f5570?w=1920\">\n\t\t\t<input type=\"color\" title=\"Color\" value=\"#ffffff\" selected>\n\t\t</fieldset>\n\t\t<input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n\t\t<input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type == 'image'\">\n\t\t<input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.5\" condition=\"overlay && bg.type == 'image'\">\n\t</mbr-parameters>\n\t\n\t<div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\"></div>\n\t\n\t<div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n\t\t<div class=\"row justify-content-center\">\n\t\t\t<div class=\"col-12 content-head\">\n\t\t\t\t<div class=\"mbr-section-head mb-5\" mbr-if=\"showTitle || showSubtitle || showmainButtons\">\n\t\t\t\t\t<h4 class=\"mbr-section-title mbr-fonts-style align-center mb-0 display-2\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title\" style=\"color: #373365;\">\n\t\t\t\t\t\t<strong>Ressources bibliographiques</strong>\n\t\t\t\t\t</h4>\n\t\t\t\t\t<h5 class=\"mbr-section-subtitle mbr-fonts-style align-center mb-0 mt-4 display-7\" mbr-if=\"showSubtitle\" data-app-selector=\".mbr-section-subtitle, .mbr-section-head .mbr-section-btn\">\n\t\t\t\t\t\tDocuments essentiels pour le dialogue islamo-catholique\n\t\t\t\t\t</h5>\n\t\t\t\t\t<div class=\"mbr-section-btn align-center item-footer mb-0 mt-4\" mbr-if=\"showmainButtons\" data-toolbar=\"-mbrBtnMove,-mbrBtnAdd\" mbr-buttons mbr-theme-style=\"display-7\">\n\t\t\t\t\t\t<a href=\"bibliographie.html\" class=\"btn item-btn btn-primary\">Voir toute la bibliographie</a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\t\t\n\t\t<div class=\"row\" mbr-class=\"{'justify-content-center': cardsWidth == 12}\">\n\t\t\t<!-- Card 1: Nostra Aetate -->\n\t\t\t<div class=\"item features-image col-12 col-md-6 col-lg-{{cardsWidth}} active\">\n\t\t\t\t<div class=\"item-wrapper resource-card\" mbr-style=\"{'background-color': cardsBg}\" mbr-class=\"{'h-100': spacing}\">\n\t\t\t\t\t<div class=\"item-img resource-img\">\n\t\t\t\t\t\t<img src=\"@PROJECT_PATH@/assets/images/leon-xiv-nostra-aetate-1024x450.webp\" alt=\"Nostra Aetate - Vatican II\" data-slide-to=\"0\" data-bs-slide-to=\"0\" loading=\"lazy\">\n\t\t\t\t\t\t<div class=\"resource-overlay\">\n\t\t\t\t\t\t\t<h5 class=\"item-title mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".item-title\" mbr-if=\"showCardTitle\">\n\t\t\t\t\t\t\t\t<strong>Nostra aetate (1965)</strong>\n\t\t\t\t\t\t\t</h5>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"item-content resource-content\" mbr-if=\"showText || showButtons\" mbr-class=\"{'p-3': spacing}\">\n\t\t\t\t\t\t<p class=\"mbr-text mbr-fonts-style display-7\" mbr-if=\"showText\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-text, .item .mbr-section-btn\" style=\"color: #373365;\">\n\t\t\t\t\t\t\tDéclaration du concile Vatican II sur les relations de l’Église avec les religions non chrétiennes, Nostra aetate opère un véritable changement de paradigme : en quelques paragraphes denses, l’Église y reconnaît les semences de vérité et de sainteté présentes dans les autres traditions religieuses et appelle à dépasser la méfiance héritée de l’histoire. Elle ouvre ainsi un chemin de respect, de rencontre et de collaboration, en particulier avec le judaïsme et l’islam, au service de la dignité de toute personne humaine et de la paix entre les peuples. Ce texte fondateur demeure aujourd’hui encore la charte de base de l’attitude de l’Église catholique envers les croyants d’autres religions, et inspire de nombreuses initiatives de dialogue.\n\t\t\t\t\t\t</p>\n\t\t\t\t\t\t<div class=\"mbr-section-btn item-footer\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove,-mbrBtnAdd\" mbr-buttons mbr-theme-style=\"display-7\">\n\t\t\t\t\t\t\t<a href=\"https://www.vatican.va/archive/hist_councils/ii_vatican_council/documents/vat-ii_decl_19651028_nostra-aetate_fr.html\" class=\"btn item-btn btn-primary display-7\" target=\"_blank\" rel=\"noopener noreferrer\">Texte complet</a>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t\t\n\t\t\t<!-- Card 2: Charte d'Abu Dhabi -->\n\t\t\t<div class=\"item features-image col-12 col-md-6 col-lg-{{cardsWidth}}\">\n\t\t\t\t<div class=\"item-wrapper resource-card\" mbr-style=\"{'background-color': cardsBg}\" mbr-class=\"{'h-100': spacing}\">\n\t\t\t\t\t<div class=\"item-img resource-img\">\n\t\t\t\t\t\t<img src=\"@PROJECT_PATH@/assets/images/cq5dam.thumbnail.cropped.750.422.webp\" alt=\"Charte d'Abu Dhabi 2019\" data-slide-to=\"1\" data-bs-slide-to=\"1\" loading=\"lazy\">\n\t\t\t\t\t\t<div class=\"resource-overlay\">\n\t\t\t\t\t\t\t<h5 class=\"item-title mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".item-title\" mbr-if=\"showCardTitle\">\n\t\t\t\t\t\t\t\t<strong>Charte d'Abu Dhabi (2019)</strong>\n\t\t\t\t\t\t\t</h5>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"item-content resource-content\" mbr-if=\"showText || showButtons\" mbr-class=\"{'p-3': spacing}\">\n\t\t\t\t\t\t<p class=\"mbr-text mbr-fonts-style display-7\" mbr-if=\"showText\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-text, .item .mbr-section-btn\" style=\"color: #373365;\">\n\t\t\t\t\t\t\tSigné conjointement par le pape François et le grand imam d’al‑Azhar à Abu Dhabi en 2019, le Document sur la fraternité humaine pour la paix mondiale et la coexistence commune – souvent appelé « Charte d’Abu Dhabi » – constitue une étape majeure du rapprochement entre responsables chrétiens et musulmans. Il affirme avec force que la foi en Dieu ne peut jamais justifier la haine, la violence ou le terrorisme, mais qu’elle engage au contraire les croyants sur la voie du respect réciproque, de la justice sociale et de la défense des plus vulnérables. Ce texte propose un véritable pacte éthique et spirituel pour notre temps, invitant les religions à se mettre ensemble au service de l’amitié sociale, de la citoyenneté partagée et d’une fraternité universelle ouverte à tous, croyants ou non.\n\t\t\t\t\t\t</p>\n\t\t\t\t\t\t<div class=\"mbr-section-btn item-footer\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove,-mbrBtnAdd\" mbr-buttons mbr-theme-style=\"display-7\">\n\t\t\t\t\t\t\t<a href=\"https://www.vatican.va/content/francesco/fr/travels/2019/outside/documents/papa-francesco_20190204_documento-fratellanza-umana.html\" class=\"btn item-btn btn-primary display-7\" target=\"_blank\" rel=\"noopener noreferrer\">Texte complet</a>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t\t\n\t\t\t<!-- Card 3: Document CEF 2021 -->\n\t\t\t<div class=\"item features-image col-12 col-md-6 col-lg-{{cardsWidth}}\">\n\t\t\t\t<div class=\"item-wrapper resource-card\" mbr-style=\"{'background-color': cardsBg}\" mbr-class=\"{'h-100': spacing}\">\n\t\t\t\t\t<div class=\"item-img resource-img\">\n\t\t\t\t\t\t<a href=\"https://www.editionsducerf.fr/librairie/livre/19215/l-eglise-catholique-et-les-relations-avec-les-musulmans\" target=\"_blank\" rel=\"noopener noreferrer\">\n\t\t\t\t\t\t\t<img src=\"@PROJECT_PATH@/assets/images/61gm7vyzzil.-ac-uf8941000-ql80-676x1000.webp\" alt=\"Document CEF 2021\" data-slide-to=\"2\" data-bs-slide-to=\"2\" loading=\"lazy\">\n\t\t\t\t\t\t</a>\n\t\t\t\t\t\t<div class=\"resource-overlay\">\n\t\t\t\t\t\t\t<h5 class=\"item-title mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".item-title\" mbr-if=\"showCardTitle\">\n\t\t\t\t\t\t\t\t<strong>Document CEF 2021</strong>\n\t\t\t\t\t\t\t</h5>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"item-content resource-content\" mbr-if=\"showText || showButtons\" mbr-class=\"{'p-3': spacing}\">\n\t\t\t\t\t\t<p class=\"mbr-text mbr-fonts-style display-7\" mbr-if=\"showText\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-text, .item .mbr-section-btn\" style=\"color: #373365;\">\n\t\t\t\t\t\t\tPublié par la Conférence des évêques de France, ce compendium rassemble de manière structurée l’enseignement de l’Église et l’expérience pastorale accumulée en France sur les relations avec les musulmans. Il offre des repères théologiques, historiques et juridiques, mais aussi des pistes concrètes pour les communautés chrétiennes, les prêtres, les diacres et les laïcs engagés, afin de vivre au quotidien une rencontre respectueuse, lucide et fraternelle avec les musulmans, dans le cadre de la société française et de la laïcité. Ce document se veut à la fois outil de formation et guide pratique : il aide à discerner les enjeux missionnaires et citoyens du dialogue islamo‑catholique, à prévenir les incompréhensions et à encourager des initiatives locales de rencontre, de coopération et de prière pour la paix.\n\t\t\t\t\t\t</p>\n\t\t\t\t\t\t<div class=\"mbr-section-btn item-footer\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove,-mbrBtnAdd\" mbr-buttons mbr-theme-style=\"display-7\">\n\t\t\t\t\t\t\t<a href=\"https://www.laprocure.com/product/25517/eglise-catholique-conference-episcopale-francaise-l-eglise-catholique-et-les-relations-avec-les-musulmans-compendium\" class=\"btn item-btn btn-primary display-7\" target=\"_blank\" rel=\"noopener noreferrer\">Commander</a>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\t</div>\n\n\t<style>\n\t\t/* ===== CORRECTION ESPACE APRÈS TEXTE UNIQUEMENT ===== */\n\t\t/* Laisse le contrôle de hauteur d'image aux paramètres Mobirise */\n\n\t\t/* Card structure flex sans forcer la hauteur totale */\n\t\t.resource-card {\n\t\t\tbackground: #ffffff;\n\t\t\tborder-radius: 12px;\n\t\t\toverflow: hidden;\n\t\t\tbox-shadow: 0 4px 20px rgba(55, 51, 101, 0.12);\n\t\t\ttransition: all 0.3s ease;\n\t\t\tdisplay: flex;\n\t\t\tflex-direction: column;\n\t\t}\n\n\t\t.resource-card:hover {\n\t\t\ttransform: translateY(-8px);\n\t\t\tbox-shadow: 0 12px 40px rgba(55, 51, 101, 0.2);\n\t\t}\n\n\t\t/* Conteneur image - PAS DE HAUTEUR FIXE ICI */\n\t\t/* La hauteur est contrôlée par le paramètre Mobirise imageHeight */\n\t\t.resource-img {\n\t\t\tposition: relative;\n\t\t\toverflow: hidden;\n\t\t\tflex-shrink: 0;\n\t\t}\n\n\t\t.resource-img img {\n\t\t\twidth: 100%;\n\t\t\tobject-fit: cover;\n\t\t\ttransition: transform 0.5s ease;\n\t\t}\n\n\t\t.resource-card:hover .resource-img img {\n\t\t\ttransform: scale(1.05);\n\t\t}\n\n\t\t/* Overlay dégradé */\n\t\t.resource-overlay {\n\t\t\tposition: absolute;\n\t\t\tbottom: 0;\n\t\t\tleft: 0;\n\t\t\tright: 0;\n\t\t\tbackground: linear-gradient(to top, rgba(55, 51, 101, 0.95) 0%, rgba(55, 51, 101, 0.6) 60%, transparent 100%);\n\t\t\tpadding: 40px 15px 15px;\n\t\t\tcolor: #ffffff;\n\t\t}\n\n\t\t.resource-overlay .item-title {\n\t\t\tcolor: #ffffff !important;\n\t\t\tmargin: 0;\n\t\t\tfont-size: 1.1rem;\n\t\t\tline-height: 1.3;\n\t\t\ttext-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);\n\t\t}\n\n\t\t/* ===== CORRECTION PRINCIPALE : CONTENU COMPACT ===== */\n\t\t.resource-content {\n\t\t\tpadding: 0.75rem 1rem 0.5rem;\n\t\t\tflex-grow: 0;\n\t\t\tdisplay: flex;\n\t\t\tflex-direction: column;\n\t\t}\n\n\t\t/* Texte sans espace excessif */\n\t\t.resource-content .mbr-text {\n\t\t\tmargin-bottom: 0.5rem !important;\n\t\t\tmargin-top: 0 !important;\n\t\t\tline-height: 1.5;\n\t\t\tfont-size: 0.9rem;\n\t\t}\n\n\t\t/* Supprimer marges internes des paragraphes */\n\t\t.resource-content .mbr-text p {\n\t\t\tmargin-bottom: 0 !important;\n\t\t}\n\n\t\t/* Bouton collé au texte */\n\t\t.resource-card .item-footer {\n\t\t\tmargin-top: 0 !important;\n\t\t\tpadding-top: 0 !important;\n\t\t\tpadding-bottom: 0.25rem;\n\t\t}\n\n\t\t.resource-card .btn-primary {\n\t\t\tbackground: #373365;\n\t\t\tborder-color: #373365;\n\t\t\ttransition: all 0.2s ease;\n\t\t\tmargin-top: 0 !important;\n\t\t\tmargin-bottom: 0 !important;\n\t\t\tpadding: 0.375rem 0.75rem;\n\t\t\tfont-size: 0.85rem;\n\t\t}\n\n\t\t.resource-card .btn-primary:hover {\n\t\t\tbackground: #ffffff;\n\t\t\tcolor: #373365;\n\t\t}\n\n\t\t/* Override h-100 seulement sur le contenu, pas sur l'image */\n\t\t.resource-card .item-wrapper.h-100 {\n\t\t\theight: auto;\n\t\t}\n\n\t\t/* Responsive */\n\t\t@media (max-width: 768px) {\n\t\t\t.resource-overlay {\n\t\t\t\tpadding: 30px 12px 12px;\n\t\t\t}\n\n\t\t\t.resource-overlay .item-title {\n\t\t\t\tfont-size: 1rem;\n\t\t\t}\n\n\t\t\t.resource-content {\n\t\t\t\tpadding: 0.5rem 0.75rem 0.25rem;\n\t\t\t}\n\n\t\t\t.resource-content .mbr-text {\n\t\t\t\tfont-size: 0.85rem;\n\t\t\t\tmargin-bottom: 0.4rem !important;\n\t\t\t}\n\t\t}\n\t</style>\n</section>",
          "_cid": "vcT2lcPehi",
          "_anchor": "features04-4v",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "& when (@bg-type = \"color\")": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = \"image\")": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".card-content-text": {
              "@media (max-width: 767px)": {
                "padding": "0 1.5rem 1.5rem 1.5rem"
              },
              "@media (min-width: 768px)": {
                "padding": "0 2.25rem 2.25rem 2.25rem"
              },
              "@media (min-width: 992px)": {
                "padding": "1rem 4rem 4rem 4rem"
              }
            },
            ".card-wrapper": {
              "background": "@wrapBgColor"
            },
            ".mbr-text, .mbr-section-btn": {
              "color": "#373365",
              "text-align": "left"
            },
            ".card-title, .card-box": {
              "text-align": "left",
