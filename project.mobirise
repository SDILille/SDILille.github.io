          "_name": "list06",
          "_sourceTheme": "startm5",
          "_customHTML": "\n\n\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <link href=\"https://fonts.googleapis.com/icon?family=Material+Icons\" rel=\"stylesheet\">\n    <style>\n        .material-icons {\n            font-size: 20px;\n            vertical-align: middle;\n            margin-right: 8px;\n            color: #35386b;\n        }\n    </style>\n\n\n<section data-bs-version=\"5.1\" class=\"list06\" group=\"List\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"3\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"3\">\n        <input type=\"range\" name=\"textWidth\" title=\"Width\" min=\"4\" max=\"12\" value=\"12\" step=\"1\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showMainTitle\">\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showMainSubtitle\">\n        <input type=\"checkbox\" title=\"Position\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Date\" name=\"showSubtitle\" checked>\n        <input type=\"checkbox\" title=\"List 1\" name=\"showList1\" checked>\n        <input type=\"checkbox\" title=\"List 2\" name=\"showList2\">\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\">\n        <input type=\"color\" title=\"Card BG\" name=\"cardbg\" value=\"#ffffff\" selected>\n        <input type=\"color\" title=\"Bullet Color\" name=\"iconColor\" value=\"#35386b\" selected>\n        <header>Background</header>\n        <input type=\"color\" title=\"Color\" name=\"bgColor\" value=\"#edefeb\">\n    </mbr-parameters>\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"col-12 mb-5 content-head\" mbr-if=\"showMainTitle || showMainSubtitle\">\n            <h3 class=\"mbr-section-title mbr-fonts-style align-center mb-0\" mbr-theme-style=\"display-2\" mbr-if=\"showMainTitle\" data-app-selector=\".mbr-section-title\">\n                <b>Bibliographie</b>\n            </h3>\n            <h5 class=\"mbr-section-subtitle mbr-fonts-style align-center mb-0 mt-4\" mbr-theme-style=\"display-7\" mbr-if=\"showMainSubtitle\" data-app-selector=\".mbr-section-subtitle\">\n                Lorem ipsum dolor sit amet, consectetur adipiscing elit.\n            </h5>\n        </div>\n        <div class=\"row justify-content-center\">\n            <div class=\"col-12 col-lg-{{textWidth}}\">\n                <div class=\"item features-without-image col-12 active\">\n                    <div class=\"item-wrapper\">\n                        <h5 class=\"mbr-card-title mbr-fonts-style mt-0 mb-3\" mbr-if=\"showTitle\" data-app-selector=\".mbr-card-title\" mbr-theme-style=\"display-5\">\n                            <b>Bibliographie</b></h5>\n                        <h6 class=\"mbr-card-subtitle mbr-fonts-style mt-0 mb-4\" mbr-if=\"showSubtitle\" data-app-selector=\".mbr-card-subtitle\" mbr-theme-style=\"display-7\">Octobre 2025.</h6>\n                        <h6 class=\"mbr-card-subtitle mbr-fonts-style mt-0 mb-3\" mbr-if=\"showList1\" data-app-selector=\".mbr-card-subtitle\" mbr-theme-style=\"display-7\"><i>Etablie par fr. Jean-François Bour.</i></h6>\n                        <div class=\"counter-container mbr-text mbr-fonts-style\" mbr-if=\"showList1\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-text\" data-multiline mbr-article>\n                            <div><b><u>Approches historiques et géographiques</u></b></div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Arkoun M.</b> (dir.), <i>Histoire de l'islam et des musulmans en France du Moyen Âge à nos jours</i>, Paris, Albin Michel, 2006.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Amir-Moezzi M.-A.</b> et <b>Lory P.</b>, <i>Petite histoire de l'islam</i>, Librio (Flammarion), 2007, 94 p. (et J'ai Lu).</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Godard B.</b>, <i>La question musulmane en France, un état des lieux sans concessions</i>, Fayard, 2015, 350 p.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Francis Messner</b> (dir.), <i>Le statut des ministres du culte musulman en France</i>, P. Univ. Strasbourg, 2021, 284 p.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Dupont A.L.</b>, <i>Atlas de l'islam</i>, éd. Autrement, 2022, 96 p.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Tolan J.</b>, <i>Nouvelle histoire de l'islam, VIIe-XXIe s.</i>, Tallandier, 2022.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Jamel El-Hamri</b>, <i>Les musulmans dans l'histoire de France, une place singulière</i>, AFPI, 2023, 128 p.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Franck Frégosi</b>, <i>Gouverner l'islam en France</i>, Seuil, 2025, 381 p.</div><div><br></div>\n                            <div><b><u>Le Coran</u></b></div>\n                            <div><span class=\"material-icons\">menu_book</span><i>Coran</i>, Traduction de <b>Denise Masson</b>, Paris, Gallimard (Reconnue par Al-Azhar, Le Caire).</div>\n                            <div><span class=\"material-icons\">menu_book</span><i>Coran</i>, Traduction de <b>Mohammed Hamidullah</b> (bilingue avec introduction et notes).</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Amir-Moezzi M.-A.</b> (dir.), <i>Dictionnaire du Coran</i> – coll. Bouquins, Robert Laffont, Paris, 2007, 981 p.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Jomier J.</b>, <i>Les grands thèmes du Coran</i>, Paris, Le Cerf, 1999.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Monneret J.-L.</b>, <i>Les grands thèmes du Coran, classement thématique (versets)</i>, Dervy, 2003, 725 p.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Reeber M.</b>, <i>Le Coran (guide de lecture)</i>, Les essentiels Milan, Toulouse, 2002, 63 p.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Benzine R.</b>, <i>Le Coran expliqué aux jeunes</i>, Seuil, Paris, 2013, 200 p.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Gobillot G.</b> et <b>Cuypers M.</b>, <i>Idées reçues sur le Coran, Entre tradition islamique et lecture moderne</i>, Le Cavalier Bleu, Paris, 2021, 145 p.</div><div><br></div>\n                            <div><b><u>Doctrines et traditions</u></b></div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Gardet L.</b>, <i>L'Islam, religion et communauté</i>, Desclée de Brouwer, 1982.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Jomier J.</b>, <i>Pour connaître l'islam</i>, Cerf, Paris, 1988, 200 p.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Alili R.</b>, <i>Qu'est-ce que l'islam ?</i>, La Découverte, Paris, 1996.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Platti E.</b>, <i>Islam... Étrange ?</i>, Cerf, Paris, 2000, 338 p.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Brunin J.-L.</b>, <i>L'Islam... tout simplement</i>, L'Atelier, Paris, 2003, 191 p.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Borrmans M.</b>, <i>Pour comprendre les musulmans</i>, Mediaspaul, 2010, 63 p.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Candiard A.</b>, <i>Comprendre l'islam ou plutôt : pourquoi on n'y comprend rien</i>, Champs actuel, 2016.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Claverie P.</b>, <i>Petite introduction à l'islam</i>, Cerf, Paris, 2010, 110 p.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Delcambre A.-M.</b>, <i>L'islam</i>, La Découverte, Paris, 2004, 125 p.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Reeber M.</b>, <i>L'islam</i>, Les essentiels Milan, Toulouse, 2005, 63 p.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Stehly Ralph</b>, <i>Introduction à l'islam, fondements et croyances</i>, éd. Erick Bonnier, 2019.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Abdennour Bidar</b>, <i>Les cinq piliers de l'islam et leur sens initiatique</i>, Albin Michel, 2023, 225 p.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Lepesqueur Y.</b>, <i>L'islam et l'Ordre du monde</i>, Tallandier, 2025.</div><div><br></div>\n                            <div><b><u>Études spécialisées</u></b></div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Amir Moezzi M.A.</b>, <i>Le guide divin dans le shî`isme originel</i>, Verdier, 2007, 348 p.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Chabbi J.</b>, <i>Les Trois Piliers de l'islam, Lecture anthropologique du Coran</i>, Seuil, 2016.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Chabbi J.</b>, <i>Le Coran décrypté : Figures bibliques en Arabie</i>, Poche, Paris, 2014, 415 p.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Dye Dominique</b> et <b>Amir-Moezzi Mohammed-Ali</b> (dir.), <i>Le Coran des historiens</i>, Cerf, Paris, 2019 (3 vol.).</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Djait H.</b>, <i>La grande discorde, Religion et politique dans l'islam des origines</i>, Gallimard, Paris, 1989.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Coulson N.J.</b>, <i>Histoire du droit islamique</i>, PUF, Paris, 1995, 234 p.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Jolivet J.</b>, <i>La théologie et les Arabes</i>, Cerf, Paris, 2002, 120 p.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Cruz Hernandez M.</b>, <i>Histoire de la pensée en terre d'islam</i>, éd. Desjonquères, 2005, 951 p.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Boubakeur Si Hamza</b>, <i>Traité moderne de théologie islamique</i>, Paris, Maisonneuve et Larose, 2003.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Arminjon Constance</b>, <i>Brève histoire de la pensée politique en Islam contemporain</i>, Labor &amp; Fides, 2017.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Arminjon C.</b>, <i>Vers une nouvelle théologie en Islam</i>, CNRS éd., 2022, 379 p.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Hanne Olivier</b>, <i>Histoire du Djihad, des origines de l'islam à Daech</i>, Tallandier, 2024, 505 p.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Pisani E.</b> (dir.), <i>Théologies musulmanes du pluralisme religieux</i>, Cerf Patrimoines, 2024.</div>\n                            <div><b><u>Débats</u></b></div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Delorme Ch.</b>, <i>L'islam que j'aime, l'islam qui m'inquiète</i>, Paris, Bayard, 2012, 244 p.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Oubrou T.</b>, <i>Un imam en colère</i>, Paris, Bayard, 2012, 180 p.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Abdelkrim F.</b>, <i>Pourquoi j'ai cessé d'être islamiste : Itinéraire au cœur de l'islam en France</i>, éd. Les points sur les I, 2015, 264 p.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Dounia Bouzar</b>, <i>Désamorcer l'islam radical : Ces dérives sectaires qui défigurent l'islam</i>, L'Atelier, 2014.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Bencheikh Ghaleb</b>, <i>Petit manuel pour un islam à la mesure des hommes</i>, JC Lattès, 2018.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Ben Achour Yadh</b> et <b>Dermange François</b>, <i>Quel islam pour l'Europe</i>, Labor et Fides, 2017.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Adrien Candiard</b>, <i>Du fanatisme. Quand la religion est malade</i>, Les Éditions du Cerf, 2020, 96 p.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Platti Emilio</b>, <i>Que penser de... ? L'islamisme</i>, Fidélité, Paris-Bruxelles, 2016, 117 p.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Rémi Brague</b>, <i>Sur l'Islam</i>, Gallimard, 2023, 385 p.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Hugo Micheron</b>, <i>La colère et l'oubli – les démocraties face au jihadisme européen</i>, Folio, nov. 2024.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Omero Marongiu</b> et alii, <i>Qu'est-ce qu'un islam libéral ?</i>, éd. Atlandes, 2023, 174 p.</div><div><br></div>\n                            <div><b><u>Témoignages</u></b></div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Karima Berger</b>, <i>Éclats d'Islam : Chroniques d'un itinéraire spirituel</i>, Albin Michel, mars 2009, 263 p.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Reille Christian</b>, <i>Un jésuite en terre d'Islam</i>, Lessius, 2017.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Christine Ray</b>, <i>Christian de Chergé, une biographie spirituelle</i>, Albin Michel, 1998.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Chahina-Marie Baret</b>, <i>Musulmane disciple du Christ</i>, Fidélité, 2022, 112 p.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>R. Hamel</b> et <b>N. Kermiche</b>, <i>Sœurs de douleur</i>, éd. XO, 2025, 239 p.</div><div><br></div>\n                            <div><b><u>Autour du dialogue islamo-chrétien</u></b></div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Arnaldez Roger</b>, <i>Jésus, fils de Marie prophète de l'islam</i>, Desclée, 1980.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Jean-Jacques Pérennès</b>, <i>Passion Kaboul, le père Serge de Beaureceuil</i>, 2014, 355 p.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Michel Dubost</b>, <i>Catholiques - Musulmans, une fraternité critique</i>, Mediaspaul, mai 2014, 246 p.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Adrien Candiard</b>, <i>En finir avec la tolérance ? Différences religieuses et rêve andalou</i>, PUF, 2014, 112 p.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Borrmans Maurice</b>, <i>Chrétiens et musulmans : ressemblances et diversité</i>, Mediaspaul, 2015, 144 p.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Conférence des Évêques de France</b>, <i>L'Église catholique et les relations avec les musulmans - Compendium</i>, Bayard – Cerf – Mame, 2021.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Gira Dennis</b>, <i>Le dialogue à la portée de tous, ou presque</i>, Bayard, 2012.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Druel Jean</b>, <i>Je crois en Dieu, moi non plus ! Principes du dialogue interreligieux</i>, Cerf, 2017.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Salenson Christian</b>, <i>Cette Église révélée par les martyrs d'Algérie</i>, Nouvelle Cité, 2020.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Younes M.</b>, <i>Les approches chrétiennes de l'islam - Tensions, déplacements, enjeux</i>, Cerf, 2020, 364 p.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Henri de La Hougue</b>, <i>L'Église et la diversité des religions</i>, Salvator, 2021.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Gira D.</b>, <i>Le dialogue interreligieux, une perspective chrétienne</i>, éd. Chemins de dialogue, 2022.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Guggenheim A.</b> (dir.), <i>Une pratique chrétienne de la rencontre avec l'islam et les musulmans</i>, Parole et Silence, 2022.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>J.-Marc Aveline</b>, <i>Dieu a tant aimé le monde – Petite théologie de la mission</i>, Cerf, 2023, 157 p.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>C. Hamza</b>, <b>X. Manzano</b>, <b>C. Roucou</b>, <i>Dire sa foi</i>, Chemins de dialogue, 2024, 98 p.</div><div><br></div>\n                            <div><b><u>Documents épiscopaux</u></b></div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Épiscopat (2024-10)</b>, « <i>Les 50 ans du SNRM, L'engagement de l'Église de France pour le dialogue avec les musulmans</i> », Conf. des Évêques de France, sept. 2024.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Épiscopat</b>, « <i>60 ans de Nostra Aetate</i> », février 2025.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>En Dialogue</b>, « <i>Discours et conférences de l'anniversaire du SNRM, 1973-2023</i> », CEF, juin 2025, 70 p.</div>\n                            <div><span class=\"material-icons\">menu_book</span><b>Salenson Christian</b>, <i>Au cœur des autres – petite théologie du dialogue</i>, Nouvelle Cité, 2025, 259 p.</div>\n                        </div>\n                        <h6 class=\"mbr-card-subtitle mbr-fonts-style mt-0 mb-3\" mbr-if=\"showList2\" data-app-selector=\".mbr-card-subtitle\" mbr-theme-style=\"display-7\">\n                            <b>Achievements</b>\n                        </h6>\n                        <div class=\"counter-container mbr-text mbr-fonts-style\" mbr-if=\"showList2\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-text\" data-multiline mbr-article>\n                            <ul>\n                                <li>Created a fresh logo for a prominent company that garnered positive feedback from both its clientele and staff.</li>\n                                <li>Crafted a social media campaign resulting in over 1 million impressions.</li>\n                            </ul>\n                        </div>\n                        <div mbr-buttons mbr-theme-style=\"display-7\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\">\n                            <a class=\"btn btn-white\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                                Learn more\n                            </a>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>\n\n",
          "_cid": "vcreqW0oDQ",
          "_anchor": "list06-4m",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".image-wrap img": {
              "width": "100%",
              "@media (min-width: 992px)": {
                "display": "block",
                "margin": "auto",
                "width": "(@imageWidth * 10%)"
              }
            }
          },
          "_name": "header10",
          "_sourceTheme": "mobirise5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"header10\" group=\"Headers\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"3\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"3\" condition=\"fullScreen == false\">\n        <input type=\"range\" name=\"imageWidth\" title=\"Image Width\" min=\"1\" max=\"10\" step=\"1\" value=\"3\" condition=\"showImage\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\" checked>\n        <input type=\"checkbox\" title=\"Image\" name=\"showImage\" checked>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"../_images/background7.jpg\" parallax>\n            <input type=\"color\" title=\"Color\" value=\"#ffffff\" selected>\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"../_images/background13.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#2299aa\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.1\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div class=\"align-center\" mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row justify-content-center\">\n            <div class=\"col-md-12 col-lg-9\">\n                <h1 class=\"mbr-section-title mbr-fonts-style mb-3\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-1\" mbr-if=\"showTitle\"><b>\"Dire sa foi\"</b></h1>\n                <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .mbr-section-btn\">Auteurs : Colette Hamza, Christophe Roucou, Xavier Manzano\n<br>© Publications Chemins de Dialogue, 2024</p>\n                <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn mt-3\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\"><a class=\"btn btn-secondary\" href=\"https://icm.catholique.fr/cheminsdedialogue/d/\" data-app-placeholder=\"Type Text\" target=\"_blank\">Commander</a></div>\n                <div class=\"image-wrap mt-4\" mbr-if=\"showImage\">\n                    <img src=\"@PROJECT_PATH@/assets/images/1545852-1-300x499.webp\" alt=\"Mobirise Website Builder\" title>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "vcTOnGZwqg",
          "_anchor": "header10-52",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = \"color\")": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = \"image\")": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".item": {
              "display": "flex",
              "align-items": "center",
              "margin-bottom": "2rem",
              "@media (min-width: 991px)": {
                "margin-bottom": "4rem"
              },
              "&:last-child": {
                ".icon-box": {
                  "&:before": {
                    "display": "none"
                  }
                }
              },
              "& when not (@showCardText)": {
                "& when (@showCardTitle)": {
                  "margin-bottom": "4rem"
                }
              },
              "& when not (@showCardTitle)": {
                "& when (@showCardText)": {
                  "margin-bottom": "4rem"
                }
              },
              "& when not (@showArrows)": {
                "align-items": "flex-start"
              },
              "&.last": {
                ".icon-box": {
                  "&:before": {
                    "display": "none"
                  }
                }
              }
            },
            ".icon-box": {
              "background": "@iconColor",
              "width": "60px",
              "min-width": "60px",
              "height": "60px",
              "border-radius": "50%",
              "margin-right": "2rem",
              "display": "flex",
              "justify-content": "center",
              "align-items": "center",
              "position": "relative",
              "@media (max-width: 768px)": {
                "margin-right": "1rem"
              },
              "& when (@showArrows)": {
                "&::before": {
                  "content": "\"\\e925\"",
                  "font-family": "Moririse2 !important",
                  "position": "absolute",
                  "font-size": "~\"@{arrowsSize}px\"",
                  "left": "50%",
                  "top": "~\"@{arrowsTop}%\"",
                  "& when (@fullWidth)": {
                    "top": "100%"
                  },
                  "color": "@iconColor",
                  "transform": "translate(-50%, 0)"
                }
              }
            },
            "span": {
              "font-size": "2rem",
              "color": "contrast(@iconColor, darken(@iconColor, 50%), #ffffff, 60%)"
            },
            "@media (max-width: 991px)": {
              ".card": {
                "margin-bottom": "2rem"
              },
              ".card-wrapper": {
                "margin-bottom": "2rem"
              },
              ".icon-box": {
                "& when (@showArrows)": {
                  "&::before": {
                    "top": "141%",
                    "& when (@fullWidth)": {
                      "top": "123%"
                    }
                  }
                }
              }
            },
            "@media (max-width: 768px)": {
              ".icon-box": {
                "& when (@showArrows)": {
                  "&::before": {
                    "top": "114%"
                  }
                }
              }
            },
            ".mbr-text, .mbr-section-btn": {
              "text-align": "justify"
            },
            ".icon-text DIV": {
              "text-align": "justify"
            },
            ".icon-text": {
              "text-align": "justify"
            },
            ".card-title, .card-box": {
              "text-align": "justify"
            }
          },
          "_name": "features20",
          "_sourceTheme": "mobirise5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"features20\" group=\"Features\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{'mbr-parallax-background': bg.parallax}\" plugins=\"mobirise-icons2\">\n\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"9\" step=\"1\" value=\"3\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"9\" step=\"1\" value=\"3\">\n        <input type=\"range\" name=\"textWidth\" title=\"Width\" min=\"7\" max=\"12\" value=\"9\" step=\"1\">\n        <select title=\"Steps\" name=\"steps\">\n            <option value=\"1\">1</option>\n            <option value=\"2\">2</option>\n            <option value=\"3\" selected>3</option>\n            <option value=\"4\">4</option>\n            <option value=\"5\">5</option>\n            <option value=\"6\">6</option>\n            <option value=\"7\">7</option>\n            <option value=\"8\">8</option>\n            <option value=\"9\">9</option>\n            <option value=\"10\">10</option>\n        </select>\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <input type=\"checkbox\" title=\"Button\" name=\"showButton\">\n        <header>Step</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showCardTitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showCardText\" checked>\n        <input type=\"color\" name=\"iconColor\" title=\"Color\" value=\"#6592e6\">\n        <input type=\"checkbox\" title=\"Arrows\" name=\"showArrows\">\n        <input type=\"color\" name=\"iconColor\" title=\"Color\" value=\"#373365\">\n        <input type=\"range\" inline title=\"Arrows Size\" name=\"arrowsSize\" min=\"10\" max=\"100\" step=\"1\" value=\"32\" condition=\"showArrows\">\n            <input type=\"range\" inline title=\"Arrows Top\" name=\"arrowsTop\" min=\"0\" max=\"150\" step=\"1\" value=\"120\" condition=\"showArrows\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"../_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#ffffff\" selected>\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"../_images/background13.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n    </div>\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row justify-content-center\">\n            <div class=\"col-md-12 col-lg-{{textWidth}}\" mbr-if=\"showTitle || showText || showButton\">\n                <div class=\"card-wrapper pb-4\">\n                    <div class=\"card-box align-center\">\n                        <h4 class=\"card-title mbr-fonts-style mb-4\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\" data-app-selector=\".card-title, .card-box\"><b>Un ouvrage pour accompagner le dialogue et la formation: \"Dire sa foi\"</b></h4>\n                        <p class=\"mbr-text mbr-fonts-style mb-4\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .mbr-section-btn\">\n                            Quand des jeunes chrétiens rencontrent d'autres croyants. Un livre pour accompagner les jeunes chrétiens dans le dialogue avec leurs amis musulmans, répondre à leurs questions et approfondir leur propre foi dans un dialogue authentique.<br></p>\n                        <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" data-toolbar=\"-mbrBtnMove\" mbr-if=\"showButton\">\n                            <a class=\"btn btn-primary\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">Create\n                                your own site</a>\n                        </div>\n                    </div>\n                </div>\n            </div>\n            <div class=\"col-12 col-md-{{textWidth-1}}\">\n                <div class=\"item mbr-flex\" mbr-class=\"{'last': steps == 1}\">\n                    <div class=\"icon-box\">\n                        <span class=\"step-number mbr-fonts-style\" mbr-theme-style=\"display-5\">1</span>\n                    </div>\n                    <div class=\"text-box\" mbr-if=\"showCardTitle || showCardText\">\n                        <h4 class=\"icon-title card-title mbr-black mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".icon-title\" mbr-if=\"showCardTitle\"><b>Ne pas parler à la place de l'autre</b></h4>\n                        <h5 class=\"icon-text mbr-black mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".icon-text\" mbr-if=\"showCardText\"><div>Écoute sincère et attentive de l'interlocuteur, dans le respect de sa foi et de son identité.</div></h5>\n                    </div>\n                </div>\n                <div class=\"item mbr-flex\" mbr-if=\"steps > 1\" mbr-class=\"{'last': steps == 2}\">\n                    <div class=\"icon-box\">\n                        <span class=\"step-number mbr-fonts-style\" mbr-theme-style=\"display-5\">2</span>\n                    </div>\n                    <div class=\"text-box\" mbr-if=\"showCardTitle || showCardText\">\n                        <h4 class=\"icon-title card-title mbr-black mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".icon-title\" mbr-if=\"showCardTitle\"><b>Reconnaître notre humanité commune</b></h4>\n                        <h5 class=\"icon-text mbr-black mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".icon-text\" mbr-if=\"showCardText\"><div>Ce qui nous rapproche est plus grand que ce qui nous sépare : mêmes désirs, mêmes interrogations, même dignité.</div></h5>\n                    </div>\n                </div>\n                <div class=\"item mbr-flex\" mbr-if=\"steps > 2\" mbr-class=\"{'last': steps == 3}\">\n                    <div class=\"icon-box\">\n                        <span class=\"step-number mbr-fonts-style\" mbr-theme-style=\"display-5\">3</span>\n                    </div>\n                    <div class=\"text-box\" mbr-if=\"showCardTitle || showCardText\">\n                        <h4 class=\"icon-title card-title mbr-black mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".icon-title\" mbr-if=\"showCardTitle\"><b>Le dialogue comme charité</b></h4>\n                        <h5 class=\"icon-text mbr-black mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".icon-text\" mbr-if=\"showCardText\">Témoigner de sa foi sans chercher à convaincre, dans la gratuité et l'amitié authentique.</h5>\n                    </div>\n                </div>\n                <div class=\"item mbr-flex\" mbr-if=\"steps > 3\" mbr-class=\"{'last': steps == 4}\">\n                    <div class=\"icon-box\">\n                        <span class=\"step-number mbr-fonts-style\" mbr-theme-style=\"display-5\">4</span>\n                    </div>\n                    <div class=\"text-box\" mbr-if=\"showCardTitle || showCardText\">\n                        <h4 class=\"icon-title card-title mbr-black mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".icon-title\" mbr-if=\"showCardTitle\">\n                            <b>Specification</b>\n                        </h4>\n                        <h5 class=\"icon-text mbr-black mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".icon-text\" mbr-if=\"showCardText\">Mobirise is perfect for non-techies who\n                            are not familiar with\n                            the intricacies of web development.</h5>\n                    </div>\n                </div>\n                <div class=\"item mbr-flex\" mbr-if=\"steps > 4\" mbr-class=\"{'last': steps == 5}\">\n                    <div class=\"icon-box\">\n                        <span class=\"step-number mbr-fonts-style\" mbr-theme-style=\"display-5\">5</span>\n                    </div>\n                    <div class=\"text-box\" mbr-if=\"showCardTitle || showCardText\">\n                        <h4 class=\"icon-title card-title mbr-black mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".icon-title\" mbr-if=\"showCardTitle\">\n                            <b>Project Planning</b>\n                        </h4>\n                        <h5 class=\"icon-text mbr-black mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".icon-text\" mbr-if=\"showCardText\">Mobirise is perfect for non-techies who\n                            are not familiar with\n                            the intricacies of web development.</h5>\n                    </div>\n                </div>\n                <div class=\"item mbr-flex\" mbr-if=\"steps > 5\" mbr-class=\"{'last': steps == 6}\">\n                    <div class=\"icon-box\">\n                        <span class=\"step-number mbr-fonts-style\" mbr-theme-style=\"display-5\">6</span>\n                    </div>\n                    <div class=\"text-box\" mbr-if=\"showCardTitle || showCardText\">\n                        <h4 class=\"icon-title card-title mbr-black mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".icon-title\" mbr-if=\"showCardTitle\">\n                            <b>Deployment</b>\n                        </h4>\n                        <h5 class=\"icon-text mbr-black mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".icon-text\" mbr-if=\"showCardText\">Mobirise is perfect for non-techies who\n                            are not familiar with\n                            the intricacies of web development.</h5>\n                    </div>\n                </div>\n                <div class=\"item mbr-flex\" mbr-if=\"steps > 6\" mbr-class=\"{'last': steps == 7}\">\n                    <div class=\"icon-box\">\n                        <span class=\"step-number mbr-fonts-style\" mbr-theme-style=\"display-5\">7</span>\n                    </div>\n                    <div class=\"text-box\" mbr-if=\"showCardTitle || showCardText\">\n                        <h4 class=\"icon-title card-title mbr-black mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".icon-title\" mbr-if=\"showCardTitle\">\n                            <b>Specification</b>\n                        </h4>\n                        <h5 class=\"icon-text mbr-black mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".icon-text\" mbr-if=\"showCardText\">Mobirise is perfect for non-techies who\n                            are not familiar with\n                            the intricacies of web development.</h5>\n                    </div>\n                </div>\n                <div class=\"item mbr-flex\" mbr-if=\"steps > 7\" mbr-class=\"{'last': steps == 8}\">\n                    <div class=\"icon-box\">\n                        <span class=\"step-number mbr-fonts-style\" mbr-theme-style=\"display-5\">8</span>\n                    </div>\n                    <div class=\"text-box\" mbr-if=\"showCardTitle || showCardText\">\n                        <h4 class=\"icon-title card-title mbr-black mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".icon-title\" mbr-if=\"showCardTitle\">\n                            <b>Project Planning</b>\n                        </h4>\n                        <h5 class=\"icon-text mbr-black mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".icon-text\" mbr-if=\"showCardText\">Mobirise is perfect for non-techies who\n                            are not familiar with\n                            the intricacies of web development.</h5>\n                    </div>\n                </div>\n                <div class=\"item mbr-flex\" mbr-if=\"steps > 8\" mbr-class=\"{'last': steps == 9}\">\n                    <div class=\"icon-box\">\n                        <span class=\"step-number mbr-fonts-style\" mbr-theme-style=\"display-5\">9</span>\n                    </div>\n                    <div class=\"text-box\" mbr-if=\"showCardTitle || showCardText\">\n                        <h4 class=\"icon-title card-title mbr-black mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".icon-title\" mbr-if=\"showCardTitle\">\n                            <b>Deployment</b>\n                        </h4>\n                        <h5 class=\"icon-text mbr-black mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".icon-text\" mbr-if=\"showCardText\">Mobirise is perfect for non-techies who\n                            are not familiar with\n                            the intricacies of web development.</h5>\n                    </div>\n                </div>\n                <div class=\"item mbr-flex\" mbr-if=\"steps > 9\" mbr-class=\"{'last': steps == 10}\">\n                    <div class=\"icon-box\">\n                        <span class=\"step-number mbr-fonts-style\" mbr-theme-style=\"display-5\">10</span>\n                    </div>\n                    <div class=\"text-box\" mbr-if=\"showCardTitle || showCardText\">\n                        <h4 class=\"icon-title card-title mbr-black mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".icon-title\" mbr-if=\"showCardTitle\">\n                            <b>Deployment</b>\n                        </h4>\n                        <h5 class=\"icon-text mbr-black mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".icon-text\" mbr-if=\"showCardText\">Mobirise is perfect for non-techies who\n                            are not familiar with\n                            the intricacies of web development.</h5>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "vcTcMpOHVk",
          "_anchor": "features20-4y",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "background-color": "@bgColor",
            "& when (@reverseContent)": {
              ".row": {
                "flex-direction": "row-reverse"
              }
            },
            ".mbr-text": {
