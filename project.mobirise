              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "& when (@bg-type = \"color\")": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = \"image\")": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".card-wrapper": {
              "background": "@wrapBgColor",
              "@media (max-width: 767px)": {
                "padding": "2rem 1.5rem"
              },
              "@media (min-width: 768px) and (max-width: 991px)": {
                "padding": "2.25rem"
              },
              "@media (min-width: 992px)": {
                "padding": "4rem"
              }
            },
            ".mbr-text, .mbr-section-btn": {
              "color": "#000000",
              "text-align": "left"
            },
            ".card-title, .card-box": {
              "text-align": "left",
              "color": "#000000"
            },
            ".card-title": {
              "color": "#373365"
            }
          },
          "_name": "article07",
          "_sourceTheme": "startm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"article07 cid-vd0iIrFPdY\" id=\"article07-5v\" group=\"Article\" mbr-class=\"{'mbr-fullscreen': fullScreen, 'mbr-parallax-background': bg.parallax}\">\n  <mbr-parameters>\n    <header>Size</header>\n    <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n    <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n    <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"8\">\n    <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"2\">\n    <input type=\"range\" inline title=\"Content Width\" name=\"contentWidth\" min=\"8\" max=\"12\" step=\"1\" value=\"10\">\n    \n    <header>Show/Hide</header>\n    <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n    <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\">\n    <input type=\"color\" title=\"Wrap Bg\" name=\"wrapBgColor\" value=\"#ffffff\">\n    \n    <header>Background</header>\n    <fieldset type=\"background\" name=\"bg\" parallax>\n      <input type=\"image\" title=\"Image\" value=\"https://images.unsplash.com/photo-1507692049790-de58290a4334?w=1920\" parallax>\n      <input type=\"color\" title=\"Color\" value=\"#ffffff\" selected>\n      <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n    </fieldset>\n    \n    <header condition=\"bg.type === 'video'\">Fallback Image</header>\n    <input type=\"image\" title=\"Fallback Image\" value=\"https://images.unsplash.com/photo-1507692049790-de58290a4334?w=1920\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n    <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n    <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n    <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.3\" condition=\"overlay && bg.type !== 'color'\">\n  </mbr-parameters>\n\n  <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n  <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\"></div>\n  \n  <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n    <div class=\"row justify-content-center\">\n      <div class=\"card col-md-12 col-lg-{{contentWidth}} shadow rounded bg-white\" mbr-style=\"{'background-color': wrapBgColor}\">\n        <div class=\"card-wrapper\">\n          <h3 class=\"card-title mbr-fonts-style mt-3 mb-4\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\" data-app-selector=\".card-title\">\n            <b id=\"titleIcons\"></b> Calendrier du dialogue\n          </h3>\n          \n          <div class=\"year-selector\" id=\"buttons\" style=\"text-align: center; margin: 20px 0; display: flex; flex-wrap: wrap; justify-content: center; gap: 10px;\"></div>\n          \n          <div id=\"content\" style=\"margin-top: 20px;\"></div>\n          \n          <div mbr-buttons mbr-theme-style=\"display-7\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\" style=\"margin-top: 20px;\">\n            <a class=\"btn btn-primary\" href=\"#\" data-app-placeholder=\"Type Text\">En savoir plus</a>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <style>\n    @import url('https://fonts.googleapis.com/css2?family=Mulish:wght@400;600;700&display=swap');\n\n    .article07 {\n      background-color: #ffffff;\n      color: #232323;\n      font-family: 'Mulish', sans-serif;\n      font-weight: 400;\n      line-height: 1.5;\n    }\n\n    .article07 .icon-svg {\n      display: inline-block;\n      width: 24px;\n      height: 24px;\n      margin-right: 6px;\n      vertical-align: middle;\n    }\n\n    .article07 .year-selector button {\n      padding: 10px 15px;\n      border: 1px solid #373365;\n      border-radius: 4px;\n      cursor: pointer;\n      background: #ffffff;\n      color: #373365;\n      font-size: 14px;\n      font-weight: 600;\n      font-family: 'Mulish', sans-serif;\n      transition: all 0.2s ease-in-out;\n      display: inline-flex;\n      align-items: center;\n      justify-content: center;\n      word-break: break-word;\n    }\n    \n    .article07 .year-selector button:hover {\n      background: #373365;\n      color: #ffffff;\n      box-shadow: rgba(0, 0, 0, 0.07) 0px 1px 1px 0px, rgba(0, 0, 0, 0.07) 0px 1px 3px 0px, rgba(0, 0, 0, 0.03) 0px 0px 0px 1px;\n    }\n    \n    .article07 .year-selector button.active {\n      background: #373365;\n      color: #ffffff;\n      box-shadow: rgba(0, 0, 0, 0.07) 0px 1px 1px 0px, rgba(0, 0, 0, 0.07) 0px 1px 3px 0px, rgba(0, 0, 0, 0.03) 0px 0px 0px 1px;\n    }\n    \n    .article07 .calendar-grid {\n      display: grid;\n      grid-template-columns: 1fr 1fr;\n      gap: 20px;\n      margin-top: 20px;\n    }\n    \n    @media (max-width: 700px) {\n      .article07 .calendar-grid {\n        grid-template-columns: 1fr;\n      }\n    }\n    \n    .article07 .calendar-card {\n      background: #f5f5f5;\n      padding: 20px;\n      border-radius: 4px;\n      border: 1px solid #edefea;\n    }\n    \n    .article07 .calendar-card h2 {\n      margin-bottom: 15px;\n      font-size: 18px;\n      margin-top: 0;\n      font-weight: 600;\n      color: #373365;\n      font-family: 'Mulish', sans-serif;\n      display: flex;\n      align-items: center;\n    }\n    \n    .article07 .calendar-item {\n      display: flex;\n      justify-content: space-between;\n      align-items: center;\n      padding: 10px 0;\n      border-bottom: 1px solid #edefea;\n      font-size: 14px;\n      gap: 10px;\n      color: #232323;\n      font-weight: 400;\n      font-family: 'Mulish', sans-serif;\n    }\n    \n    .article07 .calendar-item:last-child {\n      border-bottom: none;\n    }\n    \n    .article07 .calendar-date {\n      background: #f0eef8;\n      padding: 4px 10px;\n      border-radius: 4px;\n      font-size: 0.85em;\n      white-space: nowrap;\n      flex-shrink: 0;\n      color: #373365;\n      font-weight: 600;\n      font-family: 'Mulish', sans-serif;\n    }\n  </style>\n\n  <script>\n    // Fonction pour créer une icône SVG croix droite\n    function getCrossIcon() {\n      return '<svg class=\"icon-svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#373365\" stroke-width=\"2\"><line x1=\"12\" y1=\"2\" x2=\"12\" y2=\"22\"></line><line x1=\"2\" y1=\"12\" x2=\"22\" y2=\"12\"></line></svg>';\n    }\n\n    // Fonction pour créer une icône SVG lune/croissant\n    function getCrescentIcon() {\n      return '<svg class=\"icon-svg\" viewBox=\"0 0 24 24\" fill=\"#373365\"><path d=\"M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z\"></path></svg>';\n    }\n\n    const cal = {\n      2026:{c:[[\"1er janvier\",\"Solennité Marie Mère de Dieu\"],[\"6 janvier\",\"Épiphanie\"],[\"18 fév\",\"Mercredi des Cendres\"],[\"25 mars\",\"Annonciation\"],[\"29 mars\",\"Rameaux\"],[\"2 avril\",\"Jeudi Saint\"],[\"3 avril\",\"Vendredi Saint\"],[\"5 avril\",\"Pâques\"],[\"14 mai\",\"Ascension\"],[\"24 mai\",\"Pentecôte\"],[\"4 juin\",\"Fête-Dieu\"],[\"15 août\",\"Assomption\"],[\"1er nov\",\"Toussaint\"],[\"8 déc\",\"Immaculée Conception\"],[\"25 déc\",\"Noël\"]],i:[[\"18 fév\",\"Début Ramadan\"],[\"15 mars\",\"Laylat al-Qadr\"],[\"20 mars\",\"Aïd al-Fitr\"],[\"27 mai\",\"Aïd al-Adha\"],[\"16 juil\",\"Nouvel An Hijri\"],[\"25 août\",\"Mawlid\"]]},\n      2027:{c:[[\"1er janvier\",\"Solennité Marie Mère de Dieu\"],[\"6 janvier\",\"Épiphanie\"],[\"10 fév\",\"Mercredi des Cendres\"],[\"25 mars\",\"Annonciation\"],[\"21 mars\",\"Rameaux\"],[\"25 mars\",\"Jeudi Saint\"],[\"26 mars\",\"Vendredi Saint\"],[\"28 mars\",\"Pâques\"],[\"6 mai\",\"Ascension\"],[\"16 mai\",\"Pentecôte\"],[\"27 mai\",\"Fête-Dieu\"],[\"15 août\",\"Assomption\"],[\"1er nov\",\"Toussaint\"],[\"8 déc\",\"Immaculée Conception\"],[\"25 déc\",\"Noël\"]],i:[[\"8 fév\",\"Début Ramadan\"],[\"5 mars\",\"Laylat al-Qadr\"],[\"10 mars\",\"Aïd al-Fitr\"],[\"17 mai\",\"Aïd al-Adha\"],[\"6 juil\",\"Nouvel An Hijri\"],[\"15 août\",\"Mawlid\"]]},\n      2028:{c:[[\"1er janvier\",\"Solennité Marie Mère de Dieu\"],[\"6 janvier\",\"Épiphanie\"],[\"1er mars\",\"Mercredi des Cendres\"],[\"25 mars\",\"Annonciation\"],[\"9 avril\",\"Rameaux\"],[\"13 avril\",\"Jeudi Saint\"],[\"14 avril\",\"Vendredi Saint\"],[\"16 avril\",\"Pâques\"],[\"25 mai\",\"Ascension\"],[\"4 juin\",\"Pentecôte\"],[\"15 juin\",\"Fête-Dieu\"],[\"15 août\",\"Assomption\"],[\"1er nov\",\"Toussaint\"],[\"8 déc\",\"Immaculée Conception\"],[\"25 déc\",\"Noël\"]],i:[[\"28 janv\",\"Début Ramadan\"],[\"23 fév\",\"Laylat al-Qadr\"],[\"27 fév\",\"Aïd al-Fitr\"],[\"5 mai\",\"Aïd al-Adha\"],[\"24 juin\",\"Nouvel An Hijri\"],[\"3 août\",\"Mawlid\"]]},\n      2029:{c:[[\"1er janvier\",\"Solennité Marie Mère de Dieu\"],[\"6 janvier\",\"Épiphanie\"],[\"14 fév\",\"Mercredi des Cendres\"],[\"25 mars\",\"Annonciation\"],[\"25 mars\",\"Rameaux\"],[\"29 mars\",\"Jeudi Saint\"],[\"30 mars\",\"Vendredi Saint\"],[\"1er avril\",\"Pâques\"],[\"10 mai\",\"Ascension\"],[\"20 mai\",\"Pentecôte\"],[\"31 mai\",\"Fête-Dieu\"],[\"15 août\",\"Assomption\"],[\"1er nov\",\"Toussaint\"],[\"8 déc\",\"Immaculée Conception\"],[\"25 déc\",\"Noël\"]],i:[[\"16 janv\",\"Début Ramadan\"],[\"11 fév\",\"Laylat al-Qadr\"],[\"15 fév\",\"Aïd al-Fitr\"],[\"24 avril\",\"Aïd al-Adha\"],[\"13 juin\",\"Nouvel An Hijri\"],[\"23 juil\",\"Mawlid\"]]},\n      2030:{c:[[\"1er janvier\",\"Solennité Marie Mère de Dieu\"],[\"6 janvier\",\"Épiphanie\"],[\"6 mars\",\"Mercredi des Cendres\"],[\"25 mars\",\"Annonciation\"],[\"14 avril\",\"Rameaux\"],[\"18 avril\",\"Jeudi Saint\"],[\"19 avril\",\"Vendredi Saint\"],[\"21 avril\",\"Pâques\"],[\"30 mai\",\"Ascension\"],[\"9 juin\",\"Pentecôte\"],[\"20 juin\",\"Fête-Dieu\"],[\"15 août\",\"Assomption\"],[\"1er nov\",\"Toussaint\"],[\"8 déc\",\"Immaculée Conception\"],[\"25 déc\",\"Noël\"]],i:[[\"5 janv\",\"Début Ramadan\"],[\"1er fév\",\"Laylat al-Qadr\"],[\"4 fév\",\"Aïd al-Fitr\"],[\"14 avril\",\"Aïd al-Adha\"],[\"3 juin\",\"Nouvel An Hijri\"],[\"12 juil\",\"Mawlid\"]]},\n      2031:{c:[[\"1er janvier\",\"Solennité Marie Mère de Dieu\"],[\"6 janvier\",\"Épiphanie\"],[\"26 fév\",\"Mercredi des Cendres\"],[\"25 mars\",\"Annonciation\"],[\"6 avril\",\"Rameaux\"],[\"10 avril\",\"Jeudi Saint\"],[\"11 avril\",\"Vendredi Saint\"],[\"13 avril\",\"Pâques\"],[\"22 mai\",\"Ascension\"],[\"1er juin\",\"Pentecôte\"],[\"12 juin\",\"Fête-Dieu\"],[\"15 août\",\"Assomption\"],[\"1er nov\",\"Toussaint\"],[\"8 déc\",\"Immaculée Conception\"],[\"25 déc\",\"Noël\"]],i:[[\"26 déc 2030\",\"Début Ramadan\"],[\"19 janv\",\"Laylat al-Qadr\"],[\"24 janv\",\"Aïd al-Fitr\"],[\"3 avril\",\"Aïd al-Adha\"],[\"23 mai\",\"Nouvel An Hijri\"],[\"1er juil\",\"Mawlid\"]]},\n      2032:{c:[[\"1er janvier\",\"Solennité Marie Mère de Dieu\"],[\"6 janvier\",\"Épiphanie\"],[\"11 fév\",\"Mercredi des Cendres\"],[\"25 mars\",\"Annonciation\"],[\"28 mars\",\"Rameaux\"],[\"1er avril\",\"Jeudi Saint\"],[\"2 avril\",\"Vendredi Saint\"],[\"4 avril\",\"Pâques\"],[\"13 mai\",\"Ascension\"],[\"23 mai\",\"Pentecôte\"],[\"3 juin\",\"Fête-Dieu\"],[\"15 août\",\"Assomption\"],[\"1er nov\",\"Toussaint\"],[\"8 déc\",\"Immaculée Conception\"],[\"25 déc\",\"Noël\"]],i:[[\"14 déc 2031\",\"Début Ramadan\"],[\"8 janv\",\"Laylat al-Qadr\"],[\"13 janv\",\"Aïd al-Fitr\"],[\"22 mars\",\"Aïd al-Adha\"],[\"12 mai\",\"Nouvel An Hijri\"],[\"20 juin\",\"Mawlid\"]]},\n      2033:{c:[[\"1er janvier\",\"Solennité Marie Mère de Dieu\"],[\"6 janvier\",\"Épiphanie\"],[\"2 mars\",\"Mercredi des Cendres\"],[\"25 mars\",\"Annonciation\"],[\"10 avril\",\"Rameaux\"],[\"14 avril\",\"Jeudi Saint\"],[\"15 avril\",\"Vendredi Saint\"],[\"17 avril\",\"Pâques\"],[\"26 mai\",\"Ascension\"],[\"5 juin\",\"Pentecôte\"],[\"16 juin\",\"Fête-Dieu\"],[\"15 août\",\"Assomption\"],[\"1er nov\",\"Toussaint\"],[\"8 déc\",\"Immaculée Conception\"],[\"25 déc\",\"Noël\"]],i:[[\"3 déc 2032\",\"Début Ramadan\"],[\"28 déc 2032\",\"Laylat al-Qadr\"],[\"2 janv\",\"Aïd al-Fitr\"],[\"11 mars\",\"Aïd al-Adha\"],[\"1er mai\",\"Nouvel An Hijri\"],[\"9 juin\",\"Mawlid\"]]},\n      2034:{c:[[\"1er janvier\",\"Solennité Marie Mère de Dieu\"],[\"6 janvier\",\"Épiphanie\"],[\"22 fév\",\"Mercredi des Cendres\"],[\"25 mars\",\"Annonciation\"],[\"2 avril\",\"Rameaux\"],[\"6 avril\",\"Jeudi Saint\"],[\"7 avril\",\"Vendredi Saint\"],[\"9 avril\",\"Pâques\"],[\"18 mai\",\"Ascension\"],[\"28 mai\",\"Pentecôte\"],[\"8 juin\",\"Fête-Dieu\"],[\"15 août\",\"Assomption\"],[\"1er nov\",\"Toussaint\"],[\"8 déc\",\"Immaculée Conception\"],[\"25 déc\",\"Noël\"]],i:[[\"22 nov 2033\",\"Début Ramadan\"],[\"17 déc 2033\",\"Laylat al-Qadr\"],[\"21 déc 2033\",\"Aïd al-Fitr\"],[\"28 fév\",\"Aïd al-Adha\"],[\"20 avril\",\"Nouvel An Hijri\"],[\"29 mai\",\"Mawlid\"]]},\n      2035:{c:[[\"1er janvier\",\"Solennité Marie Mère de Dieu\"],[\"6 janvier\",\"Épiphanie\"],[\"7 fév\",\"Mercredi des Cendres\"],[\"25 mars\",\"Annonciation\"],[\"18 mars\",\"Rameaux\"],[\"22 mars\",\"Jeudi Saint\"],[\"23 mars\",\"Vendredi Saint\"],[\"25 mars\",\"Pâques\"],[\"3 mai\",\"Ascension\"],[\"13 mai\",\"Pentecôte\"],[\"24 mai\",\"Fête-Dieu\"],[\"15 août\",\"Assomption\"],[\"1er nov\",\"Toussaint\"],[\"8 déc\",\"Immaculée Conception\"],[\"25 déc\",\"Noël\"]],i:[[\"11 nov 2034\",\"Début Ramadan\"],[\"6 déc 2034\",\"Laylat al-Qadr\"],[\"10 déc 2034\",\"Aïd al-Fitr\"],[\"17 fév\",\"Aïd al-Adha\"],[\"10 avril\",\"Nouvel An Hijri\"],[\"19 mai\",\"Mawlid\"]]},\n      2036:{c:[[\"1er janvier\",\"Solennité Marie Mère de Dieu\"],[\"6 janvier\",\"Épiphanie\"],[\"27 fév\",\"Mercredi des Cendres\"],[\"25 mars\",\"Annonciation\"],[\"6 avril\",\"Rameaux\"],[\"10 avril\",\"Jeudi Saint\"],[\"11 avril\",\"Vendredi Saint\"],[\"13 avril\",\"Pâques\"],[\"22 mai\",\"Ascension\"],[\"1er juin\",\"Pentecôte\"],[\"12 juin\",\"Fête-Dieu\"],[\"15 août\",\"Assomption\"],[\"1er nov\",\"Toussaint\"],[\"8 déc\",\"Immaculée Conception\"],[\"25 déc\",\"Noël\"]],i:[[\"31 oct 2035\",\"Début Ramadan\"],[\"25 nov 2035\",\"Laylat al-Qadr\"],[\"29 nov 2035\",\"Aïd al-Fitr\"],[\"7 fév\",\"Aïd al-Adha\"],[\"29 mars\",\"Nouvel An Hijri\"],[\"7 mai\",\"Mawlid\"]]},\n      2037:{c:[[\"1er janvier\",\"Solennité Marie Mère de Dieu\"],[\"6 janvier\",\"Épiphanie\"],[\"18 fév\",\"Mercredi des Cendres\"],[\"25 mars\",\"Annonciation\"],[\"29 mars\",\"Rameaux\"],[\"2 avril\",\"Jeudi Saint\"],[\"3 avril\",\"Vendredi Saint\"],[\"5 avril\",\"Pâques\"],[\"14 mai\",\"Ascension\"],[\"24 mai\",\"Pentecôte\"],[\"4 juin\",\"Fête-Dieu\"],[\"15 août\",\"Assomption\"],[\"1er nov\",\"Toussaint\"],[\"8 déc\",\"Immaculée Conception\"],[\"25 déc\",\"Noël\"]],i:[[\"20 oct 2036\",\"Début Ramadan\"],[\"14 nov 2036\",\"Laylat al-Qadr\"],[\"18 nov 2036\",\"Aïd al-Fitr\"],[\"27 janv\",\"Aïd al-Adha\"],[\"19 mars\",\"Nouvel An Hijri\"],[\"27 avril\",\"Mawlid\"]]}\n    };\n\n    function show(y) {\n      document.querySelectorAll('.year-selector button').forEach(b => b.classList.remove('active'));\n      const clickedBtn = document.querySelector(`.year-selector button[data-year=\"${y}\"]`);\n      if (clickedBtn) clickedBtn.classList.add('active');\n      const d = cal[y];\n      document.getElementById('content').innerHTML = '<div class=\"calendar-grid\"><div class=\"calendar-card catholic\"><h2>' + getCrossIcon() + 'Catholicisme</h2>' + d.c.map(x => '<div class=\"calendar-item\"><span>' + x[1] + '</span><span class=\"calendar-date\">' + x[0] + '</span></div>').join('') + '</div><div class=\"calendar-card islam\"><h2>' + getCrescentIcon() + 'Islam</h2>' + d.i.map(x => '<div class=\"calendar-item\"><span>' + x[1] + '</span><span class=\"calendar-date\">' + x[0] + '</span></div>').join('') + '</div></div>';\n    }\n\n    // Initialiser le titre avec les icônes SVG\n    document.getElementById('titleIcons').innerHTML = getCrossIcon() + getCrescentIcon();\n\n    const currentYear = new Date().getFullYear();\n    const startYear = 2026;\n    const endYear = 2037;\n    \n    let defaultYear = currentYear;\n    if (currentYear < startYear) {\n      defaultYear = startYear;\n    } else if (currentYear > endYear) {\n      defaultYear = endYear;\n    }\n\n    let btns = '';\n    for(let y = startYear; y <= endYear; y++) {\n      btns += '<button data-year=\"' + y + '\" ' + (y === defaultYear ? 'class=\"active\" ' : '') + 'onclick=\"show(' + y + ')\">' + y + '</button>';\n    }\n    document.getElementById('buttons').innerHTML = btns;\n    show(defaultYear);\n  </script>\n</section>",
          "_anchor": "article07-bh",
          "_isUserblock": true,
          "_cid": "vf59h4Cjik",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "_name": "footer1",
          "_sourceTheme": "mobirise5",
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".social-row": {
              "display": "flex",
              "flex-wrap": "wrap"
            },
            ".soc-item": {
              "display": "flex",
              "align-items": "center",
              "justify-content": "center",
              "border-radius": "50%",
              "background-color": "white",
              "margin-right": "0.5rem",
              "margin-bottom": "1rem",
              "padding": "0.5rem",
              "height": "2.5rem",
              "width": "2.5rem"
            },
            "@media (max-width: 767px)": {
              ".row": {
                "text-align": "center"
              },
              ".social-row": {
                "justify-content": "center"
              }
            },
            ".list": {
              "list-style": "none",
              "padding-left": "0",
              "@media (max-width: 991px)": {
                "margin-bottom": "2rem"
              },
              "@media (min-width: 992px)": {
                "margin-bottom": "0rem"
              },
              "color": "#ffffff",
              "text-align": "justify"
            },
            ".mbr-text": {
              "color": "#ffffff"
            },
            ".mbr-iconfont": {
              "color": "black"
            },
            ".list DIV": {
              "text-align": "justify"
            }
          },
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"footer1\" group=\"Footers\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" global once=\"footers\" mbr-class=\"{'mbr-parallax-background': bg.parallax}\">\n\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"3\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Social\" name=\"showSocial\" checked>\n        <input type=\"range\" name=\"socialCount\" title=\"Social Count\" min=\"1\" max=\"4\" step=\"1\" value=\"4\" condition=\"showSocial\">\n        <input type=\"checkbox\" title=\"Copyright\" name=\"showCopyright\" checked>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value>\n            <input type=\"color\" title=\"Color\" value=\"#373365\" selected>\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#373365\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n    \n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row mbr-white\">\n            <div class=\"col-12 col-md-6 col-lg-3\">\n                <h5 mbr-text class=\"mbr-section-subtitle mbr-fonts-style mb-2\" data-app-selector=\".mbr-section-subtitle\" mbr-theme-style=\"display-7\" mbr-if=\"showTitle\"><b>Citation biblique</b></h5>\n                <ul class=\"list mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".list\" data-multiline mbr-article>\n                    <div>« Si quelqu'un dit : \"J'aime Dieu\", alors qu'il a de la haine contre son frère, c'est un menteur. En effet, celui qui n'aime pas son frère, qu'il voit, est incapable d'aimer Dieu, qu'il ne voit pas. </div><div>Et voici le commandement que nous tenons de lui : celui qui aime Dieu, qu'il aime aussi son frère. » <span style=\"font-size: 1rem;\">— <b>Première lettre de Jean 4, 20-21</b></span></div>\n                </ul>\n            </div>\n\n            <div class=\"col-12 col-md-6 col-lg-3\">\n                <h5 mbr-text class=\"mbr-section-subtitle mbr-fonts-style mb-2\" data-app-selector=\".mbr-section-subtitle\" mbr-theme-style=\"display-7\" mbr-if=\"showTitle\"><b>Partenaires</b></h5>\n                <ul class=\"list mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".list\" data-multiline mbr-article>\n                    <div><a href=\"https://www.vatican.va/content/romancuria/fr/dicasteri/dicastero-dialogo-interreligioso.index.html\" class=\"text-success text-primary\" target=\"_blank\">Vatican Dicastère</a></div><div><a href=\"https://relations-catholiques-musulmans.cef.fr/\" class=\"text-success\" target=\"_blank\">Conf. des évêques de France</a></div><div><a href=\"https://lille.catholique.fr/famille-societe/dialogue/dialogue-interreligieux-2/\" class=\"text-success\" target=\"_blank\">Diocèse de Lille</a></div>\n                </ul>\n            </div>\n\n            <div class=\"col-12 col-md-6 col-lg-3 text-center\">\n                <style>\n                    .map-wrapper {\n                        filter: grayscale(100%);\n                        border-radius: 8px;\n                        overflow: hidden;\n                        display: inline-block;\n                    }\n                </style>\n                <div class=\"map-wrapper\">\n                    <iframe src=\"https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2530.021627962608!2d3.0880876763192586!3d50.64528947162996!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47c32a04413994e3%3A0x99509bf2778763a5!2s74%20Rue%20Hippolyte%20Lefebvre%2C%2059800%20Lille!5e0!3m2!1sfr!2sfr!4v1773909007679!5m2!1sfr!2sfr\" width=\"250\" height=\"250\" style=\"border:0;\" allowfullscreen loading=\"lazy\" referrerpolicy=\"no-referrer-when-downgrade\"></iframe>\n                </div>\n            </div>\n\n            <div class=\"col-12 col-md-6 col-lg-3\">\n                <h5 class=\"mbr-section-subtitle mbr-fonts-style mb-2\" mbr-theme-style=\"display-7\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-subtitle\"><br><b>Maison Paul VI</b></h5>\n                <p class=\"mbr-text mbr-fonts-style mb-4\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-text\">\n                    Dialogue interreligieux<br><br>\n                    74 Rue Hippolyte Lefebvre<br>\n                    59800 Lille<br>\n                    03 20 06 43 02<br></p>\n                <h5 class=\"mbr-section-subtitle mbr-fonts-style mb-3\" mbr-theme-style=\"display-7\" mbr-if=\"showTitle && showSocial\" data-app-selector=\".mbr-section-subtitle\"><b>Social</b></h5>\n                <div class=\"social-row display-7\" mbr-if=\"showSocial\">\n                    <div class=\"soc-item\">\n                        <a href=\"https://www.facebook.com/interreligieuxlille\" target=\"_blank\">\n                            <span mbr-icon class=\"mbr-iconfont socicon-facebook socicon\" style=\"color: rgb(55, 51, 101); fill: rgb(55, 51, 101);\"></span>\n                        </a>\n                    </div>\n                    <div class=\"soc-item\" mbr-if=\"socialCount>1\">\n                        <a href=\"https://x.com/InterLille\" target=\"_blank\">\n                            <span mbr-icon class=\"mbr-iconfont socicon-twitter socicon\" style=\"color: rgb(55, 51, 101); fill: rgb(55, 51, 101);\"></span>\n                        </a>\n                    </div>\n                    <div class=\"soc-item\" mbr-if=\"socialCount>2\">\n                        <a href=\"https://www.instagram.com/sdrmlille/\" target=\"_blank\">\n                            <span mbr-icon class=\"mbr-iconfont socicon-instagram socicon\" style=\"color: rgb(55, 51, 101); fill: rgb(55, 51, 101);\"></span>\n                        </a>\n                    </div>\n                    <div class=\"soc-item\" mbr-if=\"socialCount>3\">\n                        <a href=\"https://www.tiktok.com/@sdrmlille\" target=\"_blank\">\n                            <span mbr-icon class=\"mbr-iconfont socicon-tiktok socicon\" style=\"color: rgb(55, 51, 101); fill: rgb(55, 51, 101);\"></span>\n                        </a>\n                    </div>\n                </div>\n            </div>\n\n            <div class=\"col-12 mt-4\" mbr-if=\"showCopyright\">\n                <p class=\"mbr-text mb-0 mbr-fonts-style copyright align-center\" mbr-theme-style=\"display-7\" data-app-selector=\".copyright\" data-app-placeholder=\"Type Text\">© 2026 Diocèse de Lille. Tous droits réservés.&nbsp;<a href=\"mentions.html\" class=\"text-success text-primary\">Mentions Légales</a></p>\n            </div>\n        </div>\n    </div>\n</section>",
          "_isUserblock": true,
          "_cid": "vf58WOFSsp",
