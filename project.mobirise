            ".collapsed": {
              "span": {
                "transform": "rotate(0deg)"
              }
            },
            ".panel-title": {
              "display": "flex",
              "align-items": "center",
              "justify-content": "space-between"
            },
            "p": {
              "margin-bottom": "0.3rem"
            },
            ".mbri-arrow-up": {
              "transform": "rotate(45deg)"
            },
            ".panel-title-edit": {
              "color": "#373365"
            },
            ".card .card-header": {
              "background-color": "transparent",
              "margin-bottom": "0",
              "border": "0",
              "border-radius": "10px"
            },
            ".card": {
              "background": "white",
              "padding": "0rem 1rem",
              "border-radius": "10px!important"
            },
            ".panel-title-edit, .mbr-iconfont": {
              "color": "#373365"
            },
            ".panel-text": {
              "color": "#373365"
            },
            "H4": {
              "color": "#373365"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".mbr-section-title": {
              "color": "#373365"
            }
          },
          "_name": "list03",
          "_sourceTheme": "softwarem4",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"list3\" group=\"List\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{'mbr-parallax-background':bg.parallax}\" plugins=\"mbr-switch-arrow, mobirise-icons2\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"4\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"4\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubtitle\" checked>\n        <select title=\"Amount\" name=\"cardAmount\">\n            <option value=\"1\">1</option>\n            <option value=\"2\">2</option>\n            <option value=\"3\">3</option>\n            <option value=\"4\">4</option>\n            <option value=\"5\">5</option>\n            <option value=\"6\">6</option>\n            <option value=\"7\">7</option>\n            <option value=\"8\">8</option>\n            <option value=\"9\">9</option>\n            <option value=\"10\">10</option>\n            <option value=\"11\">11</option>\n            <option value=\"12\">12</option>\n            <option value=\"13\">13</option>\n            <option value=\"14\">14</option>\n            <option value=\"15\" selected>15</option>\n        </select>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"https://images.unsplash.com/photo-1516450360452-9312f5e86fc7?w=1920\">\n            <input type=\"color\" title=\"Color\" value=\"#ffffff\" selected>\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"https://images.unsplash.com/photo-1516450360452-9312f5e86fc7?w=1920\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" checked condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.9\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\"></div>\n    <div class=\"container\">\n        <div class=\"row justify-content-center\">\n            <div class=\"col-12 col-md-12 col-lg-8 m-auto\">\n                <div class=\"content\">\n                    <div class=\"mbr-section-head align-center mb-5\" mbr-if=\"showTitle || showSubtitle\">\n                        <h4 class=\"mbr-section-subtitle mb-2 mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showSubtitle\" data-app-selector=\".mbr-section-subtitle\"><b>FAQ</b></h4>\n                        <h3 class=\"mbr-section-title mb-2 mbr-fonts-style\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title\"><b>Questions &amp; Réponses</b></h3>\n                    </div>\n                    <div id=\"bootstrap-accordion\" class=\"panel-group accordionStyles accordion\" role=\"tablist\" aria-multiselectable=\"true\">\n\n                        <div class=\"card mb-3\">\n                            <div class=\"card-header\" role=\"tab\" id=\"heading1\">\n                                <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse1\" aria-expanded=\"false\" aria-controls=\"collapse1\">\n                                    <h6 class=\"panel-title-edit mbr-semibold mbr-fonts-style mb-0\" mbr-theme-style=\"display-5\" data-app-selector=\".panel-title-edit\">Qu'est-ce que le dialogue interreligieux ? Pourquoi le favoriser ?</h6>\n                                    <span class=\"sign mbr-iconfont mobi-mbri-plus\"></span>\n                                </a>\n                            </div>\n                            <div id=\"collapse1\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"heading1\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                                <div class=\"panel-body\">\n                                    <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">C'est une rencontre authentique fondée sur le respect mutuel, sans syncrétisme ni prosélytisme. L'Église encourage ce dialogue depuis Vatican II car elle reconnaît en l'autre un frère créé par Dieu.</p>\n                                </div>\n                            </div>\n                        </div>\n\n                        <div class=\"card mb-3\" mbr-if=\"cardAmount > 1\">\n                            <div class=\"card-header\" role=\"tab\" id=\"heading2\">\n                                <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse2\" aria-expanded=\"false\" aria-controls=\"collapse2\">\n                                    <h6 class=\"panel-title-edit mbr-semibold mbr-fonts-style mb-0\" mbr-theme-style=\"display-5\" data-app-selector=\".panel-title-edit\">Le dialogue signifie-t-il renoncer à sa foi ? Peut-on prier ensemble ?</h6>\n                                    <span class=\"sign mbr-iconfont mobi-mbri-plus\"></span>\n                                </a>\n                            </div>\n                            <div id=\"collapse2\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"heading2\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                                <div class=\"panel-body\">\n                                    <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">Non, il exige au contraire d'être enraciné dans sa propre identité. Les chrétiens et musulmans ne prient pas ensemble au sens rituel, mais chacun peut prier selon sa foi dans le respect de l'autre.</p>\n                                </div>\n                            </div>\n                        </div>\n\n                        <div class=\"card mb-3\" mbr-if=\"cardAmount > 2\">\n                            <div class=\"card-header\" role=\"tab\" id=\"heading3\">\n                                <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse3\" aria-expanded=\"false\" aria-controls=\"collapse3\">\n                                    <h6 class=\"panel-title-edit mbr-semibold mbr-fonts-style mb-0\" mbr-theme-style=\"display-5\" data-app-selector=\".panel-title-edit\">Les chrétiens croient-ils en un seul Dieu ? Jésus, Fils de Dieu ?</h6>\n                                    <span class=\"sign mbr-iconfont mobi-mbri-plus\"></span>\n                                </a>\n                            </div>\n                            <div id=\"collapse3\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"heading3\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                                <div class=\"panel-body\">\n                                    <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">Oui, les chrétiens sont monothéistes : « Je crois en un seul Dieu ». La Trinité n'est pas trois dieux mais trois « personnes » en un seul Dieu. « Fils de Dieu » exprime une relation intime d'amour, non une génération physique. Jésus révèle Dieu comme Amour qui se donne jusqu'à la croix.</p>\n                                </div>\n                            </div>\n                        </div>\n\n                        <div class=\"card mb-3\" mbr-if=\"cardAmount > 3\">\n                            <div class=\"card-header\" role=\"tab\" id=\"heading4\">\n                                <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse4\" aria-expanded=\"false\" aria-controls=\"collapse4\">\n                                    <h6 class=\"panel-title-edit mbr-semibold mbr-fonts-style mb-0\" mbr-theme-style=\"display-5\" data-app-selector=\".panel-title-edit\">Pourquoi quatre Évangiles et non un seul livre révélé ?</h6>\n                                    <span class=\"sign mbr-iconfont mobi-mbri-plus\"></span>\n                                </a>\n                            </div>\n                            <div id=\"collapse4\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"heading4\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                                <div class=\"panel-body\">\n                                    <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">Pour les chrétiens, la Parole de Dieu est d'abord une Personne : Jésus-Christ. Les quatre Évangiles sont des témoignages inspirés de l'expérience des Apôtres. Cette diversité invite à méditer le mystère du Christ sous différents angles.</p>\n                                </div>\n                            </div>\n                        </div>\n\n                        <div class=\"card mb-3\" mbr-if=\"cardAmount > 4\">\n                            <div class=\"card-header\" role=\"tab\" id=\"heading5\">\n                                <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse5\" aria-expanded=\"false\" aria-controls=\"collapse5\">\n                                    <h6 class=\"panel-title-edit mbr-semibold mbr-fonts-style mb-0\" mbr-theme-style=\"display-5\" data-app-selector=\".panel-title-edit\">Comment répondre à mes amis musulmans ? Mon enfant a un ami musulman ?</h6>\n                                    <span class=\"sign mbr-iconfont mobi-mbri-plus\"></span>\n                                </a>\n                            </div>\n                            <div id=\"collapse5\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"heading5\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                                <div class=\"panel-body\">\n                                    <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">Accueillez les questions comme un cadeau : écoutez sincèrement sans chercher à convaincre, témoignez avec simplicité, reconnaissez humblement ce que vous ne savez pas. C'est aussi une belle opportunité d'éducation à la fraternité pour votre enfant. Encouragez-le à respecter son ami et à s'intéresser à sa foi en identifiant les différences et points communs.</p>\n                                </div>\n                            </div>\n                        </div>\n\n                        <div class=\"card mb-3\" mbr-if=\"cardAmount > 5\">\n                            <div class=\"card-header\" role=\"tab\" id=\"heading6\">\n                                <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse6\" aria-expanded=\"false\" aria-controls=\"collapse6\">\n                                    <h6 class=\"panel-title-edit mbr-semibold mbr-fonts-style mb-0\" mbr-theme-style=\"display-5\" data-app-selector=\".panel-title-edit\">Comment organiser un repas interreligieux ?</h6>\n                                    <span class=\"sign mbr-iconfont mobi-mbri-plus\"></span>\n                                </a>\n                            </div>\n                            <div id=\"collapse6\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"heading6\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                                <div class=\"panel-body\">\n                                    <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">Oui ! Un repas partagé est un geste de fraternité très fort. Prévoir un menu respectueux des prescriptions alimentaires (viande halal ou options végétariennes), éviter l'alcool si souhaité, prévoir un temps de parole où chacun peut partager. C'est l'occasion de célébrer ensemble et de renforcer les liens.</p>\n                                </div>\n                            </div>\n                        </div>\n\n                        <div class=\"card mb-3\" mbr-if=\"cardAmount > 6\">\n                            <div class=\"card-header\" role=\"tab\" id=\"heading7\">\n                                <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse7\" aria-expanded=\"false\" aria-controls=\"collapse7\">\n                                    <h6 class=\"panel-title-edit mbr-semibold mbr-fonts-style mb-0\" mbr-theme-style=\"display-5\" data-app-selector=\".panel-title-edit\">Comment réagir face aux préjugés et à l'islamophobie ?</h6>\n                                    <span class=\"sign mbr-iconfont mobi-mbri-plus\"></span>\n                                </a>\n                            </div>\n                            <div id=\"collapse7\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"heading7\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                                <div class=\"panel-body\">\n                                    <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">Le chrétien est appelé à être artisan de paix et à combattre toute forme de discrimination. Face aux préjugés : 1) Témoignez de votre expérience positive du dialogue. 2) Rappelez que l'islam ne peut être réduit aux actes de quelques-uns. 3) Dénoncez fermement les amalgames et les discours de haine. 4) Soutenez concrètement vos frères et sœurs musulmans victimes de discrimination.</p>\n                                </div>\n                            </div>\n                        </div>\n\n                        <div class=\"card mb-3\" mbr-if=\"cardAmount > 7\">\n                            <div class=\"card-header\" role=\"tab\" id=\"heading8\">\n                                <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse8\" aria-expanded=\"false\" aria-controls=\"collapse8\">\n                                    <h6 class=\"panel-title-edit mbr-semibold mbr-fonts-style mb-0\" mbr-theme-style=\"display-5\" data-app-selector=\".panel-title-edit\">Pourquoi créer un groupe ? Quels sont les principes de base ?</h6>\n                                    <span class=\"sign mbr-iconfont mobi-mbri-plus\"></span>\n                                </a>\n                            </div>\n                            <div id=\"collapse8\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"heading8\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                                <div class=\"panel-body\">\n                                    <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\">Favoriser le dialogue authentique, les liens d'amitié, les actions solidaires et témoigner de la charité mutuelle. <strong>Principes :</strong> respect mutuel des convictions, écoute bienveillante, équilibre entre les religions, confidentialité, absence de jugement et de prosélytisme.</p>\n                                </div>\n                            </div>\n                        </div>\n\n                        <div class=\"card mb-3\" mbr-if=\"cardAmount > 8\">\n                            <div class=\"card-header\" role=\"tab\" id=\"heading9\">\n                                <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse9\" aria-expanded=\"false\" aria-controls=\"collapse9\">\n                                    <h6 class=\"panel-title-edit mbr-semibold mbr-fonts-style mb-0\" mbr-theme-style=\"display-5\" data-app-selector=\".panel-title-edit\">Comment créer un groupe ? Étapes et organisation</h6>\n                                    <span class=\"sign mbr-iconfont mobi-mbri-plus\"></span>\n                                </a>\n                            </div>\n                            <div id=\"collapse9\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"heading9\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                                <div class=\"panel-body\">\n                                    <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\"><strong>Création :</strong> 1) Binôme animateur (1 musulman + 1 catholique). 2) Rassemblez 6-12 membres. 3) 1ère réunion pour fixer objectifs. 4) Rédigez ensemble une charte. <strong>Réunions (2h) :</strong> 15-20 min accueil • 45-60 min discussion • 15 min conclusion. Rythme : toutes les 2-4 semaines. Lieux : alternez salle paroissiale, musulmane, neutre.</p>\n                                </div>\n                            </div>\n                        </div>\n\n                        <div class=\"card mb-3\" mbr-if=\"cardAmount > 9\">\n                            <div class=\"card-header\" role=\"tab\" id=\"heading10\">\n                                <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse10\" aria-expanded=\"false\" aria-controls=\"collapse10\">\n                                    <h6 class=\"panel-title-edit mbr-semibold mbr-fonts-style mb-0\" mbr-theme-style=\"display-5\" data-app-selector=\".panel-title-edit\">Rôle des animateurs. Sujets et actions ?</h6>\n                                    <span class=\"sign mbr-iconfont mobi-mbri-plus\"></span>\n                                </a>\n                            </div>\n                            <div id=\"collapse10\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"heading10\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                                <div class=\"panel-body\">\n                                    <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\"><strong>Animateurs :</strong> préparent les réunions, veillent à l'équilibre, assurent l'écoute, gèrent les tensions. <strong>Sujets :</strong> figures spirituelles communes, prière, éducation des enfants, fêtes religieuses, engagement solidaire, famille et valeurs. <strong>Actions :</strong> visites de lieux de culte, repas partagés, projets solidaires, conférences, événements culturels.</p>\n                                </div>\n                            </div>\n                        </div>\n\n                        <div class=\"card mb-3\" mbr-if=\"cardAmount > 10\">\n                            <div class=\"card-header\" role=\"tab\" id=\"heading11\">\n                                <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse11\" aria-expanded=\"false\" aria-controls=\"collapse11\">\n                                    <h6 class=\"panel-title-edit mbr-semibold mbr-fonts-style mb-0\" mbr-theme-style=\"display-5\" data-app-selector=\".panel-title-edit\">Comment réussir ? Gérer les conflits et l'essoufflement ?</h6>\n                                    <span class=\"sign mbr-iconfont mobi-mbri-plus\"></span>\n                                </a>\n                            </div>\n                            <div id=\"collapse11\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"heading11\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                                <div class=\"panel-body\">\n                                    <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\"><strong>Réussite :</strong> écoutez sincèrement, préparez les réunions, témoignez avec humilité, diversifiez les activités, accueillez de nouveaux membres. <strong>Tensions :</strong> rappelez la charte, écoutez chacun, cherchez les points communs. <strong>Essoufflement :</strong> évaluez les sujets, diversifiez, prenez une pause si nécessaire. Contactez le Service diocésain si besoin.</p>\n                                </div>\n                            </div>\n                        </div>\n\n                        <div class=\"card mb-3\" mbr-if=\"cardAmount > 11\">\n                            <div class=\"card-header\" role=\"tab\" id=\"heading12\">\n                                <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse12\" aria-expanded=\"false\" aria-controls=\"collapse12\">\n                                    <h6 class=\"panel-title-edit mbr-semibold mbr-fonts-style mb-0\" mbr-theme-style=\"display-5\" data-app-selector=\".panel-title-edit\">Mariage à l'église avec un(e) musulman(e) ? Préparation ? Enfants ?</h6>\n                                    <span class=\"sign mbr-iconfont mobi-mbri-plus\"></span>\n                                </a>\n                            </div>\n                            <div id=\"collapse12\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"heading12\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                                <div class=\"panel-body\">\n                                    <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\"><strong>Mariage :</strong> Oui, sous <strong>dispense de l'évêque</strong> (« mariage avec disparité de culte »). Célébration à l'église <strong>sans messe eucharistique</strong>. <strong>Préparation :</strong> plusieurs mois obligatoires avec prêtre/diacre, sessions mixtes, dialogue sur la foi, l'éducation des enfants, les pratiques religieuses. <strong>Enfants :</strong> l'Église demande au catholique de « tout faire » pour les baptiser dans la foi catholique, mais chaque couple décide selon sa conscience. <strong>Essentiel : en parler avant le mariage.</strong></p>\n                                </div>\n                            </div>\n                        </div>\n\n                        <div class=\"card mb-3\" mbr-if=\"cardAmount > 12\">\n                            <div class=\"card-header\" role=\"tab\" id=\"heading13\">\n                                <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse13\" aria-expanded=\"false\" aria-controls=\"collapse13\">\n                                    <h6 class=\"panel-title-edit mbr-semibold mbr-fonts-style mb-0\" mbr-theme-style=\"display-5\" data-app-selector=\".panel-title-edit\">Témoins de mariage et parrains de baptême</h6>\n                                    <span class=\"sign mbr-iconfont mobi-mbri-plus\"></span>\n                                </a>\n                            </div>\n                            <div id=\"collapse13\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"heading13\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                                <div class=\"panel-body\">\n                                    <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\"><strong>Mariage :</strong> Aucune exigence religieuse pour les témoins. <strong>Baptême :</strong> Témoin doit être catholique (canon 874), sauf si baptisé non-catholique avec parrain catholique présent. <strong>Parrain :</strong> au moins 16 ans, catholique et confirmé, ayant reçu l'Eucharistie, menant une vie conforme à la foi, ne pas être parent du baptisé.</p>\n                                </div>\n                            </div>\n                        </div>\n\n                        <div class=\"card mb-3\" mbr-if=\"cardAmount > 13\">\n                            <div class=\"card-header\" role=\"tab\" id=\"heading14\">\n                                <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse14\" aria-expanded=\"false\" aria-controls=\"collapse14\">\n                                    <h6 class=\"panel-title-edit mbr-semibold mbr-fonts-style mb-0\" mbr-theme-style=\"display-5\" data-app-selector=\".panel-title-edit\">Témoin non-catholique pour un baptême : comment accompagner ?</h6>\n                                    <span class=\"sign mbr-iconfont mobi-mbri-plus\"></span>\n                                </a>\n                            </div>\n                            <div id=\"collapse14\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"heading14\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                                <div class=\"panel-body\">\n                                    <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\"><strong>1) Informer avec bienveillance :</strong> expliquez respectueusement les règles canoniques et leur sens pastoral. <strong>2) Proposer un dialogue :</strong> « Avez-vous un proche catholique qui pourrait être parrain ? » <strong>3) Vérifier les options :</strong> identifier un catholique ou envisager une autre participation (lecteur, porteur du cierge). <strong>4) Soutien pastoral :</strong> préparer la famille pour une cérémonie respectueuse et signifiante.</p>\n                                </div>\n                            </div>\n                        </div>\n\n                        <div class=\"card mb-3\" mbr-if=\"cardAmount > 14\">\n                            <div class=\"card-header\" role=\"tab\" id=\"heading15\">\n                                <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse15\" aria-expanded=\"false\" aria-controls=\"collapse15\">\n                                    <h6 class=\"panel-title-edit mbr-semibold mbr-fonts-style mb-0\" mbr-theme-style=\"display-5\" data-app-selector=\".panel-title-edit\">Formations, aide et ressources disponibles</h6>\n                                    <span class=\"sign mbr-iconfont mobi-mbri-plus\"></span>\n                                </a>\n                            </div>\n                            <div id=\"collapse15\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"heading15\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                                <div class=\"panel-body\">\n                                    <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\"><strong>Service diocésain pour le dialogue interreligieux du diocèse de Lille</strong><br>📞 <strong>07 56 94 24 84</strong><br>✉️ jerome.montois@lille.catholique.fr<br><br><strong>Propose :</strong> formations au dialogue interreligieux, accompagnement des groupes, mise en réseau avec d'autres initiatives, soutien en cas de tensions, conflits ou discrimination.<br><br><strong>P. Pascal DAME</strong> (Couples islamo-catholiques)<br>📞 <strong>06 70 05 56 40</strong></p>\n                                </div>\n                            </div>\n                        </div>\n\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_anchor": "list03-al",
          "_isUserblock": true,
          "_cid": "veSOc64QlM",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "_name": "footer1",
          "_sourceTheme": "mobirise5",
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".social-row": {
              "display": "flex",
              "flex-wrap": "wrap"
            },
            ".soc-item": {
              "display": "flex",
              "align-items": "center",
              "justify-content": "center",
              "border-radius": "50%",
              "background-color": "white",
              "margin-right": "0.5rem",
              "margin-bottom": "1rem",
              "padding": "0.5rem",
              "height": "2.5rem",
              "width": "2.5rem"
            },
            "@media (max-width: 767px)": {
              ".row": {
                "text-align": "center"
              },
              ".social-row": {
                "justify-content": "center"
              }
            },
            ".list": {
              "list-style": "none",
              "padding-left": "0",
              "@media (max-width: 991px)": {
                "margin-bottom": "2rem"
              },
              "@media (min-width: 992px)": {
                "margin-bottom": "0rem"
              },
              "color": "#ffffff",
              "text-align": "justify"
            },
            ".mbr-text": {
              "color": "#ffffff"
            },
            ".mbr-iconfont": {
              "color": "black"
            },
            ".list DIV": {
              "text-align": "justify"
            }
          },
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"footer1\" group=\"Footers\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" global once=\"footers\" mbr-class=\"{'mbr-parallax-background': bg.parallax}\">\n\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"3\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Social\" name=\"showSocial\" checked>\n        <input type=\"range\" name=\"socialCount\" title=\"Social Count\" min=\"1\" max=\"4\" step=\"1\" value=\"4\" condition=\"showSocial\">\n        <input type=\"checkbox\" title=\"Copyright\" name=\"showCopyright\" checked>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value>\n            <input type=\"color\" title=\"Color\" value=\"#373365\" selected>\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#373365\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n    \n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row mbr-white\">\n            <div class=\"col-12 col-md-6 col-lg-3\">\n                <h5 mbr-text class=\"mbr-section-subtitle mbr-fonts-style mb-2\" data-app-selector=\".mbr-section-subtitle\" mbr-theme-style=\"display-7\" mbr-if=\"showTitle\"><b>Citation biblique</b></h5>\n                <ul class=\"list mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".list\" data-multiline mbr-article>\n                    <div>« Si quelqu'un dit : \"J'aime Dieu\", alors qu'il a de la haine contre son frère, c'est un menteur. En effet, celui qui n'aime pas son frère, qu'il voit, est incapable d'aimer Dieu, qu'il ne voit pas. </div><div>Et voici le commandement que nous tenons de lui : celui qui aime Dieu, qu'il aime aussi son frère. » <span style=\"font-size: 1rem;\">— <b>Première lettre de Jean 4, 20-21</b></span></div>\n                </ul>\n            </div>\n\n            <div class=\"col-12 col-md-6 col-lg-3\">\n                <h5 mbr-text class=\"mbr-section-subtitle mbr-fonts-style mb-2\" data-app-selector=\".mbr-section-subtitle\" mbr-theme-style=\"display-7\" mbr-if=\"showTitle\"><b>Partenaires</b></h5>\n                <ul class=\"list mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".list\" data-multiline mbr-article>\n                    <div><a href=\"https://www.vatican.va/content/romancuria/fr/dicasteri/dicastero-dialogo-interreligioso.index.html\" class=\"text-success text-primary\" target=\"_blank\">Vatican Dicastère</a></div><div><a href=\"https://relations-catholiques-musulmans.cef.fr/\" class=\"text-success\" target=\"_blank\">Conf. des évêques de France</a></div><div><a href=\"https://lille.catholique.fr/famille-societe/dialogue/dialogue-interreligieux-2/\" class=\"text-success\" target=\"_blank\">Diocèse de Lille</a></div>\n                </ul>\n            </div>\n\n            <div class=\"col-12 col-md-6 col-lg-3 text-center\">\n                <style>\n                    .map-wrapper {\n                        filter: grayscale(100%);\n                        border-radius: 8px;\n                        overflow: hidden;\n                        display: inline-block;\n                    }\n                </style>\n                <div class=\"map-wrapper\">\n                    <iframe src=\"https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2530.021627962608!2d3.0880876763192586!3d50.64528947162996!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47c32a04413994e3%3A0x99509bf2778763a5!2s74%20Rue%20Hippolyte%20Lefebvre%2C%2059800%20Lille!5e0!3m2!1sfr!2sfr!4v1773909007679!5m2!1sfr!2sfr\" width=\"250\" height=\"250\" style=\"border:0;\" allowfullscreen loading=\"lazy\" referrerpolicy=\"no-referrer-when-downgrade\"></iframe>\n                </div>\n            </div>\n\n            <div class=\"col-12 col-md-6 col-lg-3\">\n                <h5 class=\"mbr-section-subtitle mbr-fonts-style mb-2\" mbr-theme-style=\"display-7\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-subtitle\"><br><b>Maison Paul VI</b></h5>\n                <p class=\"mbr-text mbr-fonts-style mb-4\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-text\">\n                    Dialogue interreligieux<br><br>\n                    74 Rue Hippolyte Lefebvre<br>\n                    59800 Lille<br>\n                    03 20 06 43 02<br></p>\n                <h5 class=\"mbr-section-subtitle mbr-fonts-style mb-3\" mbr-theme-style=\"display-7\" mbr-if=\"showTitle && showSocial\" data-app-selector=\".mbr-section-subtitle\"><b>Social</b></h5>\n                <div class=\"social-row display-7\" mbr-if=\"showSocial\">\n                    <div class=\"soc-item\">\n                        <a href=\"https://www.facebook.com/interreligieuxlille\" target=\"_blank\">\n                            <span mbr-icon class=\"mbr-iconfont socicon-facebook socicon\" style=\"color: rgb(55, 51, 101); fill: rgb(55, 51, 101);\"></span>\n                        </a>\n                    </div>\n                    <div class=\"soc-item\" mbr-if=\"socialCount>1\">\n                        <a href=\"https://x.com/InterLille\" target=\"_blank\">\n                            <span mbr-icon class=\"mbr-iconfont socicon-twitter socicon\" style=\"color: rgb(55, 51, 101); fill: rgb(55, 51, 101);\"></span>\n                        </a>\n                    </div>\n                    <div class=\"soc-item\" mbr-if=\"socialCount>2\">\n                        <a href=\"https://www.instagram.com/sdrmlille/\" target=\"_blank\">\n                            <span mbr-icon class=\"mbr-iconfont socicon-instagram socicon\" style=\"color: rgb(55, 51, 101); fill: rgb(55, 51, 101);\"></span>\n                        </a>\n                    </div>\n                    <div class=\"soc-item\" mbr-if=\"socialCount>3\">\n                        <a href=\"https://www.tiktok.com/@sdrmlille\" target=\"_blank\">\n                            <span mbr-icon class=\"mbr-iconfont socicon-tiktok socicon\" style=\"color: rgb(55, 51, 101); fill: rgb(55, 51, 101);\"></span>\n                        </a>\n                    </div>\n                </div>\n            </div>\n\n            <div class=\"col-12 mt-4\" mbr-if=\"showCopyright\">\n                <p class=\"mbr-text mb-0 mbr-fonts-style copyright align-center\" mbr-theme-style=\"display-7\" data-app-selector=\".copyright\" data-app-placeholder=\"Type Text\">© 2026 Diocèse de Lille. Tous droits réservés.&nbsp;<a href=\"mentions.html\" class=\"text-success text-primary\">Mentions Légales</a></p>\n            </div>\n        </div>\n    </div>\n</section>",
          "_anchor": "footer1-av",
          "_isUserblock": true,
          "_cid": "veTe4NhP0l",
          "_protectedParams": [],
          "_global": true,
          "_once": "footers",
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            ".progress-container": {
              "z-index": "20000",
              "position": "fixed",
              "width": "100%",
              "height": "(@LineHeight * 1px)",
              "background": "@BckColor",
              "top": "(@TopLine * 1px)"
            },
            ".progress-bar": {
              "height": "(@LineHeight * 1px)",
              "background": "@Linecolor",
              "width": "0%"
            },
            "& when (@Stickyzen2 = false)": {
              ".sticky2": {
                "position": "fixed",
                "top": "0px",
                "width": "100%"
              }
            },
            "& when (@Stickyzen2)": {
              ".sticky2": {
                "position": "fixed",
                "top": "(@TopLine2 * 1px)",
                "width": "100%"
              }
            },
            ".hidden": {
              "display": "none"
            },
            "H10": {
              "color": "#767676"
            }
          },
          "_name": "design-block",
          "_customHTML": "<section data-bs-version=\"5.1\" mbr-id=\"_anchor\" class=\"_customHTML\">\n \n  \n     <mbr-parameters>\n<hr><header>Scroll Indicator</header>\n        \n       <input type=\"color\" title=\"Background Color\" name=\"BckColor\" value=\"#ffffff\">\n        <input type=\"color\" title=\"Line Color\" name=\"Linecolor\" value=\"#f5b06b\">\n       <input type=\"range\" title=\"Line Height\" name=\"LineHeight\" min=\"1\" max=\"15\" step=\"1\" value=\"3\">\n        <input type=\"range\" title=\"Top Position\" name=\"TopLine\" min=\"0\" max=\"300\" step=\"1\" value=\"0\">\n      <input type=\"checkbox\" title=\"Sticky\" name=\"Stickyzen2\">\n       <input type=\"range\" title=\"Top Position 2\" name=\"TopLine2\" min=\"0\" max=\"300\" step=\"1\" value=\"70\" condition=\"Stickyzen2\">\n    </mbr-parameters> \n \n  <div class=\"progress-container\" id=\"myHeader\">\n    <div class=\"progress-bar\" id=\"myBar\"></div>\n  </div>      \n  \n<script type=\"text/javascript\">\nwindow.onscroll = function() {myFunction()};\nvar header = document.getElementById(\"myHeader\");\n// Get the offset position of the navbar\nvar sticky = header.offsetTop;\nfunction myFunction() {\n  var winScroll = document.body.scrollTop || document.documentElement.scrollTop;\n  var height = document.documentElement.scrollHeight - document.documentElement.clientHeight;\n  var scrolled = (winScroll / height) * 100;\n  document.getElementById(\"myBar\").style.width = scrolled + \"%\";\n  \n   if (window.pageYOffset > sticky) {\n    header.classList.add(\"sticky2\");\n  } else {\n    header.classList.remove(\"sticky2\");\n  }\n  \n  \n}\n \n        \n</script>\n\n <div mbr-class=\"{'hidden': isPublish}\" style=\"padding:1rem; background-color:#c1c1c1;\">\n   <div class=\"align-center\">\n              <h10> <br><br><br><br><br><br>Scroll Indicator - Progress bar<br>\n        Click the \"gear\" icon to change the layout of the social bar. This text will be removed on preview/publish.<br><br><svg id=\"svg\" version=\"1.1\" xmlns=\"http://www.w3.org/2000/svg\" xmlns:xlink=\"http://www.w3.org/1999/xlink\" width=\"150\" viewBox=\"0, 0, 400,383.33333333333337\"><g id=\"svgg\"><path id=\"path0\" d=\"M37.210 6.152 C 35.603 6.521,34.673 7.586,34.092 9.720 C 33.330 12.516,33.825 95.736,34.612 97.241 C 35.870 99.644,28.382 99.467,134.420 99.600 C 199.138 99.681,231.925 99.852,232.882 100.115 C 235.440 100.816,235.350 101.661,230.295 124.449 C 224.368 151.170,212.070 208.952,209.422 222.521 C 207.800 230.833,207.905 232.790,209.971 232.790 C 211.891 232.790,209.325 235.910,254.122 179.099 C 277.812 149.054,289.953 133.596,295.689 126.174 C 297.890 123.327,306.521 112.368,314.870 101.822 C 367.957 34.759,386.363 11.054,386.765 9.224 C 387.073 7.820,386.446 6.596,385.169 6.111 C 383.972 5.656,39.193 5.697,37.210 6.152 M382.917 8.569 C 384.519 9.741,380.855 14.580,323.489 87.057 C 313.389 99.818,299.260 117.766,292.092 126.942 C 279.051 143.636,265.977 160.258,245.456 186.236 C 239.439 193.853,229.856 206.001,224.162 213.231 C 210.292 230.840,210.188 230.897,212.490 219.587 C 217.028 197.295,227.371 148.754,232.598 125.216 C 237.896 101.359,238.065 99.524,235.099 97.991 C 234.120 97.484,228.193 97.405,188.034 97.358 C 75.294 97.227,37.576 96.911,36.978 96.092 C 36.161 94.974,36.161 10.490,36.978 9.373 C 37.513 8.642,38.883 8.626,116.843 8.435 C 301.952 7.984,382.171 8.024,382.917 8.569 M81.622 108.821 C 107.636 108.875,150.091 108.875,175.966 108.821 C 201.840 108.766,180.556 108.722,128.667 108.722 C 76.779 108.722,55.608 108.766,81.622 108.821 M177.885 157.718 C 177.182 158.404,174.020 162.244,170.860 166.251 C 167.700 170.259,164.939 173.732,164.724 173.970 C 164.509 174.207,161.918 177.468,158.965 181.217 C 156.012 184.965,150.834 191.512,147.459 195.767 C 144.084 200.021,139.856 205.359,138.063 207.629 C 129.342 218.668,112.627 239.779,108.533 244.926 C 107.162 246.650,103.624 251.125,100.671 254.870 C 97.718 258.615,93.156 264.369,90.533 267.657 C 87.91