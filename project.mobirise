            },
            ".mbr-section-title": {
              "color": "#373365"
            }
          },
          "_name": "content7",
          "_sourceTheme": "mobirise5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"content7\" group=\"Content\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"0\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"0\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"range\" name=\"textWidth\" title=\"Width\" min=\"4\" max=\"12\" value=\"10\" step=\"1\">\n        <input type=\"color\" name=\"lineColor\" title=\"Line Color\" value=\"#f5b06b\">\n        <input type=\"color\" name=\"cardColor\" title=\"Color\" value=\"#fafafa\">\n        <header>Background</header>\n        <input type=\"color\" title=\"Color\" name=\"bgColor\" value=\"#ffffff\">\n    </mbr-parameters>\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row justify-content-center\">\n            <div class=\"col-12 col-md-{{textWidth}}\">\n                <blockquote>\n                <h5 class=\"mbr-section-title mbr-fonts-style mb-2\" mbr-theme-style=\"display-7\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title\"><b>Appel au dialogue</b></h5>\n                <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-text\">Le Concile exhorte chrétiens et musulmans à oublier le passé et à s'efforcer sincèrement à la compréhension mutuelle, ainsi qu'à protéger et promouvoir ensemble la justice sociale, les valeurs morales, la paix et la liberté.</p></blockquote>\n            </div>\n        </div>\n    </div>\n</section>",
          "_anchor": "content7-64",
          "_cid": "vd0mTVKQjF",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "_name": "design-block",
          "_sourceTheme": "startm5",
          "_styles": {
            "padding-top": "(@paddingTop * 15px)",
            "padding-bottom": "(@paddingBottom * 15px)",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            ".banner": {
              "z-index": "10",
              "height": "499px"
            },
            ".banner-wrapper": {
              "display": "table-cell",
              "vertical-align": "middle",
              "width": "100%"
            },
            ".bg-banner": {
              "padding": "(@paddingTop * 15px)",
              "height": "auto!important",
              "position": "relative"
            },
            ".bg-banner:after": {
              "top": "100%",
              "left": "50%",
              "border": "solid transparent",
              "content": "\" \"",
              "height": "0",
              "width": "0",
              "position": "absolute",
              "pointer-events": "none",
              "border-top-color": "@bg-value",
              "border-width": "20px 30px",
              "margin-left": "-30px"
            },
            ".bg-banner h1": {
              "margin": "0 !important"
            },
            ".banner h1": {
              "font-weight": "700!important",
              "font-size": "40px"
            },
            ".banner h1:last-child": {
              "margin": "0"
            },
            "H1": {
              "color": "#ffffff"
            },
            ".mbr-text": {
              "color": "#ffffff",
              "text-align": "center"
            }
          },
          "_customHTML": "<section data-bs-version=\"5.1\" class plugins=\"breadcrumbs5\" group=\"Dahomy\">\n\n<mbr-parameters>\n    <!-- Block parameters controls (Blue \"Gear\" panel) -->\n    <header>Size</header>\n    <input type=\"color\" title=\"BG Banner\" value=\"#373365\" name=\"bgbanner\">\n    <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"9\" step=\"1\" value=\"1\">\n    <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"9\" step=\"1\" value=\"0\">\n\n    <header>Background</header>\n    <fieldset type=\"background\" name=\"bg\" parallax>\n    <input type=\"color\" title=\"Background Color\" value=\"#373365\" selected>\n    </fieldset>\n    <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n    <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#232323\" condition=\"overlay && bg.type !== 'color'\">\n    <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.6\" condition=\"overlay && bg.type !== 'color'\">\n    <!-- End block parameters -->\n</mbr-parameters>\n\n<div class=\"banner bg-banner\">\n  <div class=\"container\">\n    <div class=\"row\">\n      <div class=\"col-md-12\">\n   <p class=\"mbr-text mbr-fonts-style\" data-app-selector=\".mbr-text\" mbr-theme-style=\"display-1\">Actualités<br></p>\n      </div>\n    </div>\n  </div>\n</div>\n\n</section>",
          "_anchor": "design-block-bi",
          "_isUserblock": true,
          "_cid": "vf5ao2zMy7",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "background-color": "@bgColor",
            "& when (@reverseContent)": {
              ".row": {
                "flex-direction": "row-reverse"
              }
            },
            ".mbr-text": {
              "color": "#000000"
            },
            ".mbr-section-subtitle": {
              "color": "#000000"
            }
          },
          "_name": "article15",
          "_sourceTheme": "startm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"article15\" group=\"Article\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"checkbox\" name=\"reverseContent\" title=\"Reverse\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"3\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"0\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\">\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubtitle\">\n        <header>Background</header>\n        <input type=\"color\" title=\"Color\" name=\"bgColor\" value=\"#ffffff\">\n    </mbr-parameters>\n    \n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row align-items-stretch\">\n            <!-- Colonne Facebook (gauche) -->\n            <div class=\"col-12 col-lg-5 mb-4 mb-lg-0\">\n                <div class=\"fb-wrapper\" id=\"fb-container\">\n                    <!-- L'iframe sera injecté ici par JavaScript -->\n                </div>\n            </div>\n\n            <!-- Colonne Actualités RSS (droite) -->\n            <div class=\"col-12 col-lg-7\">\n                <link href=\"https://fonts.googleapis.com/css2?family=Mulish:wght@400;600;700&display=swap\" rel=\"stylesheet\">\n                \n                <div class=\"rss-container\">\n                    <div class=\"rss-header\">\n                        <h2>CEF - Relations Catholiques-Musulmans</h2>\n                        <p>dernières actualités</p>\n                    </div>\n                    <div id=\"rss-feed\" class=\"rss-loading\">Chargement...</div>\n                </div>\n\n                <script>\n                    const feedUrl = 'https://relations-catholiques-musulmans.cef.fr/feed/';\n                    \n                    async function loadFeed() {\n                        const container = document.getElementById('rss-feed');\n                        \n                        try {\n                            const proxyUrl = `https://api.rss2json.com/v1/api.json?rss_url=${encodeURIComponent(feedUrl)}`;\n                            const response = await fetch(proxyUrl);\n                            const data = await response.json();\n                            \n                            if (data.status !== 'ok' || !data.items || data.items.length === 0) {\n                                throw new Error('Flux vide ou inaccessible');\n                            }\n                            \n                            let html = '';\n                            data.items.slice(0, 6).forEach(item => {\n                                const title = item.title || 'Sans titre';\n                                const description = item.content || item.description || '';\n                                const link = item.link || '#';\n                                const pubDate = item.pubDate || '';\n                                \n                                const cleanDesc = description.replace(/<[^>]*>/g, '').substring(0, 180);\n                                \n                                let date = '';\n                                try {\n                                    date = new Date(pubDate).toLocaleDateString('fr-FR', {\n                                        year: 'numeric',\n                                        month: 'long',\n                                        day: 'numeric'\n                                    });\n                                } catch (e) {}\n                                \n                                html += `\n                                    <article class=\"rss-article\">\n                                        <h3><a href=\"${link}\" target=\"_blank\" rel=\"noopener noreferrer\">${title}</a></h3>\n                                        <p>${cleanDesc}${cleanDesc.length >= 180 ? '...' : ''}</p>\n                                        ${date ? `<div class=\"rss-meta\">${date}</div>` : ''}\n                                    </article>\n                                `;\n                            });\n                            \n                            container.innerHTML = html;\n                            container.classList.remove('rss-loading');\n                            \n                        } catch (error) {\n                            container.innerHTML = `<div class=\"rss-error\">Impossible de charger le flux. <a href=\"https://relations-catholiques-musulmans.cef.fr/\" target=\"_blank\" rel=\"noopener noreferrer\">Voir le site directement →</a></div>`;\n                            console.error('Erreur RSS:', error);\n                        }\n                    }\n                    \n                    if (document.readyState === 'loading') {\n                        document.addEventListener('DOMContentLoaded', loadFeed);\n                    } else {\n                        loadFeed();\n                    }\n                </script>\n            </div>\n        </div>\n    </div>\n    \n    <style>\n        /* ===== FACEBOOK WRAPPER ===== */\n        .fb-wrapper {\n            position: relative;\n            width: 100%;\n            max-width: 100%;\n            background: #f5f5f5;\n            border-radius: 12px;\n            overflow: hidden;\n            height: 500px;\n        }\n        \n        .fb-wrapper iframe {\n            width: 100% !important;\n            height: 100% !important;\n            display: block;\n            border: none;\n            transform-origin: top left;\n        }\n        \n        /* ===== RSS CONTAINER ===== */\n        .rss-container {\n            background: #ffffff;\n            border-radius: 12px;\n            padding: 25px;\n            height: 500px;\n            overflow-y: auto;\n            border: 1px solid #eee;\n            font-family: 'Mulish', sans-serif;\n        }\n        \n        .rss-header {\n            margin-bottom: 25px;\n            border-bottom: 3px solid #373365;\n            padding-bottom: 15px;\n        }\n        \n        .rss-header h2 {\n            font-size: 20px;\n            font-weight: 700;\n            margin-bottom: 5px;\n            color: #373365;\n            text-transform: uppercase;\n            letter-spacing: 1px;\n            line-height: 1.3;\n        }\n        \n        .rss-header p {\n            font-size: 13px;\n            color: #666;\n            margin: 0;\n            text-transform: lowercase;\n        }\n        \n        .rss-loading {\n            text-align: center;\n            padding: 40px;\n            color: #999;\n            font-family: 'Mulish', sans-serif;\n            font-size: 14px;\n        }\n        \n        .rss-error {\n            background: #f8f9fa;\n            padding: 20px;\n            border-left: 4px solid #373365;\n            color: #666;\n            font-family: 'Mulish', sans-serif;\n            font-size: 14px;\n        }\n        \n        .rss-error a {\n            color: #373365;\n            text-decoration: underline;\n        }\n        \n        .rss-article {\n            padding: 18px 0;\n            border-bottom: 1px solid #eee;\n        }\n        \n        .rss-article:last-child {\n            border-bottom: none;\n        }\n        \n        .rss-article h3 {\n            font-size: 15px;\n            font-weight: 700;\n            margin-bottom: 8px;\n            line-height: 1.4;\n            text-transform: uppercase;\n        }\n        \n        .rss-article a {\n            color: #373365;\n            text-decoration: none;\n            transition: color 0.2s ease;\n        }\n        \n        .rss-article a:hover {\n            color: #5a4d9a;\n            text-decoration: underline;\n        }\n        \n        .rss-article p {\n            font-size: 13px;\n            color: #555;\n            line-height: 1.6;\n            margin-bottom: 8px;\n            text-align: justify;\n            text-transform: lowercase;\n            font-weight: 400;\n        }\n        \n        .rss-meta {\n            font-size: 11px;\n            color: #373365;\n            text-transform: lowercase;\n            font-weight: 600;\n        }\n        \n        /* ===== RESPONSIVE ===== */\n        @media (max-width: 991px) {\n            .fb-wrapper, .rss-container {\n                height: 450px;\n            }\n            \n            .rss-container {\n                padding: 20px;\n            }\n            \n            .rss-header h2 {\n                font-size: 18px;\n            }\n        }\n        \n        @media (max-width: 767px) {\n            .fb-wrapper, .rss-container {\n                height: 400px;\n            }\n            \n            .rss-container {\n                padding: 15px;\n            }\n            \n            .rss-header {\n                margin-bottom: 20px;\n            }\n            \n            .rss-header h2 {\n                font-size: 16px;\n                letter-spacing: 0.5px;\n            }\n            \n            .rss-article h3 {\n                font-size: 14px;\n            }\n            \n            .rss-article p {\n                font-size: 12px;\n            }\n        }\n        \n        @media (max-width: 375px) {\n            .fb-wrapper, .rss-container {\n                height: 350px;\n            }\n        }\n        \n        /* Empêcher le débordement horizontal */\n        .article15 {\n            overflow-x: hidden;\n        }\n        \n        .article15 .row {\n            margin-left: 0;\n            margin-right: 0;\n        }\n        \n        .article15 [class*=\"col-\"] {\n            padding-left: 15px;\n            padding-right: 15px;\n        }\n        \n        /* Scrollbar personnalisée pour RSS */\n        .rss-container::-webkit-scrollbar {\n            width: 6px;\n        }\n        \n        .rss-container::-webkit-scrollbar-track {\n            background: #f1f1f1;\n            border-radius: 3px;\n        }\n        \n        .rss-container::-webkit-scrollbar-thumb {\n            background: #373365;\n            border-radius: 3px;\n        }\n        \n        .rss-container::-webkit-scrollbar-thumb:hover {\n            background: #5a4d9a;\n        }\n    </style>\n    \n    <!-- SCRIPT FACEBOOK RESPONSIVE -->\n    <script>\n        (function() {\n            const container = document.getElementById('fb-container');\n            let resizeTimeout;\n            let lastWidth = 0;\n            \n            function createFacebookIframe() {\n                const containerWidth = container.offsetWidth;\n                \n                // Éviter les re-rendus inutiles si la largeur n'a pas changé\n                if (containerWidth === lastWidth && container.querySelector('iframe')) {\n                    return;\n                }\n                \n                lastWidth = containerWidth;\n                \n                // Supprimer l'ancien iframe s'il existe\n                while (container.firstChild) {\n                    container.removeChild(container.firstChild);\n                }\n                \n                // Calculer la hauteur selon le viewport\n                let height = 500;\n                if (window.innerWidth <= 375) height = 350;\n                else if (window.innerWidth <= 767) height = 400;\n                else if (window.innerWidth <= 991) height = 450;\n                \n                // Facebook a une largeur max de 500px, donc on scale si nécessaire\n                let iframeWidth = containerWidth;\n                let scale = 1;\n                \n                if (containerWidth > 500) {\n                    iframeWidth = 500;\n                    scale = containerWidth / 500;\n                }\n                \n                // Créer le nouvel iframe\n                const iframe = document.createElement('iframe');\n                const fbUrl = 'https://www.facebook.com/plugins/page.php' +\n                    '?href=https%3A%2F%2Fwww.facebook.com%2Finterreligieuxlille%2F' +\n                    '&tabs=timeline' +\n                    '&width=' + iframeWidth +\n                    '&height=' + height +\n                    '&small_header=false' +\n                    '&adapt_container_width=true' +\n                    '&hide_cover=false' +\n                    '&show_facepile=true' +\n                    '&lazy=true';\n                \n                iframe.src = fbUrl;\n                iframe.width = iframeWidth;\n                iframe.height = height;\n                iframe.style.border = 'none';\n                iframe.style.overflow = 'hidden';\n                iframe.style.display = 'block';\n                iframe.scrolling = 'no';\n                iframe.frameBorder = '0';\n                iframe.allowFullscreen = 'true';\n                iframe.allow = 'autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share';\n                iframe.loading = 'lazy';\n                \n                // Appliquer le scale si nécessaire (pour les grands écrans)\n                if (scale > 1) {\n                    iframe.style.transform = 'scale(' + scale + ')';\n                    iframe.style.transformOrigin = 'top left';\n                    iframe.style.width = '500px';\n                } else {\n                    iframe.style.width = '100%';\n                }\n                \n                container.appendChild(iframe);\n            }\n            \n            // Créer l'iframe au chargement\n            if (document.readyState === 'loading') {\n                document.addEventListener('DOMContentLoaded', function() {\n                    setTimeout(createFacebookIframe, 100);\n                });\n            } else {\n                setTimeout(createFacebookIframe, 100);\n            }\n            \n            // Recréer l'iframe au redimensionnement (avec debounce)\n            window.addEventListener('resize', function() {\n                clearTimeout(resizeTimeout);\n                resizeTimeout = setTimeout(createFacebookIframe, 250);\n            });\n            \n            // Recréer aussi sur changement d'orientation (mobile)\n            window.addEventListener('orientationchange', function() {\n                setTimeout(createFacebookIframe, 300);\n            });\n        })();\n    </script>\n</section>",
          "_anchor": "article15-bb",
          "_isUserblock": true,
          "_cid": "vf4mbdNaNE",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "_name": "footer1",
          "_sourceTheme": "mobirise5",
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".social-row": {
              "display": "flex",
              "flex-wrap": "wrap"
            },
            ".soc-item": {
              "display": "flex",
              "align-items": "center",
              "justify-content": "center",
              "border-radius": "50%",
              "background-color": "white",
              "margin-right": "0.5rem",
              "margin-bottom": "1rem",
              "padding": "0.5rem",
              "height": "2.5rem",
              "width": "2.5rem"
            },
            "@media (max-width: 767px)": {
              ".row": {
                "text-align": "center"
              },
              ".social-row": {
                "justify-content": "center"
              }
            },
            ".list": {
              "list-style": "none",
              "padding-left": "0",
              "@media (max-width: 991px)": {
                "margin-bottom": "2rem"
              },
              "@media (min-width: 992px)": {
                "margin-bottom": "0rem"
              },
              "color": "#ffffff",
              "text-align": "justify"
            },
            ".mbr-text": {
              "color": "#ffffff"
            },
            ".mbr-iconfont": {
              "color": "black"
            },
            ".list DIV": {
              "text-align": "justify"
            }
          },
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"footer1\" group=\"Footers\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" global once=\"footers\" mbr-class=\"{'mbr-parallax-background': bg.parallax}\">\n\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"3\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Social\" name=\"showSocial\" checked>\n        <input type=\"range\" name=\"socialCount\" title=\"Social Count\" min=\"1\" max=\"4\" step=\"1\" value=\"4\" condition=\"showSocial\">\n        <input type=\"checkbox\" title=\"Copyright\" name=\"showCopyright\" checked>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value>\n            <input type=\"color\" title=\"Color\" value=\"#373365\" selected>\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#373365\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n    \n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row mbr-white\">\n            <div class=\"col-12 col-md-6 col-lg-3\">\n                <h5 mbr-text class=\"mbr-section-subtitle mbr-fonts-style mb-2\" data-app-selector=\".mbr-section-subtitle\" mbr-theme-style=\"display-7\" mbr-if=\"showTitle\"><b>Citation biblique</b></h5>\n                <ul class=\"list mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".list\" data-multiline mbr-article>\n                    <div>« Si quelqu'un dit : \"J'aime Dieu\", alors qu'il a de la haine contre son frère, c'est un menteur. En effet, celui qui n'aime pas son frère, qu'il voit, est incapable d'aimer Dieu, qu'il ne voit pas. </div><div>Et voici le commandement que nous tenons de lui : celui qui aime Dieu, qu'il aime aussi son frère. » <span style=\"font-size: 1rem;\">— <b>Première lettre de Jean 4, 20-21</b></span></div>\n                </ul>\n            </div>\n\n            <div class=\"col-12 col-md-6 col-lg-3\">\n                <h5 mbr-text class=\"mbr-section-subtitle mbr-fonts-style mb-2\" data-app-selector=\".mbr-section-subtitle\" mbr-theme-style=\"display-7\" mbr-if=\"showTitle\"><b>Partenaires</b></h5>\n                <ul class=\"list mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".list\" data-multiline mbr-article>\n                    <div><a href=\"https://www.vatican.va/content/romancuria/fr/dicasteri/dicastero-dialogo-interreligioso.index.html\" class=\"text-success text-primary\" target=\"_blank\">Vatican Dicastère</a></div><div><a href=\"https://relations-catholiques-musulmans.cef.fr/\" class=\"text-success\" target=\"_blank\">Conf. des évêques de France</a></div><div><a href=\"https://lille.catholique.fr/famille-societe/dialogue/dialogue-interreligieux-2/\" class=\"text-success\" target=\"_blank\">Diocèse de Lille</a></div>\n                </ul>\n            </div>\n\n            <div class=\"col-12 col-md-6 col-lg-3 text-center\">\n                <style>\n                    .map-wrapper {\n                        filter: grayscale(100%);\n                        border-radius: 8px;\n                        overflow: hidden;\n                        display: inline-block;\n                    }\n                </style>\n                <div class=\"map-wrapper\">\n                    <iframe src=\"https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2530.021627962608!2d3.0880876763192586!3d50.64528947162996!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47c32a04413994e3%3A0x99509bf2778763a5!2s74%20Rue%20Hippolyte%20Lefebvre%2C%2059800%20Lille!5e0!3m2!1sfr!2sfr!4v1773909007679!5m2!1sfr!2sfr\" width=\"250\" height=\"250\" style=\"border:0;\" allowfullscreen loading=\"lazy\" referrerpolicy=\"no-referrer-when-downgrade\"></iframe>\n                </div>\n            </div>\n\n            <div class=\"col-12 col-md-6 col-lg-3\">\n                <h5 class=\"mbr-section-subtitle mbr-fonts-style mb-2\" mbr-theme-style=\"display-7\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-subtitle\"><br><b>Maison Paul VI</b></h5>\n                <p class=\"mbr-text mbr-fonts-style mb-4\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-text\">\n                    Dialogue interreligieux<br><br>\n                    74 Rue Hippolyte Lefebvre<br>\n                    59800 Lille<br>\n                    03 20 06 43 02<br></p>\n                <h5 class=\"mbr-section-subtitle mbr-fonts-style mb-3\" mbr-theme-style=\"display-7\" mbr-if=\"showTitle && showSocial\" data-app-selector=\".mbr-section-subtitle\"><b>Social</b></h5>\n                <div class=\"social-row display-7\" mbr-if=\"showSocial\">\n                    <div class=\"soc-item\">\n                        <a href=\"https://www.facebook.com/interreligieuxlille\" target=\"_blank\">\n                            <span mbr-icon class=\"mbr-iconfont socicon-facebook socicon\" style=\"color: rgb(55, 51, 101); fill: rgb(55, 51, 101);\"></span>\n                        </a>\n                    </div>\n                    <div class=\"soc-item\" mbr-if=\"socialCount>1\">\n                        <a href=\"https://x.com/InterLille\" target=\"_blank\">\n                            <span mbr-icon class=\"mbr-iconfont socicon-twitter socicon\" style=\"color: rgb(55, 51, 101); fill: rgb(55, 51, 101);\"></span>\n                        </a>\n                    </div>\n                    <div class=\"soc-item\" mbr-if=\"socialCount>2\">\n                        <a href=\"https://www.instagram.com/sdrmlille/\" target=\"_blank\">\n                            <span mbr-icon class=\"mbr-iconfont socicon-instagram socicon\" style=\"color: rgb(55, 51, 101); fill: rgb(55, 51, 101);\"></span>\n                        </a>\n                    </div>\n                    <div class=\"soc-item\" mbr-if=\"socialCount>3\">\n                        <a href=\"https://www.tiktok.com/@sdrmlille\" target=\"_blank\">\n                            <span mbr-icon class=\"mbr-iconfont socicon-tiktok socicon\" style=\"color: rgb(55, 51, 101); fill: rgb(55, 51, 101);\"></span>\n                        </a>\n                    </div>\n                </div>\n            </div>\n\n            <div class=\"col-12 mt-4\" mbr-if=\"showCopyright\">\n                <p class=\"mbr-text mb-0 mbr-fonts-style copyright align-center\" mbr-theme-style=\"display-7\" data-app-selector=\".copyright\" data-app-placeholder=\"Type Text\">© 2026 Diocèse de Lille. Tous droits réservés.&nbsp;<a href=\"mentions.html\" class=\"text-success text-primary\">Mentions Légales</a></p>\n            </div>\n        </div>\n    </div>\n</section>",
          "_anchor": "footer1-av",
          "_isUserblock": true,
          "_cid": "veTe4NhP0l",
          "_protectedParams": [],
          "_global": true,
          "_once": "footers",
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            ".progress-container": {
              "z-index": "20000",
              "position": "fixed",
              "width": "100%",
              "height": "(@LineHeight * 1px)",
              "background": "@BckColor",
              "top": "(@TopLine * 1px)"
            },
            ".progress-bar": {
              "height": "(@LineHeight * 1px)",
              "background": "@Linecolor",
              "width": "0%"
            },
            "& when (@Stickyzen2 = false)": {
              ".sticky2": {
                "position": "fixed",
                "top": "0px",
                "width": "100%"
              }
            },
            "& when (@Stickyzen2)": {
              ".sticky2": {
                "position": "fixed",
                "top": "(@TopLine2 * 1px)",
                "width": "100%"
              }
            },
            ".hidden": {
              "display": "none"
            },
            "H10": {
              "color": "#767676"
            }
          },
          "_name": "design-block",
          "_customHTML": "<section data-bs-version=\"5.1\" mbr-id=\"_anchor\" class=\"_customHTML\">\n \n  \n     <mbr-parameters>\n<hr><header>Scroll Indicator</header>\n        \n       <input type=\"color\" title=\"Background Color\" name=\"BckColor\" value=\"#ffffff\">\n        <input type=\"color\" title=\"Line Color\" name=\"Linecolor\" value=\"#f5b06b\">\n       <input type=\"range\" title=\"Line Height\" name=\"LineHeight\" min=\"1\" max=\"15\" step=\"1\" value=\"3\">\n        <input type=\"range\" title=\"Top Position\" name=\"TopLine\" min=\"0\" max=\"300\" step=\"1\" value=\"0\">\n      <input type=\"checkbox\" title=\"Sticky\" name=\"Stickyzen2\">\n       <input type=\"range\" title=\"Top Position 2\" name=\"TopLine2\" min=\"0\" max=\"300\" step=\"1\" value=\"70\" condition=\"Stickyzen2\">\n    </mbr-parameters> \n \n  <div class=\"progress-container\" id=\"myHeader\">\n    <div class=\"progress-bar\" id=\"myBar\"></div>\n  </div>      \n  \n<script type=\"text/javascript\">\nwindow.onscroll = function() {myFunction()};\nvar header = document.getElementById(\"myHeader\");\n// Get the offset position of the navbar\nvar sticky = header.offsetTop;\nfunction myFunction() {\n  var winScroll = document.body.scrollTop || document.documentElement.scrollTop;\n  var height = document.documentElement.scrollHeight - document.documentElement.clientHeight;\n  var scrolled = (winScroll / height) * 100;\n  document.getElementById(\"myBar\").style.width = scrolled + \"%\";\n  \n   if (window.pageYOffset > sticky) {\n    header.classList.add(\"sticky2\");\n  } else {\n    header.classList.remove(\"sticky2\");\n  }\n  \n  \n}\n \n        \n</script>\n\n <div mbr-class=\"{'hidden': isPublish}\" style=\"padding:1rem; background-color:#c1c1c1;\">\n   <div class=\"align-center\">\n              <h10> <br><br><br><br><br><br>Scroll Indicator - Progress bar<br>\n        Click the \"gear\" icon to change the layout of the social bar. This text will be removed on preview/publish.<br><br><svg id=\"svg\" version=\"1.1\" xmlns=\"http://www.w3.org/2000/svg\" xmlns:xlink=\"http://www.w3.org/1999/xlink\" width=\"150\" viewBox=\"0, 0, 400,383.33333333333337\"><g id=\"svgg\"><path id=\"path0\" d=\"M37.210 6.152 C 35.603 6.521,34.673 7.586,34.092 9.720 C 33.330 12.516,33.825 95.736,34.612 97.241 C 35.870 99.644,28.382 99.467,134.420 99.600 C 199.138 99.681,231.925 99.852,232.882 100.115 C 235.440 100.816,235.350 101.661,230.295 124.449 C 224.368 151.170,212.070 208.952,209.422 222.521 C 207.800 230.833,207.905 232.790,209.971 232.790 C 211.891 232.790,209.325 235.910,254.122 179.099 C 277.812 149.054,289.953 133.596,295.689 126.174 C 297.890 123.327,306.521 112.368,314.870 101.822 C 367.957 34.759,386.363 11.054,386.765 9.224 C 387.073 7.820,386.446 6.596,385.169 6.111 C 383.972 5.656,39.193 5.697,37.210 6.152 M382.917 8.569 C 384.519 9.741,380.855 14.580,323.489 87.057 C 313.389 99.818,299.260 117.766,292.092 126.942 C 279.051 143.636,265.977 160.258,245.456 186.236 C 239.439 193.853,229.856 206.001,224.162 213.231 C 210.292 230.840,210.188 230.897,212.490 219.587 C 217.028 197.295,227.371 148.754,232.598 125.216 C 237.896 101.359,238.065 99.524,235.099 97.991 C 234.120 97.484,228.193 97.405,188.034 97.358 C 75.294 97.227,37.576 96.911,36.978 96.092 C 36.161 94.974,36.161 10.490,36.978 9.373 C 37.513 8.642,38.883 8.626,116.843 8.435 C 301.952 7.984,382.171 8.024,382.917 8.569 M81.622 108.821 C 107.636 108.875,150.091 108.875,175.966 108.821 C 201.840 108.766,180.556 108.722,128.667 108.722 C 76.779 108.722,55.608 108.766,81.622 108.821 M177.885 157.718 C 177.182 158.404,174.020 162.244,170.860 166.251 C 167.700 170.259,164.939 173.732,164.724 173.970 C 164.509 174.207,161.918 177.468,158.965 181.217 C 156.012 184.965,150.834 191.512,147.459 195.767 C 144.084 200.021,139.856 205.359,138.063 207.629 C 129.342 218.668,112.627 239.779,108.533 244.926 C 107.162 246.650,103.624 251.125,100.671 254.870 C 97.718 258.615,93.156 264.369,90.533 267.657 C 87.91