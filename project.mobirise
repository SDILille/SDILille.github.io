        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "background-color": "@bgColor",
            ".content_block": {
              "padding": "60px 15px",
              "padding-right": "20%",
              "&:hover": {
                ".mbr-section-title a": {
                  "color": "@secondaryColor !important"
                }
              },
              "& when (@reverse)": {
                "padding-left": "20%",
                "padding-right": "15px"
              }
            },
            ".card_topic, .mbr-section-subtitle": {
              "margin-bottom": "12px"
            },
            ".card_topic .mbr-iconfont": {
              "font-size": "1rem",
              "color": "@secondaryColor",
              "margin-left": "10px",
              "margin-right": "3px"
            },
            ".image": {
              "position": "relative",
              "&:before": {
                "content": "\"\"",
                "position": "absolute",
                "width": "60%",
                "height": "100%",
                "right": "-1px",
                "background-image": "linear-gradient(to right, fade(#ffffff, 0), fade(@bgColor, 100))",
                "z-index": "1",
                "pointer-events": "none",
                "& when (@reverse)": {
                  "left": "0",
                  "background-image": "linear-gradient(to left, fade(#ffffff, 0), fade(@bgColor, 100))"
                }
              },
              "img": {
                "width": "100%",
                "height": "100%",
                "object-fit": "cover"
              }
            },
            ".mbr-section-btn .btn-secondary-outline": {
              "padding": "3px 0",
              "margin-bottom": "0",
              "border": "none !important",
              "background-color": "transparent !important",
              "&:hover, .active, &:focus": {
                "color": "@primaryColor !important"
              }
            },
            ".category_content": {
              "opacity": ".8"
            },
            "@media (max-width: 991px)": {
              ".content_block": {
                "padding": "30px 15px"
              },
              ".mbr-figure": {
                "padding": "0"
              },
              ".image": {
                "&:before": {
                  "width": "100%",
                  "height": "60%",
                  "bottom": "0",
                  "left": "0",
                  "background-image": "linear-gradient(to bottom, fade(#ffffff, 0), fade(@bgColor, 99))"
                }
              }
            },
            ".mbr-text, .mbr-section-btn": {
              "text-align": "justify",
              "color": "#373365"
            },
            ".mbr-section-title": {
              "color": "#373365"
            }
          },
          "_name": "header6",
          "_sourceTheme": "newsm4",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"header6\" group=\"Headers\">\n\n    <mbr-parameters>\n    <!-- Block parameters controls (Blue \"Gear\" panel) -->\n        <header>Size</header>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"6\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"0\">\n        <input type=\"checkbox\" title=\"Revers\" name=\"reverse\">\n        <input type=\"range\" name=\"textWidth\" title=\"Width\" min=\"4\" max=\"9\" value=\"6\" step=\"1\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Topic\" name=\"showSubtitle\">\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\">\n        <header>Background</header>\n        <input type=\"color\" title=\"Color\" value=\"#ffffff\" name=\"bgColor\">\n    <!-- End block parameters -->\n    </mbr-parameters>\n    \n    <div class>\n        <div class=\"row align-items-center\" mbr-class=\"{'flex-row-reverse' : reverse}\">\n            <div class=\"col-12 col-lg\">\n                <div class=\"mbr-figure\">\n                    <div class=\"image\">\n                        <img src=\"@PROJECT_PATH@/assets/images/design20sans20titre2010-1023x682.webp\" alt=\"Pape et imam musulman en dialogue - Basilique Saint-Pierre\" title>\n                    </div>\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-{{textWidth}}\">\n                <div class=\"content_block\">\n                    <div class=\"card_topic\" mbr-if=\"showSubtitle\">\n                        <span mbr-text class=\"category_content mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".category_content, .card_topic\"><b>Most Read</b></span>\n                        <span mbr-icon class=\"mbr-iconfont mobi-mbri-clock mobi-mbri\"></span>\n                        <span mbr-text class=\"category_estimate mbr-medium mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".category_estimate, .card_topic\">August 27, 2025</span>\n                    </div>\n                    <h1 class=\"mbr-section-title mbr-fonts-style\" mbr-theme-style=\"display-1\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title\">Le dialogue <br>Islamo-Catholique</h1>\n                    <p class=\"mbr-text mbr-fonts-style mt-3\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .mbr-section-btn\">Ce site offre des ressources pour favoriser la connaissance mutuelle et la fraternité entre chrétiens et musulmans.</p>\n                    <div class=\"mbr-section-btn\" mbr-if=\"showButtons\" mbr-buttons mbr-theme-style=\"display-4\"><a class=\"btn btn-secondary-outline\" href=\"#\" data-app-placeholder=\"Type Text\">Read More<span class=\"mobi-mbri mobi-mbri-right mbr-iconfont mbr-iconfont-btn\"></span></a></div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "vcWo7ASJ5U",
