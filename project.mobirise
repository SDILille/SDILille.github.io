        },
        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 15px)",
            "padding-bottom": "(@paddingBottom * 15px)",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".top-part": {
              "margin-bottom": "70px",
              ".mbr-section-subtitle": {
                "color": "#4f87fb",
                "font-weight": "800"
              },
              ".mbr-section-subtitle.display-4": {
                "font-size": "13px",
                "line-height": "1.85",
                "letter-spacing": "2px"
              },
              ".mbr-section-title": {
                "color": "#130947",
                "font-weight": "700"
              },
              ".mbr-section-title.display-2": {
                "line-height": "1.2",
                "letter-spacing": "-0.5px"
              }
            },
            ".nav-tabs .nav-item.open .nav-link:focus, .nav-tabs .nav-link.active:focus": {
              "outline": "none"
            },
            ".nav-tabs": {
              "flex-wrap": "wrap",
              "justify-content": "space-around",
              ".nav-item": {
                "padding": "0rem"
              },
              ".nav-link.display-7": {
                "font-size": "16px !important",
                "line-height": "1.5"
              }
            },
            ".nav-link": {
              "padding": "0.4rem 0.8rem"
            },
            ".nav-tabs .nav-link": {
              "color": "@tabsColor",
              "font-weight": "700",
              "-webkit-transition": "all 0.3s",
              "transition": "all 0.3s",
              "background": "transparent",
              "border": "none",
              "border-radius": "0 !important",
              "border-bottom": "2px solid transparent",
              "&:hover": {
                "cursor": "pointer"
              },
              "&.active": {
                "border-bottom": "2px solid @activeTabColor",
                "color": "#28303f",
                "span": {
                  "color": "@activeTabColor"
                }
              },
              "span": {
                "margin-right": "14px",
                "font-size": "1.525rem",
                "vertical-align": "middle"
              }
            },
            "@media (max-width: 768px)": {
              ".nav-tabs": {
                "-webkit-box-orient": "vertical",
                "-webkit-box-direction": "normal",
                "flex-direction": "column"
              },
              ".mbr-text, .nav-link": {
                "text-align": "left"
              },
              ".nav-link": {
                "padding": "14px 20px",
                "padding-left": "0"
              },
              ".mbr-section-title, .mbr-section-subtitle": {
                "text-align": "left"
              }
            },
            ".tab-content": {
              "margin-top": "44px",
              ".tab-pane": {
                "img": {
                  "width": "100%",
                  "border-radius": "8px",
                  "box-shadow": "0 0 20px rgba(79, 110, 173, 0.1)"
                },
                ".mbr-section-title": {
                  "text-align": "left",
                  "color": "#130947",
                  "font-weight": "700"
                },
                ".mbr-section-title.display-5": {
                  "font-size": "24px",
                  "line-height": "1.16",
                  "letter-spacing": "-0.5px"
                },
                ".mbr-text": {
                  "color": "#6d7a8c"
                },
                ".mbr-text.display-7": {
                  "line-height": "1.5",
                  "font-size": "1em"
                },
                ".mbr-list": {
                  "margin-top": "35px",
                  ".list": {
                    "list-style-type": "none",
                    "padding-left": "0",
                    "li": {
                      "margin-bottom": "1rem",
                      "&:before": {
                        "& when (@showCounter)": {
                          "font-weight": "900",
                          "color": "@counterColor",
                          "display": "inline-block",
                          "content": "'✓'",
                          "text-align": "center",
                          "line-height": "1.5em",
                          "-webkit-transition": "all 0.3s",
                          "transition": "all 0.3s",
                          "width": "25px",
                          "height": "25px"
                        }
                      }
                    }
                  }
                },
                ".mbr-list.display-4": {
                  "font-size": "1em",
                  "color": "#6d7a8c"
                }
              }
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".top-part .mbr-section-subtitle": {
              "color": "#373365",
              "text-align": "center"
            },
            "P": {
              "text-align": "justify",
              "color": "#373365"
            },
            ".top-part .mbr-section-title": {
              "text-align": "center"
            }
          },
          "_name": "tabs1",
          "_sourceTheme": "medicalm4",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"tabs1 tabs medicalm4_tabs1\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" group=\"Tabs\" mbr-class=\"{'mbr-parallax-background':bg.parallax}\" plugins=\"mbr-tabs\">\n\n    <mbr-parameters>\n        <input inline max=\"9\" min=\"0\" name=\"paddingTop\" step=\"1\" title=\"Top\" type=\"range\" value=\"9\">\n        <input inline max=\"9\" min=\"0\" name=\"paddingBottom\" step=\"1\" title=\"Bottom\" type=\"range\" value=\"5\">\n\n        <header>Show/Hide</header>\n        <input name=\"showTitle\" title=\"Title\" type=\"checkbox\" checked>\n        <input name=\"showSubtitle\" title=\"Subtitle\" type=\"checkbox\" checked>\n        <input checked name=\"showIntro\" title=\"Introduction\" type=\"checkbox\">\n        <header>Tab</header>\n        <input checked name=\"showTabTitle\" title=\"Title\" type=\"checkbox\">\n        <input checked name=\"showTabText\" title=\"Text\" type=\"checkbox\">\n        <input checked name=\"showBiblical\" title=\"Biblical Quote\" type=\"checkbox\">\n        <input checked name=\"showList\" title=\"List\" type=\"checkbox\">\n        <input checked condition=\"showList\" name=\"showCounter\" title=\"List Icon\" type=\"checkbox\">\n        <header>Color</header>\n        <input condition=\"showCounter&&showList\" name=\"counterColor\" title=\"List Icon\" type=\"color\" value=\"#373365\">\n        <input name=\"tabsColor\" title=\"Tabs\" type=\"color\" value=\"#6d7a8c\">\n        <input name=\"activeTabColor\" title=\"Active Tab\" type=\"color\" value=\"#373365\">\n        <header>Amount</header>\n        <select name=\"bootstrapTabs\" title=\"Tabs Count\">\n            <option value=\"1\">1</option>\n            <option value=\"2\">2</option>\n            <option value=\"3\">3</option>\n            <option value=\"4\">4</option>\n            <option value=\"5\">5</option>\n            <option selected value=\"6\">6</option>\n        </select>\n        <header>Background</header>\n        <fieldset name=\"bg\" parallax type=\"background\">\n            <input parallax title=\"Image\" type=\"image\" value=\"@PROJECT_PATH@/assets/images/design%2520sans%2520titre%2520(13)-1000x1000.png\">\n            <input title=\"Color\" type=\"color\" value=\"#ffffff\" selected>\n            <input title=\"Video\" type=\"video\" value=\"http://www.youtube.com/watch?v=uNCr7NdOJgw\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"../_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n\n        <input checked condition=\"bg.type !== 'color'\" name=\"overlay\" title=\"Overlay\" type=\"checkbox\">\n        <input condition=\"overlay && bg.type !== 'color'\" name=\"overlayColor\" title=\"Overlay Color\" type=\"color\" value=\"#ffffff\">\n        <input condition=\"overlay && bg.type !== 'color'\" inline max=\"1\" min=\"0\" name=\"overlayOpacity\" step=\"0.1\" title=\"Opacity\" type=\"range\" value=\"0.8\">\n    </mbr-parameters>\n    \n    <style>\n        .tab-image-wrapper {\n            width: 120px !important;\n            height: 120px !important;\n            overflow: hidden !important;\n            margin: 0 !important;\n            padding: 0 !important;\n            flex-shrink: 0 !important;\n        }\n        \n        .tab-image-wrapper img {\n            width: 120px !important;\n            height: 120px !important;\n            display: block !important;\n            object-fit: cover !important;\n        }\n    </style>\n    \n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\"></div>\n    \n    <div class=\"container\">\n        <div class=\"top-part\">\n            <h3 class=\"mbr-section-subtitle mbr-fonts-style align-center mbr-bold\" data-app-selector=\".top-part .mbr-section-subtitle\" mbr-if=\"showSubtitle\" mbr-theme-style=\"display-4\" style=\"color: #373365;\">Proposé par le service diocésain pour les relations interreligieuses</h3>\n            <h1 class=\"mbr-fonts-style mbr-section-title align-center mbr-bold\" data-app-selector=\".top-part .mbr-section-title\" mbr-if=\"showTitle\" mbr-theme-style=\"display-1\" style=\"color: #373365;\">Un Carême transformé par la rencontre</h1>\n            \n            <div class=\"mbr-text pt-4 mbr-fonts-style\" mbr-if=\"showIntro\" mbr-theme-style=\"display-7\" style=\"text-align: justify; max-width: 800px; margin: 0 auto; color: #373365;\">\n                <p><strong>Et si ce Carême, au lieu de tourner sur nous-mêmes, nous laissait vraiment rejoindre par le Christ à travers d'autres croyants ?</strong></p>\n                <p>Faire Carême avec des musulmans, ce n'est pas un peu bizarre pour des chrétiens ? Au contraire : c'est l'occasion de redécouvrir ce qui fait notre foi… et de l'oser, en face à face, avec respect.</p>\n                <p>Un Dieu unique qui se révèle comme Père, Fils et Esprit. Un Jésus qui ne donne pas seulement des règles, mais offre sa vie pour le salut de tous. Une liberté du cœur qui ne s'arrête pas au rite, mais cherche la conversion intérieure.</p>\n                <p>Ce parcours de Carême veut aider surtout les chrétiens à mettre des mots clairs sur cette foi, en rencontrant d'autres croyants sans peur, sans confusion, mais sans s'excuser d'être disciples du Christ.</p>\n                <p>Chaque semaine propose un pas de conversion : traverser nos préjugés, jeûner en vérité, prier plus profondément, partager concrètement, apprendre à écouter, entrer dans la réconciliation. Avec une conviction : le Christ nous précède dans chaque rencontre, et son Évangile peut vraiment transformer nos regards.</p>\n                <p><em>Prêt à laisser ce Carême 2026 devenir un tournant dans ta manière de croire et de rencontrer les autres ?</em></p>\n            </div>\n        </div>\n        \n        <div class=\"row\" style=\"margin-top: 40px;\">\n            <div class=\"col-12 col-md-12\">\n                <ul class=\"nav nav-tabs\" role=\"tablist\">\n                    <li role=\"presentation\" class=\"nav-item first\"><a aria-controls=\"tab1-content\" aria-selected=\"false\" class=\"nav-link mbr-fonts-style show\" data-toggle=\"tab\" data-bs-toggle=\"tab\" href=\"#tab1-content\" role=\"tab\" style=\"color: #373365;\"><span class=\"icon54-v1-desert mbr-iconfont mbr-iconfont-btn\" style=\"color: #373365;\"></span>Entrer au désert</a></li>\n                    <li role=\"presentation\" class=\"nav-item\" mbr-if=\"bootstrapTabs > 1\"><a aria-controls=\"tab2-content\" aria-selected=\"true\" class=\"nav-link mbr-fonts-style active\" data-toggle=\"tab\" data-bs-toggle=\"tab\" href=\"#tab2-content\" role=\"tab\" style=\"color: #373365;\"><span class=\"imind-bread-2 mbr-iconfont mbr-iconfont-btn\" style=\"color: #373365;\"></span>Jeûner ensemble</a></li>\n                    <li role=\"presentation\" class=\"nav-item\" mbr-if=\"bootstrapTabs > 2\"><a aria-controls=\"tab3-content\" aria-selected=\"false\" class=\"nav-link mbr-fonts-style\" data-toggle=\"tab\" data-bs-toggle=\"tab\" href=\"#tab3-content\" role=\"tab\" style=\"color: #373365;\"><span class=\"icon54-v2-church-1 mbr-iconfont mbr-iconfont-btn\" style=\"color: #373365;\"></span>La Prière</a></li>\n                    <li role=\"presentation\" class=\"nav-item\" mbr-if=\"bootstrapTabs > 3\"><a aria-controls=\"tab4-content\" aria-selected=\"false\" class=\"nav-link mbr-fonts-style\" data-toggle=\"tab\" data-bs-toggle=\"tab\" href=\"#tab4-content\" role=\"tab\" style=\"color: #373365;\"><span class=\"icon54-v3-gift mbr-iconfont mbr-iconfont-btn\" style=\"color: #373365;\"></span>L'Aumône</a></li>\n                    <li role=\"presentation\" class=\"nav-item\" mbr-if=\"bootstrapTabs > 4\"><a aria-controls=\"tab5-content\" aria-selected=\"false\" class=\"nav-link mbr-fonts-style\" data-toggle=\"tab\" data-bs-toggle=\"tab\" href=\"#tab5-content\" role=\"tab\" style=\"color: #373365;\"><span class=\"mdi-social-people mbr-iconfont mbr-iconfont-btn\" style=\"color: #373365;\"></span>Vivre ensemble</a></li>\n                    <li role=\"presentation\" class=\"nav-item\" mbr-if=\"bootstrapTabs > 5\"><a aria-controls=\"tab6-content\" aria-selected=\"false\" class=\"nav-link mbr-fonts-style\" data-toggle=\"tab\" data-bs-toggle=\"tab\" href=\"#tab6-content\" role=\"tab\" style=\"color: #373365;\"><span class=\"icon54-v1-heart mbr-iconfont mbr-iconfont-btn\" style=\"color: #373365;\"></span>La Passion</a></li>\n                </ul>\n                \n                <div class=\"tab-content\">\n                    <!-- SEMAINE 1 : ENTRER AU DÉSERT -->\n                    <div aria-labelledby=\"tab1\" class=\"tab-pane active\" id=\"tab1-content\" role=\"tabpanel\">\n                        <div class=\"row align-items-start\">\n                            <div class=\"tab-image-wrapper\">\n                                <img src=\"@PROJECT_PATH@/assets/images/ijcjnoshgdgtfpbc.webp\" alt=\"Entrer au désert\">\n                            </div>\n                            <div style=\"flex: 1;\">\n                                <h2 class=\"mbr-fonts-style mbr-section-title mbr-bold\" mbr-if=\"showTabTitle\" mbr-theme-style=\"display-5\" style=\"color: #373365;\">SEMAINE 1 : ENTRER AU DÉSERT</h2>\n                                <h4 class=\"mbr-fonts-style pt-3 mbr-bold\" mbr-if=\"showBiblical\" mbr-theme-style=\"display-7\" style=\"color: #373365; font-size: 1rem;\">« Convertissez-vous et croyez à l'Évangile » (Mc 1,15)</h4>\n                                <p class=\"mbr-text pt-4 mbr-fonts-style\" mbr-if=\"showTabText\" mbr-theme-style=\"display-7\" style=\"color: #373365; text-align: justify;\"><strong>Se laisser déplacer par la Parole. Déposer ses préjugés pour voir le Christ en l'autre.</strong></p>\n                                <p class=\"mbr-text mbr-fonts-style\" mbr-if=\"showTabText\" mbr-theme-style=\"display-7\" style=\"color: #373365; text-align: justify;\">Et si le premier désert à traverser n'était pas géographique… mais celui de nos préjugés ? On « rentre au désert », d'accord… mais on en sort quand ? Quand tu laisses la Parole de Dieu toucher ton regard sur les autres. Le Christ n'invite pas d'abord à changer de rythme, mais à changer de cœur. « Convertissez‑vous et croyez à l'Évangile » : ce n'est pas une menace, c'est une promesse. Entrer au désert, c'est accepter d'être bousculé par l'Évangile là où nous sommes le plus sûrs de nous : ce que je pense de Dieu, de l'islam, de l'autre qui ne prie pas comme moi.</p>\n                                <p class=\"mbr-text mbr-fonts-style\" mbr-if=\"showTabText\" mbr-theme-style=\"display-7\" style=\"color: #373365; text-align: justify;\">Dans ce silence intérieur, Dieu nous invite à déposer notre peur de l'autre, notre tentation de répondre trop vite, notre besoin d'avoir raison. Il ouvre un espace pour écouter : sa Parole, notre propre vérité, la parole de ceux que nous croisons au lycée, à la fac, au travail. Le désert chrétien n'enferme pas, il élargit : il prépare une rencontre plus vraie.</p>\n                                <div class=\"mbr-list mbr-fonts-style\" mbr-article mbr-if=\"showList\" mbr-theme-style=\"display-4\" style=\"color: #373365;\">\n                                    <ul class=\"list\" mbr-if=\"showList\" style=\"color: #373365;\">\n                                        <li>Déposer nos préjugés</li>\n                                        <li>Voir le Christ en l'autre</li>\n                                        <li>Accepter d'être bousculé par l'Évangile</li>\n                                    </ul>\n                                </div>\n                                <p class=\"mbr-text pt-4 mbr-fonts-style fst-italic\" mbr-if=\"showTabText\" mbr-theme-style=\"display-7\" style=\"color: #373365; text-align: justify;\"><strong>Question de conversion :</strong> Quel préjugé concret es‑tu prêt à déposer en entrant dans ce Carême ?</p>\n                            </div>\n                        </div>\n                    </div>\n\n                    <!-- SEMAINE 2 : JEÛNER ENSEMBLE -->\n                    <div aria-labelledby=\"tab2\" class=\"tab-pane\" id=\"tab2-content\" mbr-if=\"bootstrapTabs > 1\" role=\"tabpanel\">\n                        <div class=\"row align-items-start\">\n                            <div class=\"tab-image-wrapper\">\n                                <img src=\"@PROJECT_PATH@/assets/images/tqnoglswjrtgmrjk.webp\" alt=\"Jeûner ensemble\">\n                            </div>\n                            <div style=\"flex: 1;\">\n                                <h2 class=\"mbr-fonts-style mbr-section-title mbr-bold\" mbr-if=\"showTabTitle\" mbr-theme-style=\"display-5\" style=\"color: #373365;\">SEMAINE 2 : JEÛNER ENSEMBLE</h2>\n                                <h4 class=\"mbr-fonts-style pt-3 mbr-bold\" mbr-if=\"showBiblical\" mbr-theme-style=\"display-7\" style=\"color: #373365; font-size: 1rem;\">« L'homme ne vit pas seulement de pain, mais de toute parole qui sort de la bouche de Dieu » (Mt 4,4)</h4>\n                                <p class=\"mbr-text pt-4 mbr-fonts-style\" mbr-if=\"showTabText\" mbr-theme-style=\"display-7\" style=\"color: #373365; text-align: justify;\"><strong>Vivre le manque pour s'ouvrir à l'Essentiel. Un temps de sobriété en fraternité avec les croyants musulmans.</strong></p>\n                                <p class=\"mbr-text mbr-fonts-style\" mbr-if=\"showTabText\" mbr-theme-style=\"display-7\" style=\"color: #373365; text-align: justify;\">« On arrête de jeûner à quelle heure, nous les chrétiens ? » Et si la question était plutôt : pour QUI je jeûne ? Vous n'avez pas d'heure précise comme au Ramadan… c'est moins exigeant ? C'est différent : notre repère, ce n'est pas le soleil, c'est la Croix. Le jeûne chrétien n'est pas d'abord un exploit, ni une performance spirituelle. L'Église donne des repères, mais laisse une vraie liberté : abstinence de viande chaque vendredi de Carême, jeûne plus strict les Cendres et le Vendredi Saint pour ceux qui le peuvent. Jeûner en chrétien, c'est accepter de manquer pour se rendre disponible : à Dieu, à soi‑même, aux autres.</p>\n                                <div class=\"mbr-list mbr-fonts-style\" mbr-article mbr-if=\"showList\" mbr-theme-style=\"display-4\" style=\"color: #373365;\">\n                                    <ul class=\"list\" mbr-if=\"showList\" style=\"color: #373365;\">\n                                        <li>Accepter de manquer</li>\n                                        <li>Partager avec les croyants musulmans</li>\n                                        <li>Se rendre disponible à Dieu</li>\n                                    </ul>\n                                </div>\n                                <p class=\"mbr-text pt-4 mbr-fonts-style fst-italic\" mbr-if=\"showTabText\" mbr-theme-style=\"display-7\" style=\"color: #373365; text-align: justify;\"><strong>Question de conversion :</strong> Quel jeûne concret pourrait t'ouvrir davantage à Dieu ce Carême ?</p>\n                            </div>\n                        </div>\n                    </div>\n\n                    <!-- SEMAINE 3 : LA PRIÈRE -->\n                    <div aria-labelledby=\"tab3\" class=\"tab-pane\" id=\"tab3-content\" mbr-if=\"bootstrapTabs > 2\" role=\"tabpanel\">\n                        <div class=\"row align-items-start\">\n                            <div class=\"tab-image-wrapper\">\n                                <img src=\"@PROJECT_PATH@/assets/images/crsurjtikrbrrtjc.webp\" alt=\"La Prière\">\n                            </div>\n                            <div style=\"flex: 1;\">\n                                <h2 class=\"mbr-fonts-style mbr-section-title mbr-bold\" mbr-if=\"showTabTitle\" mbr-theme-style=\"display-5\" style=\"color: #373365;\">SEMAINE 3 : LA PRIÈRE</h2>\n                                <h4 class=\"mbr-fonts-style pt-3 mbr-bold\" mbr-if=\"showBiblical\" mbr-theme-style=\"display-7\" style=\"color: #373365; font-size: 1rem;\">« Priez sans cesse » (1 Th 5,17)</h4>\n                                <p class=\"mbr-text pt-4 mbr-fonts-style\" mbr-if=\"showTabText\" mbr-theme-style=\"display-7\" style=\"color: #373365; text-align: justify;\"><strong>Redécouvrir le silence qui unit. Porter dans sa prière les intentions de ceux qui prient différemment.</strong></p>\n                                <p class=\"mbr-text mbr-fonts-style\" mbr-if=\"showTabText\" mbr-theme-style=\"display-7\" style=\"color: #373365; text-align: justify;\">Pour un chrétien, prier, ce n'est pas donner à Dieu un temps « religieux » pour être tranquille le reste de la journée. C'est laisser l'Esprit faire de toute notre vie un dialogue. Le Notre Père, les psaumes, le chapelet, l'oraison silencieuse, une messe de semaine : autant de manières d'entrer dans cette relation où le Christ nous apprend à dire « Père » et à voir le monde avec ses yeux.</p>\n                                <div class=\"mbr-list mbr-fonts-style\" mbr-article mbr-if=\"showList\" mbr-theme-style=\"display-4\" style=\"color: #373365;\">\n                                    <ul class=\"list\" mbr-if=\"showList\" style=\"color: #373365;\">\n                                        <li>Entrer en dialogue constant avec Dieu</li>\n                                        <li>Redécouvrir le silence intérieur</li>\n                                        <li>Porter les intentions d'autrui</li>\n                                    </ul>\n                                </div>\n                                <p class=\"mbr-text pt-4 mbr-fonts-style fst-italic\" mbr-if=\"showTabText\" mbr-theme-style=\"display-7\" style=\"color: #373365; text-align: justify;\"><strong>Question de conversion :</strong> Quel rendez‑vous régulier avec Dieu veux‑tu fixer ?</p>\n                            </div>\n                        </div>\n                    </div>\n\n                    <!-- SEMAINE 4 : L'AUMÔNE -->\n                    <div aria-labelledby=\"tab4\" class=\"tab-pane\" id=\"tab4-content\" mbr-if=\"bootstrapTabs > 3\" role=\"tabpanel\">\n                        <div class=\"row align-items-start\">\n                            <div class=\"tab-image-wrapper\">\n                                <img src=\"@PROJECT_PATH@/assets/images/nueebfpcjwdtkhjc.webp\" alt=\"L'Aumône\">\n                            </div>\n                            <div style=\"flex: 1;\">\n                                <h2 class=\"mbr-fonts-style mbr-section-title mbr-bold\" mbr-if=\"showTabTitle\" mbr-theme-style=\"display-5\" style=\"color: #373365;\">SEMAINE 4 : L'AUMÔNE</h2>\n                                <h4 class=\"mbr-fonts-style pt-3 mbr-bold\" mbr-if=\"showBiblical\" mbr-theme-style=\"display-7\" style=\"color: #373365; font-size: 1rem;\">« Chaque fois que vous l'avez fait à l'un de ces plus petits… c'est à moi » (Mt 25,40)</h4>\n                                <p class=\"mbr-text pt-4 mbr-fonts-style\" mbr-if=\"showTabText\" mbr-theme-style=\"display-7\" style=\"color: #373365; text-align: justify;\"><strong>La foi agit par la charité. Oser une action solidaire commune.</strong></p>\n                                <p class=\"mbr-text mbr-fonts-style\" mbr-if=\"showTabText\" mbr-theme-style=\"display-7\" style=\"color: #373365; text-align: justify;\">Donner n'est plus seulement un geste de solidarité, c'est une rencontre avec le Christ présent dans le frère. L'aumône chrétienne ne se réduit pas à une pièce à la sortie de l'église : elle touche notre argent, notre temps, nos talents, nos relations. Donner, c'est consentir à ce que la logique de l'Évangile – celle du don sans calcul – prenne racine.</p>\n                                <div class=\"mbr-list mbr-fonts-style\" mbr-article mbr-if=\"showList\" mbr-theme-style=\"display-4\" style=\"color: #373365;\">\n                                    <ul class=\"list\" mbr-if=\"showList\" style=\"color: #373365;\">\n                                        <li>Reconnaître le Christ dans le pauvre</li>\n                                        <li>Agir avec générosité</li>\n                                        <li>Bâtir la solidarité</li>\n                                    </ul>\n                                </div>\n                                <p class=\"mbr-text pt-4 mbr-fonts-style fst-italic\" mbr-if=\"showTabText\" mbr-theme-style=\"display-7\" style=\"color: #373365; text-align: justify;\"><strong>Question :</strong> Quel geste d'aumône précis choisir cette semaine ?</p>\n                            </div>\n                        </div>\n                    </div>\n\n                    <!-- SEMAINE 5 : VIVRE ENSEMBLE -->\n                    <div aria-labelledby=\"tab5\" class=\"tab-pane\" id=\"tab5-content\" mbr-if=\"bootstrapTabs > 4\" role=\"tabpanel\">\n                        <div class=\"row align-items-start\">\n                            <div class=\"tab-image-wrapper\">\n                                <img src=\"@PROJECT_PATH@/assets/images/nyezszhvldfyypdr.webp\" alt=\"Vivre ensemble\">\n                            </div>\n                            <div style=\"flex: 1;\">\n                                <h2 class=\"mbr-fonts-style mbr-section-title mbr-bold\" mbr-if=\"showTabTitle\" mbr-theme-style=\"display-5\" style=\"color: #373365;\">SEMAINE 5 : VIVRE ENSEMBLE</h2>\n                                <h4 class=\"mbr-fonts-style pt-3 mbr-bold\" mbr-if=\"showBiblical\" mbr-theme-style=\"display-7\" style=\"color: #373365; font-size: 1rem;\">« Que tous soient un » (Jn 17,21)</h4>\n                                <p class=\"mbr-text pt-4 mbr-fonts-style\" mbr-if=\"showTabText\" mbr-theme-style=\"display-7\" style=\"color: #373365; text-align: justify;\"><strong>Apprendre la langue du cœur. Écouter avec bienveillance.</strong></p>\n                                <p class=\"mbr-text mbr-fonts-style\" mbr-if=\"showTabText\" mbr-theme-style=\"display-7\" style=\"color: #373365; text-align: justify;\">La foi chrétienne devient crédible quand elle se dit simplement, dans une relation où l'autre est respecté. Tenir ensemble une identité claire et une ouverture réelle. Dire « je crois que Jésus est Fils de Dieu, mort et ressuscité » sans agressivité. Vivre ensemble en chrétien, c'est chercher l'unité pour laquelle le Christ a prié : pas une uniformité, mais une communion qui respecte la vérité de chacun.</p>\n                                <div class=\"mbr-list mbr-fonts-style\" mbr-article mbr-if=\"showList\" mbr-theme-style=\"display-4\" style=\"color: #373365;\">\n                                    <ul class=\"list\" mbr-if=\"showList\" style=\"color: #373365;\">\n                                        <li>Écouter vraiment l'autre</li>\n                                        <li>Respecter les différences de foi</li>\n                                        <li>Chercher l'unité</li>\n                                    </ul>\n                                </div>\n                                <p class=\"mbr-text pt-4 mbr-fonts-style fst-italic\" mbr-if=\"showTabText\" mbr-theme-style=\"display-7\" style=\"color: #373365; text-align: justify;\"><strong>Question :</strong> Avec qui dialoguer de foi ce Carême ?</p>\n                            </div>\n                        </div>\n                    </div>\n\n                    <!-- SEMAINE 6 : LA PASSION -->\n                    <div aria-labelledby=\"tab6\" class=\"tab-pane\" id=\"tab6-content\" mbr-if=\"bootstrapTabs > 5\" role=\"tabpanel\">\n                        <div class=\"row align-items-start\">\n                            <div class=\"tab-image-wrapper\">\n                                <img src=\"@PROJECT_PATH@/assets/images/bxnhqshklppcxnvw.webp\" alt=\"La Passion\">\n                            </div>\n                            <div style=\"flex: 1;\">\n                                <h2 class=\"mbr-fonts-style mbr-section-title mbr-bold\" mbr-if=\"showTabTitle\" mbr-theme-style=\"display-5\" style=\"color: #373365;\">SEMAINE 6 : LA PASSION</h2>\n                                <h4 class=\"mbr-fonts-style pt-3 mbr-bold\" mbr-if=\"showBiblical\" mbr-theme-style=\"display-7\" style=\"color: #373365; font-size: 1rem;\">« Heureux les artisans de paix » (Mt 5,9)</h4>\n                                <p class=\"mbr-text pt-4 mbr-fonts-style\" mbr-if=\"showTabText\" mbr-theme-style=\"display-7\" style=\"color: #373365; text-align: justify;\"><strong>Offrir nos divisions à la Croix. S'engager pour la réconciliation.</strong></p>\n                                <p class=\"mbr-text mbr-fonts-style\" mbr-if=\"showTabText\" mbr-theme-style=\"display-7\" style=\"color: #373365; text-align: justify;\">La paix chrétienne ne vient pas d'un accord humain, mais du Christ qui donne sa vie pour tous. Offrir nos divisions à la Croix, c'est déposer devant le Christ nos blessures, nos incompréhensions, nos colères. Au milieu des tensions entre religions, le disciple du Crucifié cherche des chemins de réconciliation, persuadé que la Résurrection a déjà commencé son œuvre.</p>\n                                <div class=\"mbr-list mbr-fonts-style\" mbr-article mbr-if=\"showList\" mbr-theme-style=\"display-4\" style=\"color: #373365;\">\n                                    <ul class=\"list\" mbr-if=\"showList\" style=\"color: #373365;\">\n                                        <li>Déposer nos blessures</li>\n                                        <li>Cheminer vers la réconciliation</li>\n                                        <li>Être artisan de paix</li>\n                                    </ul>\n                                </div>\n                                <p class=\"mbr-text pt-4 mbr-fonts-style fst-italic\" mbr-if=\"showTabText\" mbr-theme-style=\"display-7\" style=\"color: #373365; text-align: justify;\"><strong>Question :</strong> Quel conflit confier à la Croix ?</p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n    </div>\n</section>",
          "_cid": "vdKDP25n47",
          "_anchor": "tabs1-7e",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "_name": "footer1",
          "_sourceTheme": "mobirise5",
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".social-row": {
              "display": "flex",
              "flex-wrap": "wrap"
            },
            ".soc-item": {
              "display": "flex",
              "align-items": "center",
              "justify-content": "center",
              "border-radius": "50%",
              "background-color": "white",
              "margin-right": "0.5rem",
              "margin-bottom": "1rem",
              "padding": "0.5rem",
              "height": "2.5rem",
              "width": "2.5rem"
            },
            "@media (max-width: 767px)": {
              ".row": {
                "text-align": "center"
              },
              ".social-row": {
                "justify-content": "center"
              }
            },
            ".list": {
              "list-style": "none",
              "padding-left": "0",
              "@media (max-width: 991px)": {
