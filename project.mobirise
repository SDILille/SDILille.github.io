          "_name": "menu05",
          "_sourceTheme": "startm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"menu menu5\" group=\"Menu\" plugins=\"DropDown, TouchSwipe\" always-top global once=\"menu\" not-draggable position-absolute>\n\t<mbr-parameters>\n\t\t<header>Show/Hide</header>\n\t\t<input type=\"checkbox\" title=\"Logo\" name=\"showLogo\" checked>\n\t\t<input type=\"range\" title=\"Logo Size\" inline name=\"logoSize\" min=\"1\" max=\"15\" step=\"0.1\" value=\"8.3\" condition=\"showLogo\">\n\t\t<input type=\"checkbox\" title=\"Brand Name\" name=\"showBrand\" checked>\n\t\t<input type=\"checkbox\" title=\"Menu Items\" name=\"showItems\" checked>\n\t\t<select title=\"Menu Items Align\" name=\"contentAlign\" condition=\"showItems\">\n\t\t\t<option value=\"1\">Left</option>\n\t\t\t<option value=\"2\" selected>Center</option>\n\t\t\t<option value=\"3\">Right</option>\n\t\t</select>\n\t\t<input type=\"checkbox\" title=\"Button\" name=\"showButtons\">\n\t\t<header>Styles</header>\n\t\t<input type=\"checkbox\" title=\"Collapsed\" name=\"collapsed\" condition=\"none\">\n\t\t<input type=\"checkbox\" title=\"Transparent\" name=\"transparent\" checked>\n\t\t<input type=\"checkbox\" title=\"Sticky\" name=\"sticky\" checked>\n\t\t<input type=\"range\" title=\"Opacity\" name=\"opacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"transparent\">\n\t\t<input type=\"color\" title=\"Color\" name=\"menuBgColor\" value=\"#ffffff\">\n\t\t<input type=\"color\" title=\"Hamburger\" name=\"hamburgerColor\" value=\"#f5b06b\">\n\t</mbr-parameters>\n\n\t<nav class=\"navbar navbar-dropdown\" mbr-class=\"{'navbar-fixed-top':sticky,\n                     'navbar-expand-lg':!collapsed,\n                     'collapsed':collapsed}\">\n\t\t<div class=\"container\">\n\t\t\t<div class=\"navbar-brand\">\n\t\t\t\t<span mbr-if=\"showLogo\" class=\"navbar-logo\">\n\t\t\t\t\t<a href=\"https://lille.catholique.fr/\" target=\"_blank\">\n\t\t\t\t\t\t<img src=\"@PROJECT_PATH@/assets/images/logo2.png\" alt=\"Logo Église Catholique de Lille - Dialogue Interreligieux\" mbr-style=\"{'height': logoSize + 'rem'}\">\n\t\t\t\t\t</a>\n\t\t\t\t</span>\n\t\t\t\t<span mbr-if=\"showBrand\" mbr-buttons mbr-theme-style=\"display-4\" class=\"navbar-caption-wrap\" data-toolbar=\"-mbrBtnMove,-mbrBtnAdd,-mbrBtnRemove,-iconFont\"><a class=\"navbar-caption text-primary\" data-app-selector=\".navbar-caption\" href=\"https://lille.catholique.fr/famille-societe/dialogue/dialogue-interreligieux-2/\" data-app-placeholder=\"Type Text\" target=\"_blank\">Dialogue Interreligieux</a></span>\n\t\t\t</div>\n\t\t\t<button class=\"navbar-toggler\" type=\"button\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-target=\"#navbarSupportedContent\" data-bs-target=\"#navbarSupportedContent\" aria-controls=\"navbarNavAltMarkup\" aria-expanded=\"false\" aria-label=\"Toggle navigation\" mbr-if=\"showItems || showButtons\">\n\t\t\t\t<div class=\"hamburger\">\n\t\t\t\t\t<span></span>\n\t\t\t\t\t<span></span>\n\t\t\t\t\t<span></span>\n\t\t\t\t\t<span></span>\n\t\t\t\t</div>\n\t\t\t</button>\n\t\t\t<div class=\"collapse navbar-collapse\" id=\"navbarSupportedContent\" mbr-if=\"showItems || showButtons\">\n\t\t\t\t<ul mbr-menu class=\"navbar-nav nav-dropdown\" mbr-theme-style=\"display-4\" mbr-if=\"showItems\" mbr-class=\"{'nav-right': !showButtons,'navbar-nav-top-padding': isPublish && !showBrand && !showLogo}\"><li class=\"nav-item\">\n\t\t\t\t\t\t<a class=\"nav-link link text-primary\" href=\"index.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">Découvrir</a>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li class=\"nav-item dropdown\">\n\t\t\t\t\t\t<a class=\"nav-link link text-primary dropdown-toggle\" href=\"bibliographie.html#Magisterium\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\" aria-expanded=\"false\" data-toggle=\"dropdown-submenu\" data-bs-toggle=\"dropdown\" data-bs-auto-close=\"outside\">Connaître</a><div class=\"dropdown-menu\" aria-labelledby=\"dropdown-524\"><a class=\"text-primary dropdown-item\" href=\"formation.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">Formation</a><a class=\"text-primary dropdown-item\" href=\"bibliographie.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">Documentation</a><a class=\"text-primary show dropdown-item\" href=\"calendrier.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">Calendrier</a></div>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li class=\"nav-item dropdown\">\n\t\t\t\t\t\t<a class=\"nav-link link text-primary dropdown-toggle show\" href=\"index.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\" aria-expanded=\"false\" data-toggle=\"dropdown-submenu\" data-bs-toggle=\"dropdown\" data-bs-auto-close=\"outside\">Dialoguer</a><div class=\"dropdown-menu show\" aria-labelledby=\"dropdown-557\" data-bs-popper=\"none\"><a class=\"text-primary dropdown-item\" href=\"groupes.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">Groupes du dialogue</a><a class=\"text-primary dropdown-item\" href=\"ensembleavecmarie.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">Les classes \"Ensemble avec Marie\"</a><a class=\"text-primary dropdown-item\" href=\"verset.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">Verset du Vendredi</a></div>\n\t\t\t\t\t</li><li class=\"nav-item\"><a class=\"nav-link link text-primary show\" href=\"questions.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">FAQ</a></li></ul>\n\t\t\t\t<div mbr-if=\"showButtons\" mbr-buttons mbr-theme-style=\"display-4\" class=\"navbar-buttons mbr-section-btn\"><a class=\"btn btn-primary\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\"> Start Now!</a></div>\n\t\t\t</div>\n\t\t</div>\n\t</nav>\n</section>",
          "_isUserblock": true,
          "_cid": "veTIz8Gikk",
          "_anchor": "menu05-bo",
          "_protectedParams": [],
          "_global": true,
          "_once": "menu",
          "_params": {}
        },
        {
          "alias": "deltapi-code-editor",
          "_isSecondary": true,
          "_styles": {
            "padding-top": "(@paddingTop * 15px)",
            "padding-bottom": "(@paddingBottom * 15px)",
            "background-color": "@bgColor",
            ".mbr-section": {
              "text-align": "center",
              "color": "#fff"
            },
            "P": {
              "color": "#373365",
              "text-align": "center"
            },
            "H3": {
              "color": "#373365"
            }
          },
          "_name": "custom-html",
          "_sourceTheme": "startm5",
          "_customHTML": "<section class=\"mbr-section article content1\" id=\"verset-vendredi-block\" style=\"background-color: #f7f7fb;\">\n    <mbr-parameters>\n        <header>Réglages du Bloc</header>\n        <input type=\"range\" inline title=\"Haut\" name=\"paddingTop\" min=\"0\" max=\"15\" step=\"1\" value=\"9\">\n        <input type=\"range\" inline title=\"Bas\" name=\"paddingBottom\" min=\"0\" max=\"8\" step=\"1\" value=\"4\">\n        <input type=\"checkbox\" title=\"Pleine Largeur\" name=\"fullWidth\" checked>\n        <input type=\"color\" title=\"Couleur de Fond\" name=\"bgColor\" value=\"#ffffff\">\n    </mbr-parameters>\n\n    <style>\n        :root {\n            --vj-ink: #373B65;\n            --vj-accent: #F5B06B;\n            --vj-accent-dk: #D9894A;\n            --vj-muted: #8888A8;\n        }\n        #verset-vendredi-block { background-color: var(--bgColor); color: var(--vj-ink); font-family: 'Mulish', sans-serif; }\n        \n        /* CORRECTION : Utilisation d'une grille responsive */\n        .vj-grid { \n            display: grid; \n            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); \n            gap: 25px; \n            margin-top: 40px; \n        }\n\n        .vj-card { \n            background: #ffffff; \n            border: 1px solid #dddde8; \n            border-radius: 15px; \n            padding: 25px; \n            cursor: pointer; \n            transition: all 0.3s ease; \n            display: flex; \n            flex-direction: column; \n            height: 100%; \n            position: relative; \n            min-height: 250px;\n        }\n\n        .vj-card:hover { transform: translateY(-5px); box-shadow: 0 10px 25px rgba(55,59,101,0.1); border-color: var(--vj-accent); }\n        \n        .vj-card.current { \n            border: 3px solid var(--vj-accent) !important; \n            box-shadow: 0 20px 40px rgba(245,176,107,0.3) !important;\n            /* On ne force plus l'order -1 ici pour garder la logique chronologique si besoin, \n               ou on le laisse si vous voulez la carte du jour en premier */\n            order: -1; \n        }\n\n        .vj-badge-current { \n            position: absolute; top: -12px; right: 20px; \n            background: var(--vj-accent); color: white; \n            font-size: 11px; font-weight: 800; padding: 4px 12px; \n            border-radius: 20px; z-index: 10; \n            animation: bounce 2s infinite;\n            box-shadow: 0 4px 12px rgba(245,176,107,0.4);\n        }\n\n        @keyframes bounce {\n            0%, 20%, 50%, 80%, 100% { transform: translateY(0); }\n            40% { transform: translateY(-8px); }\n            60% { transform: translateY(-4px); }\n        }\n\n        .vj-card-week { font-size: 11px; font-weight: 700; color: var(--vj-muted); text-transform: uppercase; margin-bottom: 10px; }\n        .vj-card-theme { font-family: 'Playfair Display', serif; font-size: 1.3rem; margin-bottom: 15px; color: var(--vj-ink); font-weight: 700; }\n        .vj-card-bible { font-style: italic; font-size: 0.95rem; line-height: 1.5; margin-bottom: 15px; color: #5a5e8a; flex-grow: 1; }\n        .vj-divider { height: 1px; background: linear-gradient(90deg, transparent, var(--vj-accent), transparent); margin: 15px 0; opacity: 0.4; }\n        .vj-card-arabic { direction: rtl; text-align: right; color: var(--vj-accent-dk); font-size: 1.1rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; font-family: serif; }\n        \n        /* Modal Styles */\n        .vj-overlay { position: fixed; inset: 0; background: rgba(55,59,101,0.7); backdrop-filter: blur(5px); display: none; z-index: 10000; justify-content: center; align-items: center; padding: 20px; }\n        .vj-modal { background: white; border-radius: 20px; max-width: 750px; width: 100%; max-height: 90vh; overflow-y: auto; padding: 40px; position: relative; box-shadow: 0 25px 50px rgba(0,0,0,0.2); }\n        .vj-close { position: absolute; top: 20px; right: 20px; font-size: 24px; border: none; background: none; cursor: pointer; color: var(--vj-muted); }\n        .vj-arabic-block { background: #fffcf5; padding: 20px; border-radius: 12px; border: 1px solid #f9ebd8; margin-bottom: 20px; }\n    </style>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\" [style.padding-top]=\"paddingTop + 'rem'\" [style.padding-bottom]=\"paddingBottom + 'rem']\">\n        <div class=\"row justify-content-center text-center\">\n            <div class=\"col-12 col-lg-10\">\n                <h3 class=\"mbr-section-title mbr-fonts-style mb-3\" mbr-theme-style=\"display-1\">Le Verset du <b>Vendredi</b></h3>\n                <p class=\"mbr-text mbr-fonts-style display-7 mb-4\">Chaque vendredi, un verset biblique et un verset coranique mis en résonance sur un thème spirituel universel.<br>52 semaines · 52 thèmes · Une seule humanité</p>\n                <div class=\"row justify-content-center mb-5\">\n                    <div class=\"col-md-7\">\n                        <input type=\"text\" id=\"vj-input\" class=\"form-control display-7\" placeholder=\"Rechercher un thème (ex: Paix, Justice...)\" style=\"border-radius: 50px; border: 2px solid #dddde8; padding: 12px 25px; background: white;\">\n                    </div>\n                </div>\n            </div>\n        </div>\n\n        <div class=\"vj-grid\" id=\"vj-container\"></div>\n        \n        <div id=\"vj-empty\" class=\"text-center mt-5 display-7\" style=\"display:none; color:#888;\">Aucun résultat trouvé.</div>\n    </div>\n\n    <div class=\"vj-overlay\" id=\"vj-overlay\">\n        <div class=\"vj-modal\" onclick=\"event.stopPropagation()\">\n            <button class=\"vj-close\" onclick=\"closeVjModal()\">✕</button>\n            <div id=\"vj-content\"></div>\n        </div>\n    </div>\n\n    <script>\n    const SEMAINES = [\n        {\"semaine\": 1, \"theme\": \"La Miséricorde\", \"bible_ref\": \"Psaume 103, 8\", \"bible_text\": \"Le Seigneur est tendresse et pitié, lent à la colère et plein d'amour.\", \"quran_ref\": \"Sourate 7 (Al-A'raf), verset 156\", \"arabic\": \"۞ وَٱكْتُبْ لَنَا فِى هَٰذِهِ ٱلدُّنْيَا حَسَنَةًۭ وَفِى ٱلْءَاخِرَةِ إِنَّا هُدْنَآ إِلَيْكَ ۚ قَالَ عَذَابِىٓ أُصِيبُ بِهِۦ مَنْ أَشَآءُ ۖ وَرَحْمَتِى وَسِعَتْ كُلَّ شَىْءٍۢ\", \"french\": \"Et Ma miséricorde embrasse toute chose. Je la prescrirai à ceux qui Me craignent, acquittent la Zakât, et ont foi en Nos signes.\"},\n        {\"semaine\": 2, \"theme\": \"La Lumière\", \"bible_ref\": \"Psaume 119, 105\", \"bible_text\": \"Ta parole est la lumière de mes pas, la lampe de ma route.\", \"quran_ref\": \"Sourate 24 (An-Nur), verset 35\", \"arabic\": \"۞ ٱللَّهُ نُورُ ٱلسَّMَٰوَٰتِ وَٱلْأَرْضِ ۚ مَثَلُ نُورِهِۦ كَمِشْكَوٰةٍۢ فِيهَا مِصْبَاحٌ\", \"french\": \"Allah est la Lumière des cieux et de la terre. Sa lumière est semblable à une niche où se trouve une lampe... Lumière sur lumière. Allah guide vers Sa lumière qui Il veut.\"},\n        {\"semaine\": 3, \"theme\": \"La Paix\", \"bible_ref\": \"Jean 14, 27\", \"bible_text\": \"Je vous laisse la paix, je vous donne ma paix.\", \"quran_ref\": \"Sourate 10 (Yunus), verset 25\", \"arabic\": \"وَٱللَّهُ يَدْعُوٓا۟ إِلَىٰ دَارِ ٱلسَّلَٰمِ وَيَهْدِى مَن يَشَآءُ إِلَىٰ صِرَٰطٍۢ مُّسْتَقِيمٍۢ\", \"french\": \"Allah appelle à la demeure de la paix et guide qui Il veut vers un droit chemin.\"},\n        {\"semaine\": 4, \"theme\": \"Le Pardon\", \"bible_ref\": \"Colossiens 3, 13\", \"bible_text\": \"Le Seigneur vous a pardonnés : faites de même.\", \"quran_ref\": \"Sourate 42 (Ash-Shura), verset 40\", \"arabic\": \"فَمَنْ عَفَا وَأَصْلَحَ فَأَجْرُهُۥ عَلَى ٱللَّهِ ۚ إِنَّهُۥ لَا يُحِبُّ ٱلظَّٰلِمِينَ\", \"french\": \"La sanction d'une mauvaise action est une peine identique. Mais quiconque pardonne et réforme, son salaire incombe à Allah.\"},\n        {\"semaine\": 5, \"theme\": \"La Patience\", \"bible_ref\": \"Romains 12, 12\", \"bible_text\": \"Soyez patients dans la détresse, persévérants dans la prière.\", \"quran_ref\": \"Sourate 2 (Al-Baqarah), verset 153\", \"arabic\": \"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ ٱسْتَعِينُوا۟ بِٱلصَّبْرِ وَٱلصَّلَوٰةِ ۚ إِنَّ ٱللَّهَ مَعَ ٱلصَّٰبِرِينَ\", \"french\": \"O les croyants! Cherchez secours dans l'endurance et la Salât. Car Allah est avec ceux qui sont endurants.\"},\n        {\"semaine\": 6, \"theme\": \"L'Amour du Prochain\", \"bible_ref\": \"Lévitique 19, 18\", \"bible_text\": \"Tu aimeras ton prochain comme toi-même.\", \"quran_ref\": \"Sourate 4 (An-Nisa), verset 36\", \"arabic\": \"۞ وَٱعْبُدُوا۟ ٱللَّهَ وَلَا تُشْرِكُوا۟ بِهِۦ شَيْـًۭٔا ۖ وَبِٱلْوَٰلِدَيْنِ إِحْسَٰنًۭا\", \"french\": \"Adorez Allah et ne Lui donnez aucun associé. Agissez avec bonté envers (vos) père et mère, les proches, les orphelins, les pauvres...\"},\n        {\"semaine\": 7, \"theme\": \"La Création\", \"bible_ref\": \"Psaume 19, 2\", \"bible_text\": \"Les cieux racontent la gloire de Dieu, et l'œuvre de ses mains, le firmament l'annonce.\", \"quran_ref\": \"Sourate 3 (Al-Imran), verset 190\", \"arabic\": \"إِنَّ فِى خَلْقِ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ وَٱخْتِلَٰفِ ٱلَّيْلِ وَٱلنَّهَارِ لَءَايَٰتٍۢ لِّأُو۟لِى ٱلْأَلْبَٰبِ\", \"french\": \"En vérité, dans la création des cieux et de la terre, et dans l'alternance de la nuit et du jour, il y a certes des signes pour les doués d'intelligence.\"},\n        {\"semaine\": 8, \"theme\": \"L'Hospitalité\", \"bible_ref\": \"Hébreux 13, 2\", \"bible_text\": \"N'oubliez pas l'hospitalité : elle a permis à certains, sans le savoir, de recevoir chez eux des anges.\", \"quran_ref\": \"Sourate 51 (Ad-Dhariyat), verset 24\", \"arabic\": \"هَلْ أَتَىٰكَ حَدِيثُ ضَيْفِ إِبْرَٰهِيمَ ٱلْمُكْرَمِينَ\", \"french\": \"T'est-il parvenu le récit des visiteurs honorables d'Abraham?\"},\n        {\"semaine\": 9, \"theme\": \"La Douceur\", \"bible_ref\": \"Matthieu 5, 5\", \"bible_text\": \"Heureux les doux, car ils recevront la terre en héritage.\", \"quran_ref\": \"Sourate 3 (Al-Imran), verset 159\", \"arabic\": \"فَبِمَا رَحْمَةٍۢ مِّنَ ٱللَّهِ لِنتَ لَهُمْ ۖ وَلَوْ كُنتَ فَظًّا غَلِيظَ ٱلْقَلْبِ لَٱنفَضُّوا۟ مِنْ حَوْلِكَ\", \"french\": \"C'est par quelque miséricorde de la part d'Allah que tu as été si doux envers eux! Mais si tu étais rude, ils se seraient enfuis.\"},\n        {\"semaine\": 10, \"theme\": \"La Gratitude\", \"bible_ref\": \"1 Thess. 5, 18\", \"bible_text\": \"Rendez grâce en toute circonstance, car c'est la volonté de Dieu à votre égard.\", \"quran_ref\": \"Sourate 14 (Ibrahim), verset 7\", \"arabic\": \"وَإِذْ تَأَذَّنَ رَبُّكُمْ لَئِن شَكَرْتُمْ لَأَزِيدَنَّكُمْ\", \"french\": \"Et lorsque votre Seigneur proclama: Si vous êtes reconnaissants, très certainement J'augmenterai Mes bienfaits pour vous.\"},\n        {\"semaine\": 11, \"theme\": \"L'Humilité\", \"bible_ref\": \"Jacques 4, 6\", \"bible_text\": \"Dieu s'oppose aux orgueilleux, mais aux humbles il accorde sa grâce.\", \"quran_ref\": \"Sourate 25 (Al-Furqan), verset 63\", \"arabic\": \"وَعِبَادُ ٱلرَّحْمَٰنِ ٱلَّذِينَ يَمْشُونَ عَلَى ٱلْأَرْضِ هَوْنًۭا\", \"french\": \"Les serviteurs du Tout Miséricordieux sont ceux qui marchent humblement sur terre.\"},\n        {\"semaine\": 12, \"theme\": \"Le Secours\", \"bible_ref\": \"Matthieu 25, 40\", \"bible_text\": \"Ce que vous avez fait à l'un de ces plus petits de mes frères, c'est à moi que vous l'avez fait.\", \"quran_ref\": \"Sourate 76 (Al-Insan), verset 8\", \"arabic\": \"وَيُطْعِمُونَ ٱلطَّعَامَ عَلَىٰ حُبِّهِۦ مِسْكِينًۭا وَيَتِيمًۭا وَأَسِيرًا\", \"french\": \"Ils offrent la nourriture, malgré son amour, au pauvre, à l'orphelin et au prisonnier.\"},\n        {\"semaine\": 13, \"theme\": \"La Sagesse\", \"bible_ref\": \"Proverbes 4, 7\", \"bible_text\": \"Le commencement de la sagesse, c'est d'acquérir la sagesse ; acquiers de l'intelligence.\", \"quran_ref\": \"Sourate 31 (Luqman), verset 12\", \"arabic\": \"وَلَقَدْ ءَاتَيْنَا لُقْمَٰنَ ٱلْحِكْمَةَ أَنِ ٱشْكُرْ لِلَّهِ\", \"french\": \"Nous avons effectivement donné à Luqmân la sagesse: Sois reconnaissant à Allah.\"},\n        {\"semaine\": 14, \"theme\": \"La Justice\", \"bible_ref\": \"Michée 6, 8\", \"bible_text\": \"Ce que le Seigneur réclame de toi : respecter le droit, aimer la bonté, et marcher humblement avec ton Dieu.\", \"quran_ref\": \"Sourate 4 (An-Nisa), verset 135\", \"arabic\": \"۞ يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ كُونُوا۟ قَوَّٰmِينَ بِٱلْقِسْطِ\", \"french\": \"O les croyants! Observez strictement la justice et soyez des témoins véridiques comme Allah l'ordonne.\"},\n        {\"semaine\": 15, \"theme\": \"La Foi\", \"bible_ref\": \"Hébreux 11, 1\", \"bible_text\": \"La foi est la garantie des biens que l'on espère, la preuve des réalités qu'on ne voit pas.\", \"quran_ref\": \"Sourate 2 (Al-Baqarah), verset 285\", \"arabic\": \"ءَامَنَ ٱلرَّسُولُ بِمَآ أُنزِلَ إِلَيْهِ مِن رَّبِّهِۦ وَٱلْمُؤْمِنُونَ\", \"french\": \"Le Messager a cru en ce qu'on a fait descendre vers lui venant de son Seigneur, et aussi les croyants.\"},\n        {\"semaine\": 16, \"theme\": \"La Charité\", \"bible_ref\": \"1 Cor. 13, 3\", \"bible_text\": \"Quand je distribuerais tous mes biens aux affamés, s'il me manque l'amour, cela ne me sert de rien.\", \"quran_ref\": \"Sourate 2 (Al-Baqarah), verset 177\", \"arabic\": \"وَءَاتَى ٱلْمَالَ عَلَىٰ حُبِّهِۦ ذَوِى ٱلْقُرْبَىٰ\", \"french\": \"La bonté est de donner de son bien, quelqu'amour qu'on en ait, aux proches, aux orphelins, aux nécessiteux.\"},\n        {\"semaine\": 17, \"theme\": \"La Confiance\", \"bible_ref\": \"Proverbes 3, 5\", \"bible_text\": \"Confie-toi au Seigneur de tout ton cœur, ne t'appuie pas sur ta propre intelligence.\", \"quran_ref\": \"Sourate 65 (At-Talaq), verset 3\", \"arabic\": \"وَمَن يَتَوَكَّلْ عَلَى ٱللَّهِ فَهُوَ حَسْبُهُۥٓ\", \"french\": \"Et quiconque place sa confiance en Allah, Il lui suffit. Allah atteint toujours ce qu'Il Se propose.\"},\n        {\"semaine\": 18, \"theme\": \"La Parole\", \"bible_ref\": \"Matthieu 12, 36\", \"bible_text\": \"Au jour du Jugement, les hommes rendront compte de toute parole sans fondement prononcée.\", \"quran_ref\": \"Sourate 50 (Qaf), verset 18\", \"arabic\": \"مَّا يَلْفِظُ مِن قَوْلٍ إِلَّا لَدَيْهِ رَقِيبٌ عَتِيدٌۭ\", \"french\": \"Il ne prononce pas une parole sans avoir auprès de lui un observateur prêt à l'inscrire.\"},\n        {\"semaine\": 19, \"theme\": \"Le Chemin\", \"bible_ref\": \"Jean 14, 6\", \"bible_text\": \"Je suis le Chemin, la Vérité et la Vie.\", \"quran_ref\": \"Sourate 1 (Al-Fatiha), verset 6\", \"arabic\": \"ٱهْدِنَا ٱلصِّرَٰطَ ٱلْمُسْتَقِيمَ\", \"french\": \"Guide-nous dans le droit chemin,\"},\n        {\"semaine\": 20, \"theme\": \"La Vérité\", \"bible_ref\": \"Jean 8, 32\", \"bible_text\": \"Vous connaîtrez la vérité, et la vérité vous rendra libres.\", \"quran_ref\": \"Sourate 9 (At-Tawbah), verset 119\", \"arabic\": \"يَٰٓأَيُّهَا ٱلَّذِينَ ءَامَنُوا۟ ٱتَّقُوا۟ ٱللَّهَ وَكُونُوا۟ مَعَ ٱلصَّٰدِقِينَ\", \"french\": \"O vous qui croyez! Craignez Allah et soyez avec les véridiques.\"},\n        {\"semaine\": 21, \"theme\": \"La Consolation\", \"bible_ref\": \"2 Cor. 1, 3-4\", \"bible_text\": \"Béni soit Dieu, le Père des miséricordes, qui nous console dans toutes nos détresses.\", \"quran_ref\": \"Sourate 94 (Ash-Sharh), verset 5\", \"arabic\": \"فَإِنَّ mَعَ ٱلْعُسْرِ يُسْرًا\", \"french\": \"A côté de la difficulté est, certes, une facilité!\"},\n        {\"semaine\": 22, \"theme\": \"La Joie\", \"bible_ref\": \"Philippiens 4, 4\", \"bible_text\": \"Soyez toujours dans la joie du Seigneur ; je le répète : soyez dans la joie.\", \"quran_ref\": \"Sourate 10 (Yunus), verset 58\", \"arabic\": \"قُلْ بِفَضْلِ ٱللَّهِ وَبِرَحْمَتِهِۦ فَبِذَٰلِكَ فَلْيَفْرَحُوا۟\", \"french\": \"Dis: Ceci provient de la grâce d'Allah et de Sa miséricorde; Voilà de quoi ils devraient se réjouir.\"},\n        {\"semaine\": 23, \"theme\": \"La Force\", \"bible_ref\": \"Isaïe 40, 31\", \"bible_text\": \"Ceux qui espèrent dans le Seigneur renouvellent leur force : ils courent sans s'épuiser.\", \"quran_ref\": \"Sourate 2 (Al-Baqarah), verset 286\", \"arabic\": \"لَا يُكَلِّفُ ٱللَّهَ نَفْسًا إِلَّا وُسْعَهَا\", \"french\": \"Allah n'impose à aucune âme une charge supérieure à sa capacité.\"},\n        {\"semaine\": 24, \"theme\": \"Le Silence\", \"bible_ref\": \"Psaume 46, 11\", \"bible_text\": \"Arrêtez ! Reconnaissez que je suis Dieu.\", \"quran_ref\": \"Sourate 7 (Al-A'raf), verset 204\", \"arabic\": \"وَإِذَا قُرِئَ ٱلْقُرْءَانُ فَٱسْتَمِعُوا۟ لَهُۥ وَأَنصِتُوا۟\", \"french\": \"Et quand on récite le Coran, prêtez-lui l'oreille attentivement et observez le silence.\"},\n        {\"semaine\": 25, \"theme\": \"Le Souffle\", \"bible_ref\": \"Genèse 2, 7\", \"bible_text\": \"Il insuffla dans ses narines une haleine de vie, et l'homme devint un être vivant.\", \"quran_ref\": \"Sourate 15 (Al-Hijr), verset 29\", \"arabic\": \"فَإِذَا سَوَّيْتُهُۥ وَنَفَخْتُ فِيهِ مِن رُّوحِى\", \"french\": \"Dès que Je l'aurai harmonieusement formé et lui aurai insufflé Mon souffle de vie...\"},\n        {\"semaine\": 26, \"theme\": \"L'Eau Vive\", \"bible_ref\": \"Jean 4, 14\", \"bible_text\": \"L'eau que je lui donnerai deviendra en lui une source jaillissant en vie éternelle.\", \"quran_ref\": \"Sourate 21 (Al-Anbiya), verset 30\", \"arabic\": \"وَجَعَلْنَا مِنَ ٱلْمَآءِ كُلَّ شَىْءٍ حَىٍّ\", \"french\": \"Nous avons fait de l'eau toute chose vivante. Ne croiront-ils donc pas?\"},\n        {\"semaine\": 27, \"theme\": \"Le Repos\", \"bible_ref\": \"Matthieu 11, 28\", \"bible_text\": \"Venez à moi, vous tous qui peinez, et moi, je vous procurerai le repos.\", \"quran_ref\": \"Sourate 13 (Ar-Ra'd), verset 28\", \"arabic\": \"أَلَا بِذِكْرِ ٱللَّهِ تَطْمَئِنُّ ٱلْقُلُوبُ\", \"french\": \"Certes, c'est par l'évocation d'Allah que les cœurs se tranquillisent.\"},\n        {\"semaine\": 28, \"theme\": \"La Bienveillance\", \"bible_ref\": \"Romains 12, 21\", \"bible_text\": \"Ne te laisse pas vaincre par le mal, sois vainqueur du mal par le bien.\", \"quran_ref\": \"Sourate 41 (Fussilat), verset 34\", \"arabic\": \"ٱدْفَعْ بِٱلَّتِى هِىَ أَحْسَنُ\", \"french\": \"Repousse le mal par ce qui est meilleur; et voilà que ton ennemi devient un ami chaleureux.\"},\n        {\"semaine\": 29, \"theme\": \"L'Alliance\", \"bible_ref\": \"Jérémie 31, 33\", \"bible_text\": \"Je mettrai ma loi au fond de leur être et je l'écrirai sur leur cœur.\", \"quran_ref\": \"Sourate 5 (Al-Ma'idah), verset 7\", \"arabic\": \"وَٱذْكُرُوا۟ نِعْمَةَ ٱللَّهِ عَلَيْكُمْ وَمِيثَٰقَهُ\", \"french\": \"Et rappelez-vous le bienfait d'Allah sur vous, ainsi que l'alliance qu'Il a conclue avec vous.\"},\n        {\"semaine\": 30, \"theme\": \"La Protection\", \"bible_ref\": \"Psaume 91, 1-2\", \"bible_text\": \"Celui qui demeure sous l'abri du Très-Haut repose à l'ombre du Tout-Puissant.\", \"quran_ref\": \"Sourate 2 (Al-Baqarah), verset 255\", \"arabic\": \"ٱللَّهُ لَآ إِلَٰهَ إِلَّا هُوَ ٱلْحَىُّ ٱلْقَيُّومُ\", \"french\": \"Allah! Point de divinité à part Lui, le Vivant, Celui qui subsiste par lui-même.\"},\n        {\"semaine\": 31, \"theme\": \"Le Refuge\", \"bible_ref\": \"Psaume 46, 2\", \"bible_text\": \"Dieu est pour nous un refuge et un appui, un secours toujours présent.\", \"quran_ref\": \"Sourate 114 (An-Nas), verset 1\", \"arabic\": \"قُلْ أَعُوذُ بِرَبِّ ٱلنَّاسِ\", \"french\": \"Dis: Je cherche protection auprès du Seigneur des hommes.\"},\n        {\"semaine\": 32, \"theme\": \"La Compassion\", \"bible_ref\": \"Luc 10, 33\", \"bible_text\": \"Un Samaritain arriva près de lui ; il le vit et fut saisi de compassion.\", \"quran_ref\": \"Sourate 90 (Al-Balad), verset 13\", \"arabic\": \"فَكُّ رَقَبَةٍ\", \"french\": \"La vertu est de délier un joug [affranchir un esclave], ou de nourrir un jour de famine.\"},\n        {\"semaine\": 33, \"theme\": \"L'Écoute\", \"bible_ref\": \"1 Rois 19, 12\", \"bible_text\": \"Après le feu, le son d'une brise légère. Élie s'enveloppa le visage.\", \"quran_ref\": \"Sourate 50 (Qaf), verset 37\", \"arabic\": \"أَوْ أَلْقَى ٱلسَّmْعَ وَهُوَ شَهِيدٌۭ\", \"french\": \"Il y a bien là un rappel pour quiconque prête l'oreille tout en étant témoin.\"},\n        {\"semaine\": 34, \"theme\": \"Le Cœur Pur\", \"bible_ref\": \"Matthieu 5, 8\", \"bible_text\": \"Heureux les cœurs purs, car ils verront Dieu.\", \"quran_ref\": \"Sourate 26 (Ash-Shu'ara), verset 89\", \"arabic\": \"إِلَّا مَنْ أَتَى ٱللَّهَ بِقَلْبٍۢ سَلِيمٍۢ\", \"french\": \"Le succès appartient à celui qui vient à Allah avec un cœur sain.\"},\n        {\"semaine\": 35, \"theme\": \"La Générosité\", \"bible_ref\": \"2 Cor. 9, 7\", \"bible_text\": \"Que chacun donne sans contrainte, car Dieu aime celui qui donne avec joie.\", \"quran_ref\": \"Sourate 2 (Al-Baqarah), verset 261\", \"arabic\": \"مَّثَلُ ٱلَّذِينَ يُنفِقُونَ أَمْوَٰلَهُمْ فِى سَبِيلِ ٱللَّهِ\", \"french\": \"Ceux qui dépensent leurs biens dans le sentier d'Allah ressemblent à un grain d'où naissent sept épis.\"},\n        {\"semaine\": 36, \"theme\": \"Le Discernement\", \"bible_ref\": \"1 Thess. 5, 21\", \"bible_text\": \"Examinez toutes choses, et retenez ce qui est bon.\", \"quran_ref\": \"Sourate 49 (Al-Hujurat), verset 6\", \"arabic\": \"إِن جَآءَكُمْ فَاسِقٌۢ بِنَبَإٍۢ فَتَبَيَّنُوٓا۟\", \"french\": \"O vous qui avez cru! Si un pervers vous apporte une nouvelle, voyez bien clair.\"},\n        {\"semaine\": 37, \"theme\": \"La Louange\", \"bible_ref\": \"Psaume 150, 6\", \"bible_text\": \"Que tout être vivant loue le Seigneur !\", \"quran_ref\": \"Sourate 17 (Al-Isra), verset 44\", \"arabic\": \"تُسَبِّحُ لَهُ ٱلسَّمَٰوَٰتُ ٱلسَّبْعُ\", \"french\": \"Les sept cieux et la terre et ceux qui s'y trouvent célèbrent Sa gloire.\"},\n        {\"semaine\": 38, \"theme\": \"L'Unité\", \"bible_ref\": \"Galates 3, 28\", \"bible_text\": \"Il n'y a plus ni Juif ni Grec... car tous vous ne faites qu'un dans le Christ Jésus.\", \"quran_ref\": \"Sourate 49 (Al-Hujurat), verset 13\", \"arabic\": \"وَجَعَلْنَٰكُمْ شُعُوبًۭا وَقَبَآئِلَ لِتEARَفُوٓا۟\", \"french\": \"Nous avons fait de vous des nations et des tribus, pour que vous vous entre-connaissiez.\"},\n        {\"semaine\": 39, \"theme\": \"Respect de la Vie\", \"bible_ref\": \"Genèse 1, 27\", \"bible_text\": \"Dieu créa l'homme à son image, à l'image de Dieu il le créa.\", \"quran_ref\": \"Sourate 5 (Al-Ma'idah), verset 32\", \"arabic\": \"وَمَنْ أَحْيَاهَا فَكَأَنَّمَآ أَحْيَا ٱلنَّاسَ جَمِيعًۭا\", \"french\": \"Quiconque fait don de la vie à une personne, c'est comme s'il faisait don de la vie à tous les hommes.\"},\n        {\"semaine\": 40, \"theme\": \"La Présence\", \"bible_ref\": \"Actes 17, 27-28\", \"bible_text\": \"Il n'est pas loin de chacun de nous, car c'est en lui que nous avons la vie.\", \"quran_ref\": \"Sourate 2 (Al-Baqarah), verset 186\", \"arabic\": \"وَإِذَا سَأَلَكَ عِبَادِى عَنِّى فَإِنِّى قَرِيبٌ\", \"french\": \"Et quand Mes serviteurs t'interrogent sur Moi.. alors Je suis tout proche.\"},\n        {\"semaine\": 41, \"theme\": \"La Promesse\", \"bible_ref\": \"Josué 1, 9\", \"bible_text\": \"Ne tremble pas, car le Seigneur ton Dieu est avec toi partout où tu iras.\", \"quran_ref\": \"Sourate 39 (Az-Zumar), verset 53\", \"arabic\": \"لَا تَقْنَطُوا۟ مِن رَّحْمَةِ ٱللَّهِ\", \"french\": \"Dis: O Mes serviteurs qui avez commis des excès... ne désespérez pas de la miséricorde d'Allah.\"},\n        {\"semaine\": 42, \"theme\": \"Le Souvenir\", \"bible_ref\": \"Deutéronome 8, 2\", \"bible_text\": \"Souviens-toi de tout le chemin que le Seigneur ton Dieu t'a fait faire.\", \"quran_ref\": \"Sourate 13 (Ar-Ra'd), verset 28\", \"arabic\": \"ٱلَّذِينَ ءَامَنُوا۟ وَتَطْمَئِنُّ قُلُوبُهُم بِذِكْرِ ٱللَّهِ\", \"french\": \"Ceux qui ont cru, et dont les cœurs se tranquillisent à l'évocation d'Allah.\"},\n        {\"semaine\": 43, \"theme\": \"La Fidélité\", \"bible_ref\": \"Lamentations 3, 23\", \"bible_text\": \"Tes bontés se renouvellent chaque matin. Grande est ta fidélité !\", \"quran_ref\": \"Sourate 9 (At-Tawbah), verset 4\", \"arabic\": \"فَأَتِمُّوٓا۟ إِلَيْهِمْ عَهْدَهُمْ إِلَىٰ مُدَّتِهِمْ\", \"french\": \"Respectez pleinement le pacte conclu avec eux jusqu'au terme convenu. Allah aime les pieux.\"},\n        {\"semaine\": 44, \"theme\": \"La Droiture\", \"bible_ref\": \"Psaume 15, 1-2\", \"bible_text\": \"Seigneur, qui habitera ta sainte montagne ? Celui qui marche dans l'intégrité.\", \"quran_ref\": \"Sourate 11 (Hud), verset 112\", \"arabic\": \"فَٱسْتَقِمْ كَمَآ أُمِرْتَ\", \"french\": \"Demeure sur le droit chemin comme il t'est commandé, ainsi que ceux qui sont revenus vers Allah.\"},\n        {\"semaine\": 45, \"theme\": \"Le Partage\", \"bible_ref\": \"Luc 3, 11\", \"bible_text\": \"Que celui qui a deux tuniques partage avec celui qui n'en a pas.\", \"quran_ref\": \"Sourate 59 (Al-Hashr), verset 9\", \"arabic\": \"وَيُؤْتِرُونَ عَلَىٰٓ أَنفُسِهِمْ وَلَوْ كَانَ بِهِمْ خَصَاصَةٌۭ\", \"french\": \"Ils les préfèrent à eux-mêmes, même s'il y a pénurie chez eux. Quiconque se prémunit contre son avarice réussit.\"},\n        {\"semaine\": 46, \"theme\": \"Réconciliation\", \"bible_ref\": \"Matthieu 5, 9\", \"bible_text\": \"Heureux les artisans de paix, car ils seront appelés fils de Dieu.\", \"quran_ref\": \"Sourate 4 (An-Nisa), verset 128\", \"arabic\": \"وَٱلصُّلْحُ خَيْرٌۭ\", \"french\": \"La réconciliation est meilleure. Mais si vous agissez en bien et êtes pieux... Allah sait tout.\"},\n        {\"semaine\": 47, \"theme\": \"La Fraternité\", \"bible_ref\": \"1 Jean 4, 20\", \"bible_text\": \"Si quelqu'un dit : J'aime Dieu, et qu'il déteste son frère, c'est un menteur.\", \"quran_ref\": \"Sourate 49 (Al-Hujurat), verset 10\", \"arabic\": \"إِنَّمَا ٱلْمُؤْمِنُونَ إِخْوَةٌۭ\", \"french\": \"Les croyants ne sont que des frères. Etablissez la concorde entre vos frères.\"},\n        {\"semaine\": 48, \"theme\": \"Les Parents\", \"bible_ref\": \"Exode 20, 12\", \"bible_text\": \"Honore ton père et ta mère, afin que tes jours se prolongent.\", \"quran_ref\": \"Sourate 17 (Al-Isra), verset 23\", \"arabic\": \"وَبِٱلْوَٰلِدَيْنِ إِحْسَٰنًا\", \"french\": \"Ton Seigneur a décrété: N'adorez que Lui; et marquez de la bonté envers les père et mère.\"},\n        {\"semaine\": 49, \"theme\": \"La Clémence\", \"bible_ref\": \"Luc 23, 34\", \"bible_text\": \"Père, pardonne-leur : ils ne savent pas ce qu'ils font.\", \"quran_ref\": \"Sourate 42 (Ash-Shura), verset 43\", \"arabic\": \"وَلَمَن صَبَرَ وَغَفَرَ إِنَّ ذَٰلِكَ لَمِنْ عَزْمِ ٱلْأُمُورِ\", \"french\": \"Et celui qui endure et pardonne, cela en vérité, fait partie des bonnes dispositions.\"},\n        {\"semaine\": 50, \"theme\": \"Le Renouveau\", \"bible_ref\": \"2 Cor. 5, 17\", \"bible_text\": \"Si quelqu'un est en Christ, il est une nouvelle créature. Les choses anciennes sont passées.\", \"quran_ref\": \"Sourate 39 (Az-Zumar), verset 53\", \"arabic\": \"لَا تَقْنَطُوا۟ مِن رَّحْمَةِ ٱللَّهِ\", \"french\": \"Ne désespérez pas de la miséricorde d'Allah. Car Allah pardonne tous les péchés.\"},\n        {\"semaine\": 51, \"theme\": \"Émerveillement\", \"bible_ref\": \"Psaume 8, 4\", \"bible_text\": \"Quand je regarde ton ciel, ouvrage de tes doigts, la lune et les étoiles que tu as créées.\", \"quran_ref\": \"Sourate 88 (Al-Ghashiyah), verset 17\", \"arabic\": \"أَفَلَا يَنظُرُونَ إِلَى ٱلْإِبِلِ كَيْفَ خُلِقَتْ\", \"french\": \"Ne considèrent-ils donc pas les chameaux, comment ils ont été créés,\"},\n        {\"semaine\": 52, \"theme\": \"Action de grâce\", \"bible_ref\": \"Psaume 136, 1\", \"bible_text\": \"Rendez grâce au Seigneur car il est bon, car éternel est son amour !\", \"quran_ref\": \"Sourate 55 (Ar-Rahman), verset 13\", \"arabic\": \"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ\", \"french\": \"Lequel donc des bienfaits de votre Seigneur nierez-vous?\"}\n];\n\n    function getWeekNum() {\n        const d = new Date();\n        const start = new Date(d.getFullYear(), 0, 1);\n        const day = Math.floor((d - start) / 86400000);\n        return Math.min(Math.ceil((day + start.getDay() + 1) / 7), 52) || 1;\n    }\n\n    const currentWeek = getWeekNum();\n    const container = document.getElementById('vj-container');\n\n    function displayCards(data) {\n        if(data.length === 0) { \n            container.innerHTML = ''; \n            document.getElementById('vj-empty').style.display='block'; \n            return; \n        }\n        document.getElementById('vj-empty').style.display='none';\n        container.innerHTML = data.map(s => `\n            <div class=\"vj-card ${s.semaine === currentWeek ? 'current' : ''}\" onclick=\"openVjModal(${s.semaine})\">\n                ${s.semaine === currentWeek ? '<div class=\"vj-badge-current\">CETTE SEMAINE</div>' : ''}\n                <div class=\"vj-card-week\">Semaine ${s.semaine}</div>\n                <div class=\"vj-card-theme\">${s.theme}</div>\n                <div class=\"vj-card-bible\">\"${s.bible_text.substring(0,85)}${s.bible_text.length > 85 ? '...' : ''}\"</div>\n                <div class=\"vj-divider\"></div>\n                <div class=\"vj-card-arabic\">${s.arabic}</div>\n            </div>\n        `).join('');\n    }\n\n    window.openVjModal = (sem) => {\n        const s = SEMAINES.find(x => x.semaine === sem);\n        document.getElementById('vj-content').innerHTML = `\n            <h2 class=\"mbr-fonts-style display-2 mb-4\"><b>${s.theme}</b></h2>\n            <div class=\"mb-4 text-left\">\n                <p class=\"text-uppercase font-weight-bold mb-2\" style=\"color:var(--vj-ink); font-size:12px; letter-spacing:1px;\">Tradition Biblique</p>\n                <p class=\"display-7\" style=\"font-style:italic; border-left:3px solid var(--vj-ink); padding-left:15px; line-height:1.6;\">« ${s.bible_text} »</p>\n                <p class=\"text-muted small\">— ${s.bible_ref}</p>\n            </div>\n            <div class=\"vj-divider\" style=\"margin:30px 0;\"></div>\n            <div class=\"mt-4 text-left\">\n                <p class=\"text-uppercase font-weight-bold mb-2\" style=\"color:var(--vj-accent-dk); font-size:12px; letter-spacing:1px;\">Tradition Coranique</p>\n                <div class=\"vj-arabic-block\">\n                    <p dir=\"rtl\" class=\"mb-0\" style=\"font-size:1.6rem; color:var(--vj-accent-dk); line-height:1.8; text-align:right;\">${s.arabic}</p>\n                </div>\n                <p class=\"display-7\" style=\"border-left:3px solid var(--vj-accent); padding-left:15px; line-height:1.6;\">« ${s.french} »</p>\n                <p class=\"text-muted small\">— ${s.quran_ref}</p>\n            </div>\n        `;\n        document.getElementById('vj-overlay').style.display = 'flex';\n        document.body.style.overflow = 'hidden';\n    };\n\n    window.closeVjModal = () => {\n        document.getElementById('vj-overlay').style.display = 'none';\n        document.body.style.overflow = '';\n    };\n\n    document.getElementById('vj-overlay').onclick = closeVjModal;\n\n    document.getElementById('vj-input').addEventListener('input', (e) => {\n        const val = e.target.value.toLowerCase();\n        displayCards(SEMAINES.filter(x => \n            x.theme.toLowerCase().includes(val) || \n            x.bible_text.toLowerCase().includes(val)\n        ));\n    });\n\n    displayCards(SEMAINES);\n    </script>\n       <br> <div class=\"row justify-content-center text-center\">\n            <div class=\"col-12 col-lg-10\">\n                <p class=\"mbr-text mbr-fonts-style display-7 mb-4\">À propos du projet « Le Verset du Vendredi » est un projet de méditation interreligieuse.<br> <br>Chaque vendredi — jour saint dans les deux traditions — un verset biblique et un verset coranique sont mis en résonance autour d'un thème spirituel universel : la miséricorde, la paix, la justice, l'hospitalité… <br>Pas de comparaison, pas de jugement. Juste une mise en parallèle, pour contempler ce que nos traditions partagent en silence.<br><br><i>Textes bibliques : Traduction liturgique AELF · Textes coraniques : Trad. officielle Pr. Muhammad Hamidullah · Texte arabe : Mushaf de Médine ('Uthmani)</i><br></p>\n               \n                    </div>\n                </div>\n        \n</section>",
          "_anchor": "custom-html-by",
          "_isUserblock": true,
          "_cid": "vfqClAbDcm",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "_name": "footer1",
          "_sourceTheme": "mobirise5",
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".social-row": {
              "display": "flex",
              "flex-wrap": "wrap"
            },
            ".soc-item": {
              "display": "flex",
              "align-items": "center",
              "justify-content": "center",
              "border-radius": "50%",
              "background-color": "white",
              "margin-right": "0.5rem",
              "margin-bottom": "1rem",
              "padding": "0.5rem",
              "height": "2.5rem",
              "width": "2.5rem"
            },
            "@media (max-width: 767px)": {
              ".row": {
                "text-align": "center"
              },
              ".social-row": {
                "justify-content": "center"
              }
            },
            ".list": {
              "list-style": "none",
              "padding-left": "0",
              "@media (max-width: 991px)": {
                "margin-bottom": "2rem"
              },
              "@media (min-width: 992px)": {
                "margin-bottom": "0rem"
              },
              "color": "#ffffff",
              "text-align": "justify"
            },
            ".mbr-text": {
              "color": "#ffffff"
            },
            ".mbr-iconfont": {
              "color": "black"
            },
            ".list DIV": {
              "text-align": "justify"
            }
          },
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"footer1\" group=\"Footers\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" global once=\"footers\" mbr-class=\"{'mbr-parallax-background': bg.parallax}\">\n\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"3\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Social\" name=\"showSocial\" checked>\n        <input type=\"range\" name=\"socialCount\" title=\"Social Count\" min=\"1\" max=\"4\" step=\"1\" value=\"4\" condition=\"showSocial\">\n        <input type=\"checkbox\" title=\"Copyright\" name=\"showCopyright\" checked>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@PROJECT_PATH@/assets/images/foo-1-1366x768.webp\" selected>\n            <input type=\"color\" title=\"Color\" value=\"#373365\">\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#373365\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n    \n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row mbr-white\">\n            <div class=\"col-12 col-md-6 col-lg-3\">\n                <h5 mbr-text class=\"mbr-section-subtitle mbr-fonts-style mb-2\" data-app-selector=\".mbr-section-subtitle\" mbr-theme-style=\"display-7\" mbr-if=\"showTitle\"><b>Citation biblique</b></h5>\n                <ul class=\"list mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".list\" data-multiline mbr-article>\n                    <div>« Si quelqu'un dit : \"J'aime Dieu\", alors qu'il a de la haine contre son frère, c'est un menteur. En effet, celui qui n'aime pas son frère, qu'il voit, est incapable d'aimer Dieu, qu'il ne voit pas. </div><div>Et voici le commandement que nous tenons de lui : celui qui aime Dieu, qu'il aime aussi son frère. » <span style=\"font-size: 1rem;\">— <b>Première lettre de Jean 4, 20-21</b></span></div>\n                </ul>\n            </div>\n\n            <div class=\"col-12 col-md-6 col-lg-3\">\n                <h5 mbr-text class=\"mbr-section-subtitle mbr-fonts-style mb-2\" data-app-selector=\".mbr-section-subtitle\" mbr-theme-style=\"display-7\" mbr-if=\"showTitle\"><b>Partenaires</b></h5>\n                <ul class=\"list mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".list\" data-multiline mbr-article>\n                    <div><a href=\"https://www.vatican.va/content/romancuria/fr/dicasteri/dicastero-dialogo-interreligioso.index.html\" class=\"text-success text-primary\" target=\"_blank\">Vatican Dicastère</a></div><div><a href=\"https://relations-catholiques-musulmans.cef.fr/\" class=\"text-success\" target=\"_blank\">Conf. des évêques de France</a></div><div><a href=\"https://lille.catholique.fr/famille-societe/dialogue/dialogue-interreligieux-2/\" class=\"text-success\" target=\"_blank\">Diocèse de Lille</a></div>\n                </ul>\n            </div>\n\n            <div class=\"col-12 col-md-6 col-lg-3 text-center\">\n                <style>\n                    .map-wrapper {\n                        filter: grayscale(100%);\n                        border-radius: 8px;\n                        overflow: hidden;\n                        display: inline-block;\n                    }\n                </style>\n                <div class=\"map-wrapper\">\n                    <iframe src=\"https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2530.021627962608!2d3.0880876763192586!3d50.64528947162996!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47c32a04413994e3%3A0x99509bf2778763a5!2s74%20Rue%20Hippolyte%20Lefebvre%2C%2059800%20Lille!5e0!3m2!1sfr!2sfr!4v1773909007679!5m2!1sfr!2sfr\" width=\"250\" height=\"250\" style=\"border:0;\" allowfullscreen loading=\"lazy\" referrerpolicy=\"no-referrer-when-downgrade\"></iframe>\n                </div>\n            </div>\n\n            <div class=\"col-12 col-md-6 col-lg-3\">\n                <h5 class=\"mbr-section-subtitle mbr-fonts-style mb-2\" mbr-theme-style=\"display-7\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-subtitle\"><br><b>Maison Paul VI</b></h5>\n                <p class=\"mbr-text mbr-fonts-style mb-4\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-text\">\n                    Dialogue interreligieux<br><br>\n                    74 Rue Hippolyte Lefebvre<br>\n                    59800 Lille<br>\n                    03 20 06 43 02<br></p>\n                <h5 class=\"mbr-section-subtitle mbr-fonts-style mb-3\" mbr-theme-style=\"display-7\" mbr-if=\"showTitle && showSocial\" data-app-selector=\".mbr-section-subtitle\"><b>Social</b></h5>\n                <div class=\"social-row display-7\" mbr-if=\"showSocial\">\n                    <div class=\"soc-item\">\n                        <a href=\"https://www.facebook.com/interreligieuxlille\" target=\"_blank\">\n                            <span mbr-icon class=\"mbr-iconfont socicon-facebook socicon\" style=\"color: rgb(55, 51, 101); fill: rgb(55, 51, 101);\"></span>\n                        </a>\n                    </div>\n                    <div class=\"soc-item\" mbr-if=\"socialCount>1\">\n                        <a href=\"https://x.com/InterLille\" target=\"_blank\">\n                            <span mbr-icon class=\"mbr-iconfont socicon-twitter socicon\" style=\"color: rgb(55, 51, 101); fill: rgb(55, 51, 101);\"></span>\n                        </a>\n                    </div>\n                    <div class=\"soc-item\" mbr-if=\"socialCount>2\">\n                        <a href=\"https://www.instagram.com/sdrmlille/\" target=\"_blank\">\n                            <span mbr-icon class=\"mbr-iconfont socicon-instagram socicon\" style=\"color: rgb(55, 51, 101); fill: rgb(55, 51, 101);\"></span>\n                        </a>\n                    </div>\n                    <div class=\"soc-item\" mbr-if=\"socialCount>3\">\n                        <a href=\"https://www.tiktok.com/@sdrmlille\" target=\"_blank\">\n                            <span mbr-icon class=\"mbr-iconfont socicon-tiktok socicon\" style=\"color: rgb(55, 51, 101); fill: rgb(55, 51, 101);\"></span>\n                        </a>\n                    </div>\n                </div>\n            </div>\n\n            <div class=\"col-12 mt-4\" mbr-if=\"showCopyright\">\n                <p class=\"mbr-text mb-0 mbr-fonts-style copyright align-center\" mbr-theme-style=\"display-7\" data-app-selector=\".copyright\" data-app-placeholder=\"Type Text\">© 2026 Diocèse de Lille. Tous droits réservés.&nbsp;<a href=\"mentions.html\" class=\"text-success text-primary\">Mentions Légales</a></p>\n            </div>\n        </div>\n    </div>\n</section>",
          "_isUserblock": true,
          "_cid": "veTe4NhP0l",
          "_anchor": "footer1-bp",
          "_protectedParams": [],
          "_global": true,
          "_once": "footers",
          "_params": {}
        }
      ]
    }
  }
