          "_name": "article08",
          "_sourceTheme": "startm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"article8 cid-ve73gcJ2uz\" group=\"Article\" id=\"article08-8f\" mbr-class=\"{'mbr-fullscreen': fullScreen, 'mbr-parallax-background': bg.parallax}\">\n  <mbr-parameters>\n    <header>Size</header>\n    <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n    <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n    <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"2\">\n    <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"2\">\n    <input type=\"range\" inline title=\"Content Width\" name=\"contentWidth\" min=\"8\" max=\"12\" step=\"1\" value=\"8\">\n    <header>Show/Hide</header>\n    <input type=\"checkbox\" title=\"Image\" name=\"showImage\" checked>\n    <input type=\"checkbox\" title=\"Title\" name=\"showTitle\">\n    <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n    <input type=\"checkbox\" title=\"Button\" name=\"showButtons\" checked>\n    <input type=\"color\" title=\"Background\" name=\"wrapBgColor\" value=\"#ffffff\">\n    <header>Background</header>\n    <fieldset type=\"background\" name=\"bg\" parallax>\n      <input type=\"image\" title=\"Image\" value=\"https://images.unsplash.com/photo-1481627834876-b7833e8f5570?w=1920\" parallax>\n      <input type=\"color\" title=\"Color\" value=\"#ffffff\" selected>\n    </fieldset>\n    <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\">\n    <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#373365\">\n    <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0\">\n  </mbr-parameters>\n\n  <div class=\"mbr-overlay\" mbr-if=\"overlay\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\"></div>\n  \n  <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\" mbr-style=\"{'padding-top': paddingTop + 'rem', 'padding-bottom': paddingBottom + 'rem'}\">\n    <div class=\"row justify-content-center\">\n      <div class=\"col-12 col-lg-{{contentWidth}}\">\n        \n        <!-- CARD OMBRÉE -->\n        <div class=\"card shadow-lg border-0\">\n          <div class=\"card-body\">\n\n            <!-- Image centrée -->\n            <div mbr-if=\"showImage\" class=\"text-center mb-4\">\n              <img src=\"@PROJECT_PATH@/assets/images/magisterium-600x100.webp\" alt=\"Magisterium AI\" style=\"max-width: 300px; height: auto; display: inline-block;\" loading=\"lazy\">\n            </div>\n\n            <!-- Titre -->\n            <h2 mbr-if=\"showTitle\" class=\"mbr-fonts-style mb-3 text-center display-2\" mbr-theme-style=\"display-2\" data-app-selector=\".mbr-section-title\" style=\"color: #373365;\">\n              <strong>MAGISTERIUM AI</strong>\n            </h2>\n\n            <!-- Texte justifié -->\n            <p mbr-if=\"showText\" class=\"mbr-fonts-style mb-3 display-7\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-text\" style=\"color: #666; line-height: 1.6; text-align: justify;\">\n              Magisterium AI est un outil d'intelligence artificielle spécialisé, conçu pour fournir des réponses fiables et fondées sur les enseignements de l'Église catholique. Il puise dans une vaste base de données comprenant plus de 28 000 documents officiels.\n            </p>\n\n            <!-- Bouton -->\n            <div mbr-if=\"showButtons\" class=\"text-center mt-3\">\n              <button class=\"mag-btn\" onclick=\"openMagPopup()\">\n                <span>🤖</span>\n                <span>Ouvrir Magisterium AI</span>\n              </button>\n            </div>\n\n          </div>\n        </div>\n        <!-- FIN CARD OMBRÉE -->\n\n      </div>\n    </div>\n  </div>\n\n  <!-- Backdrop et Popup -->\n  <div id=\"mag-backdrop\" onclick=\"closeMagPopup()\"></div>\n  <div id=\"mag-popup\">\n    <div class=\"mag-header\" id=\"mag-header\">\n      <div class=\"mag-header-left\">\n        <span>🤖</span>\n        <span>Magisterium AI</span>\n      </div>\n      <div class=\"mag-controls\">\n        <button class=\"mag-btn-ctrl\" onclick=\"maximizeMagPopup()\" id=\"mag-maximize-btn\" title=\"Agrandir\">⛶</button>\n        <button class=\"mag-btn-ctrl\" onclick=\"closeMagPopup()\" title=\"Fermer\">✕</button>\n      </div>\n    </div>\n    <div class=\"mag-content\">\n      <iframe id=\"mag-iframe\" src=\"about:blank\" loading=\"lazy\"></iframe>\n    </div>\n  </div>\n\n  <style>\n    .mag-btn {\n      padding: 12px 24px;\n      background-color: #edefea;\n      color: #464845;\n      border: 2px solid #464845;\n      border-radius: 4px;\n      cursor: pointer;\n      font-weight: 600;\n      font-family: 'Mulish', sans-serif;\n      transition: all 0.2s ease-in-out;\n      display: inline-flex;\n      align-items: center;\n      justify-content: center;\n      gap: 8px;\n      font-size: 1rem;\n    }\n    \n    .mag-btn:hover {\n      background-color: #464845;\n      color: #ffffff;\n      transform: translateY(-2px);\n      box-shadow: 0 4px 12px rgba(70, 72, 69, 0.3);\n    }\n\n    .mag-btn:active {\n      transform: translateY(0);\n    }\n\n    #mag-backdrop {\n      display: none;\n      position: fixed;\n      top: 0;\n      left: 0;\n      width: 100%;\n      height: 100%;\n      background: rgba(0, 0, 0, 0.5);\n      z-index: 9998;\n      backdrop-filter: blur(4px);\n    }\n    \n    #mag-backdrop.active {\n      display: block;\n    }\n    \n    #mag-popup {\n      display: none;\n      position: fixed;\n      width: 500px;\n      height: 500px;\n      background: #464845;\n      border-radius: 8px;\n      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);\n      z-index: 9999;\n      flex-direction: column;\n      overflow: hidden;\n    }\n    \n    #mag-popup.active {\n      display: flex;\n    }\n    \n    .mag-header {\n      padding: 16px 24px;\n      background: #464845;\n      color: white;\n      display: flex;\n      justify-content: space-between;\n      align-items: center;\n      cursor: move;\n      user-select: none;\n      font-weight: 600;\n      font-family: 'Mulish', sans-serif;\n      border-bottom: 1px solid rgba(255, 255, 255, 0.1);\n    }\n    \n    .mag-header-left {\n      display: flex;\n      align-items: center;\n      gap: 12px;\n      font-size: 1rem;\n    }\n    \n    .mag-controls {\n      display: flex;\n      gap: 8px;\n    }\n    \n    .mag-btn-ctrl {\n      background-color: rgba(255, 255, 255, 0.2);\n      border: none;\n      color: white;\n      width: 36px;\n      height: 36px;\n      border-radius: 4px;\n      cursor: pointer;\n      font-weight: 600;\n      font-size: 1rem;\n      transition: all 0.2s;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n    }\n    \n    .mag-btn-ctrl:hover {\n      background-color: rgba(255, 255, 255, 0.3);\n      transform: scale(1.05);\n    }\n    \n    .mag-content {\n      flex: 1;\n      overflow: hidden;\n      background: #ffffff;\n    }\n    \n    .mag-content iframe {\n      width: 100%;\n      height: 100%;\n      border: none;\n    }\n\n    @media (max-width: 768px) {\n      #mag-popup {\n        width: 90vw !important;\n        height: 90vh !important;\n        max-width: 500px;\n        max-height: 500px;\n        left: 5vw !important;\n        top: 5vh !important;\n      }\n    }\n    \n    @media (max-width: 480px) {\n      #mag-popup {\n        width: 95vw !important;\n        height: 95vh !important;\n        border-radius: 0;\n      }\n      \n      .mag-btn {\n        padding: 10px 16px;\n        font-size: 0.9rem;\n        width: 100%;\n        max-width: 280px;\n      }\n      \n      .mag-header {\n        padding: 12px 16px;\n      }\n    }\n  </style>\n\n  <script>\n    (function() {\n      let magState = { isDragging: false, offsetX: 0, offsetY: 0, maximized: false };\n      const popup = document.getElementById('mag-popup');\n      const header = document.getElementById('mag-header');\n      const maximizeBtn = document.getElementById('mag-maximize-btn');\n      \n      if (!popup || !header) return;\n\n      header.addEventListener('mousedown', (e) => {\n        if (e.target.closest('.mag-controls')) return;\n        magState.isDragging = true;\n        const rect = popup.getBoundingClientRect();\n        magState.offsetX = e.clientX - rect.left;\n        magState.offsetY = e.clientY - rect.top;\n        popup.style.transition = 'none';\n      });\n\n      document.addEventListener('mousemove', (e) => {\n        if (!magState.isDragging || magState.maximized) return;\n        e.preventDefault();\n        popup.style.left = (e.clientX - magState.offsetX) + 'px';\n        popup.style.top = (e.clientY - magState.offsetY) + 'px';\n      });\n\n      document.addEventListener('mouseup', () => { \n        magState.isDragging = false;\n        if (popup) popup.style.transition = '';\n      });\n\n      window.openMagPopup = function() {\n        const backdrop = document.getElementById('mag-backdrop');\n        const iframe = document.getElementById('mag-iframe');\n        if (backdrop) backdrop.classList.add('active');\n        popup.classList.add('active');\n        popup.style.left = 'calc(50% - 250px)';\n        popup.style.top = 'calc(50% - 250px)';\n        \n        if (iframe && iframe.src === 'about:blank') {\n          iframe.src = 'https://www.magisterium.com/fr';\n        }\n      };\n\n      window.closeMagPopup = function() {\n        const backdrop = document.getElementById('mag-backdrop');\n        if (backdrop) backdrop.classList.remove('active');\n        popup.classList.remove('active');\n        magState.maximized = false;\n      };\n\n      window.maximizeMagPopup = function() {\n        magState.maximized = !magState.maximized;\n        \n        if (magState.maximized) {\n          popup.style.width = '90vw';\n          popup.style.height = '90vh';\n          popup.style.left = '5vw';\n          popup.style.top = '5vh';\n          if (maximizeBtn) maximizeBtn.title = 'Réduire';\n        } else {\n          popup.style.width = '500px';\n          popup.style.height = '500px';\n          popup.style.left = 'calc(50% - 250px)';\n          popup.style.top = 'calc(50% - 250px)';\n          if (maximizeBtn) maximizeBtn.title = 'Agrandir';\n        }\n      };\n\n      document.addEventListener('keydown', (e) => {\n        if (e.key === 'Escape') window.closeMagPopup();\n      });\n    })();\n  </script>\n</section>",
          "_anchor": "Magisterium",
          "_isUserblock": true,
          "_cid": "ve73gcJ2uz",
