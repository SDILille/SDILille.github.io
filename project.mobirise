          "_anchor": "design-block-77",
          "_isUserblock": true,
          "_cid": "vdENAv6aAY",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".mbr-iconfont": {
              "font-size": "1.4rem !important",
              "font-family": "'Moririse2' !important",
              "color": "@primaryColor",
              "margin-left": "1rem"
            },
            ".panel-group": {
              "border": "none"
            },
            ".panel-title": {
              "display": "flex",
              "align-items": "center",
              "justify-content": "space-between"
            },
            ".panel-body, .card-header": {
              "padding": "1rem 0"
            },
            ".panel-title-edit": {
              "color": "#373365"
            },
            ".card .card-header": {
              "background-color": "transparent",
              "margin-bottom": "0"
            },
            ".mbr-section-title": {
              "text-align": "justify"
            },
            "H4": {
              "color": "#373365"
            },
            ".panel-text": {
              "color": "#373365",
              "text-align": "justify"
            }
          },
          "_name": "content16",
          "_sourceTheme": "mobirise5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"content16\" group=\"Content\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{'mbr-parallax-background':bg.parallax}\" plugins=\"mbr-switch-arrow, mobirise-icons2\">\n\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"8\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"6\">\n        <input type=\"range\" name=\"textWidth\" title=\"Width\" min=\"4\" max=\"12\" value=\"6\" step=\"1\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubtitle\">\n        <select title=\"Amount\" name=\"cardAmount\">\n            <option value=\"1\">1</option>\n            <option value=\"2\">2</option>\n            <option value=\"3\">3</option>\n            <option value=\"4\">4</option>\n            <option value=\"5\">5</option>\n            <option value=\"6\">6</option>\n            <option value=\"7\">7</option>\n            <option value=\"8\">8</option>\n            <option value=\"9\">9</option>\n            <option value=\"10\">10</option>\n            <option value=\"11\">11</option>\n            <option value=\"12\">12</option>\n            <option value=\"13\">13</option>\n            <option value=\"14\">14</option>\n            <option value=\"15\">15</option>\n            <option value=\"16\" selected>16</option>\n            <option value=\"17\">17</option>\n        </select>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"../_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#ffffff\" selected>\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"../_images/background13.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" checked condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.9\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n    </div>\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row justify-content-center\">\n            <div class=\"col-12 col-md-{{textWidth}}\">\n                <div class=\"mbr-section-head align-center mb-4\" mbr-if=\"showTitle || showSubtitle\">\n                    <h3 class=\"mbr-section-title mb-0 mbr-fonts-style\" mbr-theme-style=\"display-1\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title\" style=\"color: #373365;\">\n                        Questions &amp; Réponses</h3>\n                    <h4 class=\"mbr-section-subtitle mb-0 mt-2 mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showSubtitle\" data-app-selector=\".mbr-section-subtitle\" style=\"color: #373365;\">\n                       Créer et animer un groupe islamo-catholique — Service diocésain de Lille</h4>\n                </div>\n                <div id=\"bootstrap-accordion\" class=\"panel-group accordionStyles accordion\" role=\"tablist\" aria-multiselectable=\"true\">\n                    \n                    <!-- CATÉGORIE 1: Comprendre le dialogue interreligieux -->\n                    <h4 class=\"mbr-fonts-style mb-3 mt-4\" mbr-theme-style=\"display-2\" style=\"font-weight: bold; color: #373365;\">\n                        1. Comprendre le dialogue interreligieux\n                    </h4>\n\n                    <div class=\"card mb-3\">\n                        <div class=\"card-header\" role=\"tab\" id=\"heading1\">\n                            <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse1\" aria-expanded=\"false\" aria-controls=\"collapse1\">\n                                <h6 class=\"panel-title-edit mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\" style=\"color: #373365;\">Qu'est-ce que le dialogue interreligieux ? Pourquoi le favoriser ?</h6>\n                                <span class=\"sign mbr-iconfont mbri-arrow-down\"></span>\n                            </a>\n                        </div>\n                        <div id=\"collapse1\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"heading1\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                            <div class=\"panel-body\">\n                                <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\" style=\"color: #373365;\">C'est une rencontre authentique fondée sur le respect mutuel, sans syncrétisme ni prosélytisme. L'Église encourage ce dialogue depuis Vatican II car elle reconnaît en l'autre un frère créé par Dieu.</p>\n                            </div>\n                        </div>\n                    </div>\n\n                    <div class=\"card mb-3\" mbr-if=\"cardAmount > 1\">\n                        <div class=\"card-header\" role=\"tab\" id=\"heading2\">\n                            <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse2\" aria-expanded=\"false\" aria-controls=\"collapse2\">\n                                <h6 class=\"panel-title-edit mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\" style=\"color: #373365;\">Le dialogue signifie-t-il renoncer à sa foi ? Peut-on prier ensemble ?</h6>\n                                <span class=\"sign mbr-iconfont mbri-arrow-down\"></span>\n                            </a>\n                        </div>\n                        <div id=\"collapse2\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"heading2\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                            <div class=\"panel-body\">\n                                <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\" style=\"color: #373365;\">Non, il exige au contraire d'être enraciné dans sa propre identité. Les chrétiens et musulmans ne prient pas ensemble au sens rituel, mais chacun peut prier selon sa foi dans le respect de l'autre.</p>\n                            </div>\n                        </div>\n                    </div>\n\n                    <!-- CATÉGORIE 2: Questions théologiques -->\n                    <h4 class=\"mbr-fonts-style mb-3 mt-4\" mbr-theme-style=\"display-2\" style=\"font-weight: bold; color: #373365;\">\n                        2. Questions théologiques\n                    </h4>\n\n                    <div class=\"card mb-3\" mbr-if=\"cardAmount > 2\">\n                        <div class=\"card-header\" role=\"tab\" id=\"heading3\">\n                            <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse3\" aria-expanded=\"false\" aria-controls=\"collapse3\">\n                                <h6 class=\"panel-title-edit mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\" style=\"color: #373365;\">Les chrétiens croient-ils en un seul Dieu ? Jésus, Fils de Dieu ?</h6>\n                                <span class=\"sign mbr-iconfont mbri-arrow-down\"></span>\n                            </a>\n                        </div>\n                        <div id=\"collapse3\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"heading3\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                            <div class=\"panel-body\">\n                                <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\" style=\"color: #373365;\">Oui, les chrétiens sont monothéistes : « Je crois en un seul Dieu ». La Trinité n'est pas trois dieux mais trois « personnes » en un seul Dieu. « Fils de Dieu » exprime une relation intime d'amour, non une génération physique. Jésus révèle Dieu comme Amour qui se donne jusqu'à la croix.</p>\n                            </div>\n                        </div>\n                    </div>\n\n                    <div class=\"card mb-3\" mbr-if=\"cardAmount > 2\">\n                        <div class=\"card-header\" role=\"tab\" id=\"heading4\">\n                            <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse4\" aria-expanded=\"false\" aria-controls=\"collapse4\">\n                                <h6 class=\"panel-title-edit mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\" style=\"color: #373365;\">Pourquoi quatre Évangiles et non un seul livre révélé ?</h6>\n                                <span class=\"sign mbr-iconfont mbri-arrow-down\"></span>\n                            </a>\n                        </div>\n                        <div id=\"collapse4\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"heading4\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                            <div class=\"panel-body\">\n                                <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\" style=\"color: #373365;\">Pour les chrétiens, la Parole de Dieu est d'abord une Personne : Jésus-Christ. Les quatre Évangiles sont des témoignages inspirés de l'expérience des Apôtres. Cette diversité invite à méditer le mystère du Christ sous différents angles.</p>\n                            </div>\n                        </div>\n                    </div>\n\n                    <!-- CATÉGORIE 3: Vivre le dialogue au quotidien -->\n                    <h4 class=\"mbr-fonts-style mb-3 mt-4\" mbr-theme-style=\"display-2\" style=\"font-weight: bold; color: #373365;\">\n                        3. Vivre le dialogue au quotidien\n                    </h4>\n\n                    <div class=\"card mb-3\" mbr-if=\"cardAmount > 3\">\n                        <div class=\"card-header\" role=\"tab\" id=\"heading5\">\n                            <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse5\" aria-expanded=\"false\" aria-controls=\"collapse5\">\n                                <h6 class=\"panel-title-edit mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\" style=\"color: #373365;\">Comment répondre à mes amis musulmans ? Mon enfant a un ami musulman ?</h6>\n                                <span class=\"sign mbr-iconfont mbri-arrow-down\"></span>\n                            </a>\n                        </div>\n                        <div id=\"collapse5\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"heading5\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                            <div class=\"panel-body\">\n                                <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\" style=\"color: #373365;\">Accueillez les questions comme un cadeau : écoutez sincèrement sans chercher à convaincre, témoignez avec simplicité, reconnaissez humblement ce que vous ne savez pas. C'est aussi une belle opportunité d'éducation à la fraternité pour votre enfant. Encouragez-le à respecter son ami et à s'intéresser à sa foi en identifiant les différences et points communs.</p>\n                            </div>\n                        </div>\n                    </div>\n\n                    <div class=\"card mb-3\" mbr-if=\"cardAmount > 3\">\n                        <div class=\"card-header\" role=\"tab\" id=\"heading6\">\n                            <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse6\" aria-expanded=\"false\" aria-controls=\"collapse6\">\n                                <h6 class=\"panel-title-edit mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\" style=\"color: #373365;\">Comment organiser un repas interreligieux ?</h6>\n                                <span class=\"sign mbr-iconfont mbri-arrow-down\"></span>\n                            </a>\n                        </div>\n                        <div id=\"collapse6\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"heading6\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                            <div class=\"panel-body\">\n                                <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\" style=\"color: #373365;\">Oui ! Un repas partagé est un geste de fraternité très fort. Prévoir un menu respectueux des prescriptions alimentaires (viande halal ou options végétariennes), éviter l'alcool si souhaité, prévoir un temps de parole où chacun peut partager. C'est l'occasion de célébrer ensemble et de renforcer les liens.</p>\n                            </div>\n                        </div>\n                    </div>\n\n                    <div class=\"card mb-3\" mbr-if=\"cardAmount > 3\">\n                        <div class=\"card-header\" role=\"tab\" id=\"heading7\">\n                            <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse7\" aria-expanded=\"false\" aria-controls=\"collapse7\">\n                                <h6 class=\"panel-title-edit mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\" style=\"color: #373365;\">Comment réagir face aux préjugés et à l'islamophobie ?</h6>\n                                <span class=\"sign mbr-iconfont mbri-arrow-down\"></span>\n                            </a>\n                        </div>\n                        <div id=\"collapse7\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"heading7\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                            <div class=\"panel-body\">\n                                <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\" style=\"color: #373365;\">Le chrétien est appelé à être artisan de paix et à combattre toute forme de discrimination. Face aux préjugés : 1) Témoignez de votre expérience positive du dialogue. 2) Rappelez que l'islam ne peut être réduit aux actes de quelques-uns. 3) Dénoncez fermement les amalgames et les discours de haine. 4) Soutenez concrètement vos frères et sœurs musulmans victimes de discrimination.</p>\n                            </div>\n                        </div>\n                    </div>\n\n                    <!-- CATÉGORIE 4: Créer et animer un groupe islamo-catholique -->\n                    <h4 class=\"mbr-fonts-style mb-3 mt-4\" mbr-theme-style=\"display-2\" style=\"font-weight: bold; color: #373365;\">\n                        4. Créer et animer un groupe islamo-catholique\n                    </h4>\n\n                    <div class=\"card mb-3\" mbr-if=\"cardAmount > 4\">\n                        <div class=\"card-header\" role=\"tab\" id=\"heading8\">\n                            <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse8\" aria-expanded=\"false\" aria-controls=\"collapse8\">\n                                <h6 class=\"panel-title-edit mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\" style=\"color: #373365;\">Pourquoi créer un groupe ? Quels sont les principes de base ?</h6>\n                                <span class=\"sign mbr-iconfont mbri-arrow-down\"></span>\n                            </a>\n                        </div>\n                        <div id=\"collapse8\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"heading8\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                            <div class=\"panel-body\">\n                                <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\" style=\"color: #373365;\">Favoriser le dialogue authentique, les liens d'amitié, les actions solidaires et témoigner de la charité mutuelle. <strong>Principes :</strong> respect mutuel des convictions, écoute bienveillante, équilibre entre les religions, confidentialité, absence de jugement et de prosélytisme.</p>\n                            </div>\n                        </div>\n                    </div>\n\n                    <div class=\"card mb-3\" mbr-if=\"cardAmount > 4\">\n                        <div class=\"card-header\" role=\"tab\" id=\"heading9\">\n                            <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse9\" aria-expanded=\"false\" aria-controls=\"collapse9\">\n                                <h6 class=\"panel-title-edit mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\" style=\"color: #373365;\">Comment créer un groupe ? Étapes et organisation</h6>\n                                <span class=\"sign mbr-iconfont mbri-arrow-down\"></span>\n                            </a>\n                        </div>\n                        <div id=\"collapse9\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"heading9\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                            <div class=\"panel-body\">\n                                <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\" style=\"color: #373365;\"><strong>Création :</strong> 1) Binôme animateur (1 musulman + 1 catholique). 2) Rassemblez 6-12 membres. 3) 1ère réunion pour fixer objectifs. 4) Rédigez ensemble une charte. <strong>Réunions (2h) :</strong> 15-20 min accueil • 45-60 min discussion • 15 min conclusion. Rythme : toutes les 2-4 semaines. Lieux : alternez salle paroissiale, musulmane, neutre.</p>\n                            </div>\n                        </div>\n                    </div>\n\n                    <div class=\"card mb-3\" mbr-if=\"cardAmount > 4\">\n                        <div class=\"card-header\" role=\"tab\" id=\"heading10\">\n                            <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse10\" aria-expanded=\"false\" aria-controls=\"collapse10\">\n                                <h6 class=\"panel-title-edit mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\" style=\"color: #373365;\">Rôle des animateurs. Sujets et actions ?</h6>\n                                <span class=\"sign mbr-iconfont mbri-arrow-down\"></span>\n                            </a>\n                        </div>\n                        <div id=\"collapse10\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"heading10\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                            <div class=\"panel-body\">\n                                <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\" style=\"color: #373365;\"><strong>Animateurs :</strong> préparent les réunions, veillent à l'équilibre, assurent l'écoute, gèrent les tensions. <strong>Sujets :</strong> figures spirituelles communes, prière, éducation des enfants, fêtes religieuses, engagement solidaire, famille et valeurs. <strong>Actions :</strong> visites de lieux de culte, repas partagés, projets solidaires, conférences, événements culturels.</p>\n                            </div>\n                        </div>\n                    </div>\n\n                    <div class=\"card mb-3\" mbr-if=\"cardAmount > 4\">\n                        <div class=\"card-header\" role=\"tab\" id=\"heading11\">\n                            <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse11\" aria-expanded=\"false\" aria-controls=\"collapse11\">\n                                <h6 class=\"panel-title-edit mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\" style=\"color: #373365;\">Comment réussir ? Gérer les conflits et l'essoufflement ?</h6>\n                                <span class=\"sign mbr-iconfont mbri-arrow-down\"></span>\n                            </a>\n                        </div>\n                        <div id=\"collapse11\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"heading11\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                            <div class=\"panel-body\">\n                                <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\" style=\"color: #373365;\"><strong>Réussite :</strong> écoutez sincèrement, préparez les réunions, témoignez avec humilité, diversifiez les activités, accueillez de nouveaux membres. <strong>Tensions :</strong> rappelez la charte, écoutez chacun, cherchez les points communs. <strong>Essoufflement :</strong> évaluez les sujets, diversifiez, prenez une pause si nécessaire. Contactez le Service diocésain si besoin.</p>\n                            </div>\n                        </div>\n                    </div>\n\n                    <!-- CATÉGORIE 5: Mariage islamo-catholique -->\n                    <h4 class=\"mbr-fonts-style mb-3 mt-4\" mbr-theme-style=\"display-2\" style=\"font-weight: bold; color: #373365;\">\n                        5. Mariage islamo-catholique\n                    </h4>\n\n                    <div class=\"card mb-3\" mbr-if=\"cardAmount > 5\">\n                        <div class=\"card-header\" role=\"tab\" id=\"heading12\">\n                            <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse12\" aria-expanded=\"false\" aria-controls=\"collapse12\">\n                                <h6 class=\"panel-title-edit mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\" style=\"color: #373365;\">Mariage à l'église avec un(e) musulman(e) ? Préparation ? Enfants ?</h6>\n                                <span class=\"sign mbr-iconfont mbri-arrow-down\"></span>\n                            </a>\n                        </div>\n                        <div id=\"collapse12\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"heading12\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                            <div class=\"panel-body\">\n                                <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\" style=\"color: #373365;\"><strong>Mariage :</strong> Oui, sous <strong>dispense de l'évêque</strong> (« mariage avec disparité de culte »). Célébration à l'église <strong>sans messe eucharistique</strong>. <strong>Préparation :</strong> plusieurs mois obligatoires avec prêtre/diacre, sessions mixtes, dialogue sur la foi, l'éducation des enfants, les pratiques religieuses. <strong>Enfants :</strong> l'Église demande au catholique de « tout faire » pour les baptiser dans la foi catholique, mais chaque couple décide selon sa conscience. <strong>Essentiel : en parler avant le mariage.</strong></p>\n                            </div>\n                        </div>\n                    </div>\n\n                    <!-- CATÉGORIE 6: Témoin de mariage ou baptême -->\n                    <h4 class=\"mbr-fonts-style mb-3 mt-4\" mbr-theme-style=\"display-2\" style=\"font-weight: bold; color: #373365;\">\n                        6. Témoin de mariage ou baptême – Règles canoniques\n                    </h4>\n\n                    <div class=\"card mb-3\" mbr-if=\"cardAmount > 6\">\n                        <div class=\"card-header\" role=\"tab\" id=\"heading13\">\n                            <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse13\" aria-expanded=\"false\" aria-controls=\"collapse13\">\n                                <h6 class=\"panel-title-edit mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\" style=\"color: #373365;\">Témoins de mariage et parrains de baptême</h6>\n                                <span class=\"sign mbr-iconfont mbri-arrow-down\"></span>\n                            </a>\n                        </div>\n                        <div id=\"collapse13\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"heading13\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                            <div class=\"panel-body\">\n                                <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\" style=\"color: #373365;\"><strong>Mariage :</strong> Aucune exigence religieuse pour les témoins. <strong>Baptême :</strong> Témoin doit être catholique (canon 874), sauf si baptisé non-catholique avec parrain catholique présent. <strong>Parrain :</strong> au moins 16 ans, catholique et confirmé, ayant reçu l'Eucharistie, menant une vie conforme à la foi, ne pas être parent du baptisé.</p>\n                            </div>\n                        </div>\n                    </div>\n\n                    <div class=\"card mb-3\" mbr-if=\"cardAmount > 6\">\n                        <div class=\"card-header\" role=\"tab\" id=\"heading14\">\n                            <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse14\" aria-expanded=\"false\" aria-controls=\"collapse14\">\n                                <h6 class=\"panel-title-edit mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\" style=\"color: #373365;\">Témoin non-catholique pour un baptême : comment accompagner ?</h6>\n                                <span class=\"sign mbr-iconfont mbri-arrow-down\"></span>\n                            </a>\n                        </div>\n                        <div id=\"collapse14\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"heading14\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                            <div class=\"panel-body\">\n                                <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\" style=\"color: #373365;\"><strong>1) Informer avec bienveillance :</strong> expliquez respectueusement les règles canoniques et leur sens pastoral. <strong>2) Proposer un dialogue :</strong> « Avez-vous un proche catholique qui pourrait être parrain ? » <strong>3) Vérifier les options :</strong> identifier un catholique ou envisager une autre participation (lecteur, porteur du cierge). <strong>4) Soutien pastoral :</strong> préparer la famille pour une cérémonie respectueuse et signifiante.</p>\n                            </div>\n                        </div>\n                    </div>\n\n                    <!-- CATÉGORIE 7: Ressources et accompagnement -->\n                    <h4 class=\"mbr-fonts-style mb-3 mt-4\" mbr-theme-style=\"display-2\" style=\"font-weight: bold; color: #373365;\">\n                        7. Ressources et accompagnement\n                    </h4>\n\n                    <div class=\"card mb-3\" mbr-if=\"cardAmount > 7\">\n                        <div class=\"card-header\" role=\"tab\" id=\"heading15\">\n                            <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse15\" aria-expanded=\"false\" aria-controls=\"collapse15\">\n                                <h6 class=\"panel-title-edit mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\" style=\"color: #373365;\">Formations, aide et ressources disponibles</h6>\n                                <span class=\"sign mbr-iconfont mbri-arrow-down\"></span>\n                            </a>\n                        </div>\n                        <div id=\"collapse15\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"heading15\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                            <div class=\"panel-body\">\n                                <p class=\"mbr-fonts-style panel-text\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text\" style=\"color: #373365;\"><strong>Service diocésain pour le dialogue interreligieux du diocèse de Lille</strong><br>📞 <strong>07 56 94 24 84</strong><br>✉️ jerome.montois@lille.catholique.fr<br><br><strong>Propose :</strong> formations au dialogue interreligieux, accompagnement des groupes, mise en réseau avec d'autres initiatives, soutien en cas de tensions, conflits ou discrimination.<br><br><strong>P. Pascal DAME</strong> (Couples islamo-catholiques)<br>📞 <strong>06 70 05 56 40</strong></p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "vcU7gqGAeh",
          "_anchor": "content16-5d",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
